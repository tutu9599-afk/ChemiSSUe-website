app.get('/sw.js', (c) => {
  // Return basic service worker
  const swContent = `
// Service Worker for ChemiSSUe PWA
const CACHE_NAME = 'chemissue-v1.0.0';

self.addEventListener('install', event => {
  console.log('[SW] Install event');
  self.skipWaiting();
});

self.addEventListener('activate', event => {
  console.log('[SW] Activate event');
  event.waitUntil(self.clients.claim());
});

self.addEventListener('fetch', event => {
  // Skip non-GET requests and API calls
  if (event.request.method !== 'GET' || 
      event.request.url.includes('/api/')) {
    return;
  }
  
  // Network first strategy for dynamic content
  event.respondWith(
    fetch(event.request).catch(() => {
      // Return cached version if network fails
      return caches.match(event.request);
    })
  );
});
  `;
  
  return new Response(swContent, {
    headers: { 
      'Content-Type': 'application/javascript',
      'Cache-Control': 'max-age=86400'
    }
  });
});

// Permission helper functions
async function getUserBoardPermission(env: any, userId: number, categorySlug: string, permission: string) {
  if (!userId || !categorySlug || !permission) return false;

  // Safe permission field validation
  const validPermissions = ['can_create', 'can_edit_own', 'can_edit_all', 'can_delete_own', 'can_delete_all', 'can_comment'];
  if (!validPermissions.includes(permission)) return false;

  const result = await env.DB.prepare(`
    SELECT u.role, u.id as user_id,
           bp.can_create, bp.can_edit_own, bp.can_edit_all, 
           bp.can_delete_own, bp.can_delete_all, bp.can_comment
    FROM users u
    JOIN categories c ON c.slug = ?
    LEFT JOIN board_permissions bp ON bp.category_id = c.id AND bp.role = u.role
    WHERE u.id = ? AND u.is_active = TRUE
  `).bind(categorySlug, userId).first();

  if (!result) return false;

  // Return the specific permission value
  return !!result[permission];
}

async function canUserCreatePost(env: any, userId: number, categorySlug: string) {
  return await getUserBoardPermission(env, userId, categorySlug, 'can_create');
}

async function canUserEditPost(env: any, userId: number, postId: number, categorySlug: string) {
  // Check if user can edit their own posts
  const canEditOwn = await getUserBoardPermission(env, userId, categorySlug, 'can_edit_own');
  const canEditAll = await getUserBoardPermission(env, userId, categorySlug, 'can_edit_all');
  
  if (canEditAll) return true;
  if (!canEditOwn) return false;
  
  // Check if this is user's own post
  const post = await env.DB.prepare(`
    SELECT user_id FROM posts WHERE id = ?
  `).bind(postId).first();
  
  return post && post.user_id === userId;
}

async function canUserDeletePost(env: any, userId: number, postId: number, categorySlug: string) {
  // Check if user can delete their own posts
  const canDeleteOwn = await getUserBoardPermission(env, userId, categorySlug, 'can_delete_own');
  const canDeleteAll = await getUserBoardPermission(env, userId, categorySlug, 'can_delete_all');
  
  if (canDeleteAll) return true;
  if (!canDeleteOwn) return false;
  
  // Check if this is user's own post
  const post = await env.DB.prepare(`
    SELECT user_id FROM posts WHERE id = ?
  `).bind(postId).first();
  
  return post && post.user_id === userId;
}

// Simple Authentication middleware
app.use('*', async (c, next) => {
  const sessionId = getCookie(c, 'session_id');
  let user = null;
  
  if (sessionId) {
    try {
      user = await getUserFromSession(c, sessionId);
    } catch (error) {
      // Session lookup failed, user remains null
    }
  }
  
  c.set('user', user);
  await next();
});

// Renderer middleware
app.use(renderer)

