            </button>
          </div>
        </div>
      </div>
    </section>

    {/* Values List */}
    <section class="py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">핵심 가치 목록</h2>
            <p class="text-sm text-gray-500">각 가치와 목표를 편집하고 순서를 조정하세요</p>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {values.map((value: any) => (
                <div class="value-card border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow" data-id={value.id}>
                  <div class="text-center">
                    <div class="mb-4">
                      <i class={`${value.icon || 'fas fa-star'} text-4xl text-primary-600`}></i>
                    </div>
                    <input 
                      type="text" 
                      class="value-title text-xl font-bold text-gray-900 text-center border-none bg-transparent w-full focus:ring-2 focus:ring-primary-500 focus:border-transparent rounded px-2 py-1 mb-3"
                      value={value.title}
                      placeholder="가치 제목"
                    />
                    <textarea 
                      class="value-description text-gray-600 text-center border-none bg-transparent w-full resize-none focus:ring-2 focus:ring-primary-500 focus:border-transparent rounded px-2 py-1 leading-relaxed"
                      rows="3"
                      placeholder="가치 설명"
                    >{value.description}</textarea>
                    
                    <div class="mt-4 flex justify-center space-x-2">
                      <button 
                        onclick={`editIcon(${value.id})`} 
                        class="text-blue-600 hover:text-blue-800 p-2 rounded"
                        title="아이콘 변경"
                      >
                        <i class="fas fa-palette"></i>
                      </button>
                      <button 
                        onclick={`saveValue(${value.id})`} 
                        class="text-green-600 hover:text-green-800 p-2 rounded"
                        title="저장"
                      >
                        <i class="fas fa-save"></i>
                      </button>
                      <button 
                        onclick={`deleteValue(${value.id})`} 
                        class="text-red-600 hover:text-red-800 p-2 rounded"
                        title="삭제"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            
            {values.length === 0 && (
              <div class="text-center py-12 text-gray-500">
                <i class="fas fa-heart text-4xl mb-4"></i>
                <p>가치 항목이 없습니다.</p>
                <button 
                  onclick="addNewValue()" 
                  class="mt-4 bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors"
                >
                  첫 번째 가치 추가하기
                </button>
              </div>
            )}
          </div>
        </div>

        {/* Icon Selector Modal */}
        <div id="icon-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
          <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-1/2 shadow-lg rounded-md bg-white">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">아이콘 선택</h3>
            <div class="grid grid-cols-6 gap-3 mb-4" id="icon-grid">
              {/* 아이콘들이 JavaScript로 동적 생성됩니다 */}
            </div>
            <div class="flex justify-end space-x-2">
              <button onclick="closeIconModal()" class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg">취소</button>
            </div>
          </div>
        </div>

        {/* Help */}
        <div class="mt-8 bg-orange-50 border border-orange-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-orange-900 mb-3">
            <i class="fas fa-info-circle mr-2"></i>
            가치 관리 가이드
          </h3>
          <ul class="text-sm text-orange-700 space-y-2">
            <li>• 각 카드를 클릭하여 제목과 설명을 편집하세요</li>
            <li>• 팔레트 아이콘을 클릭하여 다른 아이콘으로 변경할 수 있습니다</li>
            <li>• 변경사항은 저장 버튼을 클릭해야 적용됩니다</li>
            <li>• 조직의 핵심 가치를 명확하고 간결하게 표현하세요</li>
          </ul>
        </div>
      </div>
    </section>

    <script>{`
      let currentEditingId = null;
      
      const iconOptions = [
        'fa-heart', 'fa-star', 'fa-rocket', 'fa-graduation-cap', 'fa-hands-helping',
        'fa-lightbulb', 'fa-trophy', 'fa-target', 'fa-compass', 'fa-gem',
        'fa-fire', 'fa-mountain', 'fa-seedling', 'fa-infinity', 'fa-crown',
        'fa-shield-alt', 'fa-globe', 'fa-puzzle-piece', 'fa-handshake', 'fa-eye'
      ];
      
      // 새 가치 추가
      async function addNewValue() {
        const title = prompt('새 가치의 제목을 입력하세요:');
        if (!title) return;
        
        const description = prompt('가치 설명을 입력하세요:') || '';
        
        try {
          const response = await fetch('/api/admin/content/values-goals', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              title,
              description,
              icon: 'fas fa-star'
            })
          });
          
          const data = await response.json();
          if (data.success) {
            location.reload();
          } else {
            alert('추가 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 가치 저장
      async function saveValue(id) {
        const card = document.querySelector(\`[data-id="\${id}"]\`);
        const title = card.querySelector('.value-title').value;
        const description = card.querySelector('.value-description').value;
        
        if (!title) {
          alert('제목을 입력해주세요.');
          return;
        }
        
        try {
          const response = await fetch(\`/api/admin/content/values-goals/\${id}\`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, description })
          });
          
          const data = await response.json();
          if (data.success) {
            showNotification('저장되었습니다!', 'success');
          } else {
            alert('저장 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 가치 삭제
      async function deleteValue(id) {
        if (!confirm('정말로 이 가치를 삭제하시겠습니까?')) return;
        
        try {
          const response = await fetch(\`/api/admin/content/values-goals/\${id}\`, {
            method: 'DELETE'
          });
          
          const data = await response.json();
          if (data.success) {
            document.querySelector(\`[data-id="\${id}"]\`).remove();
            showNotification('삭제되었습니다!', 'success');
          } else {
            alert('삭제 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 아이콘 편집
      function editIcon(id) {
        currentEditingId = id;
        const iconGrid = document.getElementById('icon-grid');
        iconGrid.innerHTML = iconOptions.map(icon => 
          \`<button onclick="selectIcon('\${icon}')" class="p-3 border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-primary-500 transition-colors">
            <i class="fas \${icon} text-2xl text-gray-600"></i>
          </button>\`
        ).join('');
        document.getElementById('icon-modal').classList.remove('hidden');
      }
      
      // 아이콘 선택
      async function selectIcon(icon) {
        if (!currentEditingId) return;
        
        try {
          const response = await fetch(\`/api/admin/content/values-goals/\${currentEditingId}/icon\`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ icon: 'fas ' + icon })
          });
          
          const data = await response.json();
          if (data.success) {
            // Update icon in UI
            const card = document.querySelector(\`[data-id="\${currentEditingId}"]\`);
            const iconElement = card.querySelector('i');
            iconElement.className = 'fas ' + icon + ' text-4xl text-primary-600';
            
            closeIconModal();
            showNotification('아이콘이 변경되었습니다!', 'success');
          } else {
            alert('아이콘 변경 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 아이콘 모달 닫기
      function closeIconModal() {
        document.getElementById('icon-modal').classList.add('hidden');
        currentEditingId = null;
      }

      // 알림 표시
      function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = \`fixed top-4 right-4 z-50 px-6 py-3 rounded-md shadow-lg border \${
          type === 'success' 
            ? 'bg-green-50 text-green-800 border-green-200' 
            : 'bg-red-50 text-red-800 border-red-200'
        }\`;
        notification.innerHTML = \`
          <div class="flex items-center">
            <i class="fas \${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-2"></i>
            \${message}
          </div>
        \`;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
          if (document.body.contains(notification)) {
            document.body.removeChild(notification);
          }
        }, 3000);
      }
    `}</script>
  </div>
);

// API Routes for Content Management

// Create activity
app.post('/api/admin/content/activities', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const { category, title, description, icon } = await c.req.json();

    if (!category || !title) {
      return c.json({ error: '필수 필드가 누락되었습니다.' }, 400);
    }

    const result = await env.DB.prepare(`
      INSERT INTO activity_items (category, title, description, icon, item_order)
      VALUES (?, ?, ?, ?, (SELECT COALESCE(MAX(item_order), 0) + 1 FROM activity_items WHERE category = ?))
    `).bind(category, title, description || '', icon || 'fa-check', category).run();

    await env.DB.prepare(`
      INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
      VALUES ('activity_items', ?, 'created', ?, ?)
    `).bind(result.meta.last_row_id, title, user.id).run();

    return c.json({ success: true, id: result.meta.last_row_id });

  } catch (error) {
    console.error('Create activity error:', error);
    return c.json({ error: '활동 생성 중 오류가 발생했습니다.' }, 500);
  }
});

// Update activity
app.put('/api/admin/content/activities/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const id = c.req.param('id');
    const { title, description } = await c.req.json();

    if (!title) {
      return c.json({ error: '제목은 필수입니다.' }, 400);
    }

    await env.DB.prepare(`
      UPDATE activity_items 
      SET title = ?, description = ?, updated_at = datetime('now')
      WHERE id = ?
    `).bind(title, description || '', id).run();

    await env.DB.prepare(`
      INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
      VALUES ('activity_items', ?, 'updated', ?, ?)
    `).bind(id, title, user.id).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Update activity error:', error);
    return c.json({ error: '활동 업데이트 중 오류가 발생했습니다.' }, 500);
  }
});

// Delete activity
app.delete('/api/admin/content/activities/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const id = c.req.param('id');

    await env.DB.prepare(`
      UPDATE activity_items 
      SET is_active = FALSE, updated_at = datetime('now')
      WHERE id = ?
    `).bind(id).run();

    await env.DB.prepare(`
      INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
      VALUES ('activity_items', ?, 'deleted', 'true', ?)
    `).bind(id, user.id).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Delete activity error:', error);
    return c.json({ error: '활동 삭제 중 오류가 발생했습니다.' }, 500);
  }
});

