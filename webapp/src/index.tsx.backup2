                        type="text"
                        name="history.subtitle" 
                        value={historyData.subtitle}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                        placeholder="연혁 페이지 부제목"
                      />
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">
                        로고 이미지 URL
                      </label>
                      <input
                        type="url"
                        name="history.logo_url"
                        value={historyData.logo_url}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                        placeholder="로고 이미지 URL"
                      />
                    </div>
                  </div>
                </div>

                {/* 회칙 정보 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-gavel text-purple-600 mr-2"></i>
                    회칙 페이지 정보
                  </h2>
                  <div class="space-y-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">
                        페이지 제목
                      </label>
                      <input
                        type="text"
                        name="rules.title"
                        value={rulesData.title}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-purple-500 focus:border-purple-500"
                        placeholder="회칙 페이지 제목"
                      />
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">
                        부제목
                      </label>
                      <input
                        type="text"
                        name="rules.subtitle"
                        value={rulesData.subtitle}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-purple-500 focus:border-purple-500"
                        placeholder="회칙 페이지 부제목"
                      />
                    </div>
                    <div class="bg-gray-50 rounded-lg p-4">
                      <p class="text-sm text-gray-600">
                        <i class="fas fa-info-circle mr-2"></i>
                        회칙 내용은 코드에서 직접 관리됩니다. 내용 변경이 필요한 경우 개발자에게 문의하세요.
                      </p>
                    </div>
                  </div>
                </div>

                {/* 연락처 정보 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-phone text-indigo-600 mr-2"></i>
                    연락처 및 가입 안내
                  </h2>
                  <div class="space-y-4">
                    {contactInfo.results.map((item: any) => (
                      <div key={item.item_key}>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                          {item.item_label}
                        </label>
                        <textarea
                          name={`contact_info.${item.item_key}`}
                          rows="3"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500"
                          placeholder={item.item_label}
                        >{item.item_value}</textarea>
                      </div>
                    ))}
                  </div>
                </div>

                {/* 저장 버튼 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <div class="flex items-center justify-between">
                    <div>
                      <h3 class="text-lg font-medium text-gray-900">변경사항 저장</h3>
                      <p class="text-gray-600 text-sm mt-1">수정된 내용이 홈페이지에 즉시 반영됩니다.</p>
                    </div>
                    <div class="flex space-x-3">
                      <button
                        type="button"
                        onclick="location.reload()"
                        class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
                      >
                        <i class="fas fa-undo mr-2"></i>취소
                      </button>
                      <button
                        type="submit"
                        class="px-6 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition-colors"
                        id="save-btn"
                      >
                        <i class="fas fa-save mr-2"></i>저장하기
                      </button>
                    </div>
                  </div>
                </div>

              </form>
            </div>
          </section>
        </div>

        {/* 저장 처리 JavaScript */}
        <script>{`
          document.getElementById('homepage-edit-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const saveBtn = document.getElementById('save-btn');
            const originalText = saveBtn.innerHTML;
            saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>저장 중...';
            saveBtn.disabled = true;

            try {
              const formData = new FormData(this);
              const data = {};
              
              for (let [key, value] of formData.entries()) {
                data[key] = value;
              }

              const response = await fetch('/api/admin/homepage-content', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
              });

              const result = await response.json();

              if (result.success) {
                saveBtn.innerHTML = '<i class="fas fa-check mr-2"></i>저장 완료!';
                saveBtn.className = 'px-6 py-2 bg-green-600 text-white rounded-lg';
                
                setTimeout(() => {
                  saveBtn.innerHTML = originalText;
                  saveBtn.className = 'px-6 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition-colors';
                  saveBtn.disabled = false;
                }, 2000);
                
                alert('✅ 홈페이지 내용이 성공적으로 저장되었습니다!');
              } else {
                throw new Error(result.error || '저장 실패');
              }
            } catch (error) {
              console.error('Save error:', error);
              alert('❌ 저장 중 오류가 발생했습니다: ' + error.message);
              
              saveBtn.innerHTML = originalText;
              saveBtn.disabled = false;
            }
          });
        `}</script>
      </Layout>,
      { title: '홈페이지 내용 수정 - ChemiSSUe' }
    );

  } catch (error) {
    console.error('Homepage edit page error:', error);
    return c.render(
      <Layout user={user}>
        <div class="max-w-4xl mx-auto px-4 py-16">
          <div class="bg-red-50 border border-red-200 rounded-lg p-8 text-center">
            <i class="fas fa-exclamation-triangle text-red-600 text-4xl mb-4"></i>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">오류가 발생했습니다</h2>
            <p class="text-gray-600">페이지를 불러오는 중 문제가 발생했습니다.</p>
          </div>
        </div>
      </Layout>,
      { title: '오류' }
    );
  }
});

// 홈페이지 내용 저장 API
app.post('/api/admin/homepage-content', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const data = await c.req.json();

    // 각 섹션별로 업데이트
    for (const [key, value] of Object.entries(data)) {
      const parts = key.split('.');
      
      // 기존 content_items 처리 (about_us, professor_info, contact_info)
      if (parts.length === 2 && ['about_us', 'professor_info', 'contact_info'].includes(parts[0])) {
        const [sectionKey, itemKey] = parts;
        
        if (sectionKey && itemKey && value) {
          await env.DB.prepare(`
            UPDATE content_items 
            SET item_value = ?, updated_at = datetime('now')
            WHERE section_key = ? AND item_key = ?
          `).bind(value, sectionKey, itemKey).run();

          // 변경 로그 기록
          await env.DB.prepare(`
            INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
            VALUES ('content_items', ?, 'item_value', ?, ?)
          `).bind(`${sectionKey}.${itemKey}`, value, user.id).run();
        }
      }
      
      // 활동 데이터 처리 (academic, communication)
      else if (parts.length === 3 && ['academic', 'communication'].includes(parts[0])) {
        const [category, id, field] = parts;
        
        if (category && id && field && value) {
          await env.DB.prepare(`
            UPDATE activity_items 
            SET ${field} = ?, updated_at = datetime('now')
            WHERE id = ? AND category = ?
          `).bind(value, id, category).run();

          // 변경 로그 기록
          await env.DB.prepare(`
            INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
            VALUES ('activity_items', ?, ?, ?, ?)
          `).bind(id, field, value, user.id).run();
        }
      }
      
      // 가치와 목표 데이터 처리 (values)
      else if (parts.length === 3 && parts[0] === 'values') {
        const [, id, field] = parts;
        
        if (id && field && value) {
          await env.DB.prepare(`
            UPDATE values_goals 
            SET ${field} = ?, updated_at = datetime('now')
            WHERE id = ?
          `).bind(value, id).run();

          // 변경 로그 기록
          await env.DB.prepare(`
            INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
            VALUES ('values_goals', ?, ?, ?, ?)
          `).bind(id, field, value, user.id).run();
        }
      }
    }

    return c.json({ success: true });

  } catch (error) {
    console.error('Homepage content save error:', error);
    return c.json({ error: '저장 중 오류가 발생했습니다.' }, 500);
  }
});

// 페이지 콘텐츠 편집 - 전체 페이지 관리
app.get('/admin/pages', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  const { env } = c;

  try {
    // 모든 페이지 콘텐츠 가져오기
    const pages = await env.DB.prepare(`
      SELECT page_key, title, description, is_published, updated_at, 
             (SELECT username FROM users WHERE id = page_contents.updated_by) as updated_by_name
      FROM page_contents 
      ORDER BY updated_at DESC
    `).all();

    return c.html(`
      <!DOCTYPE html>
      <html lang="ko">
      <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>페이지 관리 - ChemiSSUe 관리자</title>
          <script src="https://cdn.tailwindcss.com"></script>
          <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" rel="stylesheet">
          <script>
            tailwind.config = {
              theme: {
                extend: {
                  colors: {
                    primary: {"50":"#eff6ff","100":"#dbeafe","500":"#3b82f6","600":"#2563eb","700":"#1d4ed8"},
                    secondary: {"50":"#f0f9ff","100":"#e0f2fe","500":"#06b6d4","600":"#0891b2","700":"#0e7490"}
                  }
                }
              }
            }
          </script>
      </head>
      <body class="bg-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="mb-6">
            <div class="flex items-center justify-between">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-edit mr-2 text-primary-600"></i>
                페이지 관리
              </h1>
              <a href="/admin" class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors">
                <i class="fas fa-arrow-left mr-2"></i>
                관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">웹사이트의 모든 페이지 콘텐츠를 관리할 수 있습니다.</p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            ${pages.results.map((page: any) => `
              <div class="bg-white rounded-lg shadow-sm p-6 border-l-4 ${page.is_published ? 'border-green-500' : 'border-yellow-500'}">
                <div class="flex items-center justify-between">
                  <div class="flex-1">
                    <div class="flex items-center">
                      <h3 class="text-xl font-semibold text-gray-900 mr-3">${page.title}</h3>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                        page.is_published 
                          ? 'bg-green-100 text-green-800' 
                          : 'bg-yellow-100 text-yellow-800'
                      }">
                        <i class="fas fa-${page.is_published ? 'check' : 'clock'} mr-1"></i>
                        ${page.is_published ? '게시됨' : '비공개'}
                      </span>
                    </div>
                    <p class="text-gray-600 mt-1">${page.description || ''}</p>
                    <p class="text-sm text-gray-500 mt-2">
                      <i class="fas fa-user mr-1"></i>
                      ${page.updated_by_name} · ${new Date(page.updated_at).toLocaleString('ko-KR')}
                    </p>
                  </div>
                  <div class="flex space-x-2">
                    <a href="/admin/pages/${page.page_key}/edit" 
                       class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                      <i class="fas fa-edit mr-2"></i>
                      편집
                    </a>
                    <a href="/${page.page_key}" target="_blank"
                       class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors">
                      <i class="fas fa-external-link-alt mr-2"></i>
                      보기
                    </a>
                  </div>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      </body>
      </html>
    `);

  } catch (error) {
    console.error('페이지 목록 조회 오류:', error);
    return c.html('<h1>오류가 발생했습니다.</h1>', 500);
  }
});

// 개별 페이지 콘텐츠 편집
app.get('/admin/pages/:pageKey/edit', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  const { env } = c;
  const pageKey = c.req.param('pageKey');

  try {
    // 페이지 콘텐츠 가져오기
    const pageContent = await env.DB.prepare(`
      SELECT * FROM page_contents WHERE page_key = ?
    `).bind(pageKey).first();

    if (!pageContent) {
      return c.html('<h1>페이지를 찾을 수 없습니다.</h1>', 404);
    }

    return c.html(`
      <!DOCTYPE html>
      <html lang="ko">
      <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0">
          <title>${pageContent.title} 편집 - ChemiSSUe 관리자</title>
          <script src="https://cdn.tailwindcss.com"></script>
          <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" rel="stylesheet">
          
          <!-- Quill Editor CSS -->
          <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
          <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
          
          <script>
            tailwind.config = {
              theme: {
                extend: {
                  colors: {
                    primary: {"50":"#eff6ff","100":"#dbeafe","500":"#3b82f6","600":"#2563eb","700":"#1d4ed8"},
                    secondary: {"50":"#f0f9ff","100":"#e0f2fe","500":"#06b6d4","600":"#0891b2","700":"#0e7490"}
                  }
                }
              }
            }
          </script>
      </head>
      <body class="bg-gray-100">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="mb-6">
            <div class="flex items-center justify-between">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-edit mr-2 text-primary-600"></i>
                ${pageContent.title} 편집
              </h1>
              <div class="flex space-x-3">
                <a href="/admin/pages" class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors">
                  <i class="fas fa-arrow-left mr-2"></i>
                  페이지 목록
                </a>
                <a href="/${pageKey}" target="_blank" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors">
                  <i class="fas fa-external-link-alt mr-2"></i>
                  미리보기
                </a>
              </div>
            </div>
          </div>

          <form id="pageEditForm" class="space-y-6">
            <!-- 기본 정보 -->
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-info-circle text-blue-600 mr-2"></i>
                페이지 기본 정보
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">페이지 제목</label>
                  <input type="text" name="title" value="${pageContent.title}" 
                         class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                         required>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">페이지 설명</label>
                  <input type="text" name="description" value="${pageContent.description || ''}"
                         class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
              </div>
            </div>

            <!-- 메타 정보 -->
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-tags text-purple-600 mr-2"></i>
                SEO 메타 정보
              </h2>
              
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">메타 제목</label>
                  <input type="text" name="meta_title" value="${pageContent.meta_title || ''}"
                         class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-purple-500 focus:border-purple-500">
                  <p class="text-xs text-gray-500 mt-1">검색엔진에 표시될 제목입니다.</p>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">메타 설명</label>
                  <textarea name="meta_description" rows="3" 
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-purple-500 focus:border-purple-500">${pageContent.meta_description || ''}</textarea>
                  <p class="text-xs text-gray-500 mt-1">검색엔진에 표시될 설명입니다.</p>
                </div>
              </div>
            </div>

            <!-- 본문 내용 -->
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-file-alt text-green-600 mr-2"></i>
                페이지 본문 내용
              </h2>
              
              <div class="mb-4">
                <div id="editor-container" style="height: 400px;"></div>
                <input type="hidden" name="content" id="content-input">
              </div>
              
              <div class="text-sm text-gray-600 bg-gray-50 p-3 rounded">
                <i class="fas fa-info-circle mr-2"></i>
                <strong>사용 팁:</strong> 제목, 목록, 링크, 이미지 등을 자유롭게 사용할 수 있습니다. 
                게시판 글쓰기와 동일한 방식으로 편집하세요.
              </div>
            </div>

            <!-- 공개 설정 -->
            <div class="bg-white rounded-lg shadow-sm p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-eye text-indigo-600 mr-2"></i>
                공개 설정
              </h2>
              
              <div class="flex items-center">
                <input type="checkbox" name="is_published" id="is_published" 
                       ${pageContent.is_published ? 'checked' : ''}
                       class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                <label for="is_published" class="ml-2 text-sm text-gray-700">
                  이 페이지를 공개합니다
                </label>
              </div>
              <p class="text-xs text-gray-500 mt-2">
                비공개로 설정하면 관리자만 페이지를 볼 수 있습니다.
              </p>
            </div>

            <!-- 저장 버튼 -->
            <div class="bg-white rounded-lg shadow-sm p-6">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="text-lg font-medium text-gray-900">변경사항 저장</h3>
                  <p class="text-gray-600 text-sm mt-1">수정된 내용이 웹사이트에 즉시 반영됩니다.</p>
                </div>
                <div class="flex space-x-3">
                  <button type="button" onclick="previewContent()" 
                          class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                    <i class="fas fa-eye mr-2"></i>
                    미리보기
                  </button>
                  <button type="submit" 
                          class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition-colors">
                    <i class="fas fa-save mr-2"></i>
                    저장하기
                  </button>
                </div>
              </div>
            </div>
          </form>
        </div>

        <script>
          // Quill 에디터 초기화
          const quill = new Quill('#editor-container', {
            theme: 'snow',
            modules: {
              toolbar: [
                [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'color': [] }, { 'background': [] }],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                [{ 'indent': '-1'}, { 'indent': '+1' }],
                ['link', 'image', 'video'],
                ['blockquote', 'code-block'],
                [{ 'align': [] }],
                ['clean']
              ]
            }
          });

          // 기존 콘텐츠 로드
          quill.root.innerHTML = \`${pageContent.content || ''}\`;

          // 폼 제출 처리
          document.getElementById('pageEditForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Quill 에디터의 내용을 hidden input에 저장
            document.getElementById('content-input').value = quill.root.innerHTML;
            
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            
            // 체크박스 처리
            data.is_published = formData.has('is_published') ? 1 : 0;
            
            try {
              const response = await fetch('/admin/pages/${pageKey}/save', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
              });
              
              if (response.ok) {
                alert('성공적으로 저장되었습니다!');
                window.location.href = '/admin/pages';
              } else {
                alert('저장 중 오류가 발생했습니다.');
              }
            } catch (error) {
              console.error('저장 오류:', error);
              alert('저장 중 오류가 발생했습니다.');
            }
          });

          // 미리보기 기능
          function previewContent() {
            const content = quill.root.innerHTML;
            const title = document.querySelector('input[name="title"]').value;
            
            const previewWindow = window.open('', 'preview', 'width=800,height=600');
            previewWindow.document.write(\`
              <!DOCTYPE html>
              <html lang="ko">
              <head>
                <meta charset="UTF-8">
                <title>\${title} - 미리보기</title>
                <script src="https://cdn.tailwindcss.com"></script>
              </head>
              <body class="bg-gray-100 p-8">
                <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-sm p-8">
                  <h1 class="text-3xl font-bold text-gray-900 mb-6">\${title}</h1>
                  <div class="prose max-w-none">\${content}</div>
                </div>
              </body>
              </html>
            \`);
          }
        </script>
      </body>
      </html>
    `);

  } catch (error) {
    console.error('페이지 편집 오류:', error);
    return c.html('<h1>오류가 발생했습니다.</h1>', 500);
  }
});

// 페이지 콘텐츠 저장
app.post('/admin/pages/:pageKey/save', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  const { env } = c;
  const pageKey = c.req.param('pageKey');
  const data = await c.req.json();

  try {
    // 페이지 콘텐츠 업데이트
    await env.DB.prepare(`
      UPDATE page_contents 
      SET title = ?, description = ?, content = ?, 
          meta_title = ?, meta_description = ?, is_published = ?,
          updated_by = ?, updated_at = datetime('now')
      WHERE page_key = ?
    `).bind(
      data.title,
      data.description,
      data.content,
      data.meta_title,
      data.meta_description,
      data.is_published,
      user.id,
      pageKey
    ).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('페이지 저장 오류:', error);
    return c.json({ error: '저장 중 오류가 발생했습니다.' }, 500);
  }
});

export default app
