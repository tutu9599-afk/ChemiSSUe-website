// CONTENT MANAGEMENT SYSTEM (CMS) ROUTES
// =================

// Admin Content Management Main Page
app.get('/admin/content', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get content statistics
    const stats = await Promise.all([
      env.DB.prepare('SELECT COUNT(*) as count FROM content_sections').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM content_items').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM activity_items').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM values_goals').first()
    ]);

    const [sectionsCount, itemsCount, activitiesCount, valuesCount] = stats;

    // Get all content sections
    const sections = await env.DB.prepare(`
      SELECT * FROM content_sections WHERE is_active = TRUE ORDER BY section_key
    `).all();

    return c.render(
      <Layout user={user}>
        <AdminContentManagement 
          stats={{
            sections: sectionsCount.count,
            items: itemsCount.count,
            activities: activitiesCount.count,
            values: valuesCount.count
          }}
          sections={sections.results}
        />
      </Layout>,
      { title: '콘텐츠 관리' }
    );

  } catch (error) {
    console.error('Admin content error:', error);
    return c.redirect('/admin');
  }
});

