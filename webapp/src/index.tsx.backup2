// 간단한 홈페이지 편집 페이지
app.get('/admin/homepage-edit', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  const { env } = c;

  try {
    // 현재 CMS 콘텐츠 데이터 가져오기
    const aboutUsContent = await env.DB.prepare(`
      SELECT item_key, item_label, item_value, item_type
      FROM content_items 
      WHERE section_key = 'about_us' AND is_active = 1
      ORDER BY item_order ASC
    `).all();

    const professorInfo = await env.DB.prepare(`
      SELECT item_key, item_label, item_value, item_type
      FROM content_items 
      WHERE section_key = 'professor_info' AND is_active = 1
      ORDER BY item_order ASC
    `).all();

    const contactInfo = await env.DB.prepare(`
      SELECT item_key, item_label, item_value, item_type
      FROM content_items 
      WHERE section_key = 'contact_info' AND is_active = 1
      ORDER BY item_order ASC
    `).all();

    // 활동 데이터 가져오기
    const academicActivities = await env.DB.prepare(`
      SELECT id, title, description, icon
      FROM activity_items 
      WHERE category = 'academic' AND is_active = 1
      ORDER BY item_order ASC
    `).all();

    const communicationActivities = await env.DB.prepare(`
      SELECT id, title, description, icon
      FROM activity_items 
      WHERE category = 'communication' AND is_active = 1
      ORDER BY item_order ASC
    `).all();

    // 가치와 목표 데이터 가져오기
    const valuesGoals = await env.DB.prepare(`
      SELECT id, title, description, icon
      FROM values_goals 
      WHERE is_active = 1
      ORDER BY item_order ASC
    `).all();

    // 연혁과 회칙은 간단한 텍스트로 관리
    const historyData = {
      title: 'ChemiSSUe 연혁',
      subtitle: '함께 성장해온 우리의 발자취',
      logo_url: 'https://page.gensparksite.com/v1/base64_upload/3112448ea471353bb7c3b074a1213546'
    };

    const rulesData = {
      title: 'ChemiSSUe 회칙', 
      subtitle: '소모임 운영을 위한 기본 규칙과 원칙'
    };

    return c.render(
      <Layout user={user}>
        <div class="bg-gray-50 min-h-screen">
          {/* Header */}
          <section class="bg-white shadow-sm">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
              <div class="flex items-center justify-between">
                <div>
                  <h1 class="text-3xl font-bold text-gray-900">
                    <i class="fas fa-home text-orange-600 mr-3"></i>
                    홈페이지 내용 수정
                  </h1>
                  <p class="text-gray-600 mt-2">홈페이지에 표시되는 내용을 간단히 수정할 수 있습니다.</p>
                </div>
                <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                  <i class="fas fa-arrow-left mr-2"></i>관리자 패널
                </a>
              </div>
            </div>
          </section>

          {/* 편집 폼 */}
          <section class="py-8">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
              <form id="homepage-edit-form" class="space-y-8">
                
                {/* 소모임 소개 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-users text-blue-600 mr-2"></i>
                    소모임 소개 ("우리는 누구인가요?" 섹션)
                  </h2>
                  <div class="space-y-4">
                    {aboutUsContent.results.map((item: any) => (
                      <div key={item.item_key}>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                          {item.item_label}
                        </label>
                        {item.item_key === 'main_title' ? (
                          <input
                            type="text"
                            name={`about_us.${item.item_key}`}
                            value={item.item_value}
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-orange-500 focus:border-orange-500"
                            placeholder={item.item_label}
                          />
                        ) : (
                          <textarea
                            name={`about_us.${item.item_key}`}
                            rows="3"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-orange-500 focus:border-orange-500"
                            placeholder={item.item_label}
                          >{item.item_value}</textarea>
                        )}
                      </div>
                    ))}
                  </div>
                </div>

                {/* 지도교수 정보 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-user-tie text-green-600 mr-2"></i>
                    지도교수 정보
                  </h2>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {professorInfo.results.map((item: any) => (
                      <div key={item.item_key}>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                          {item.item_label}
                        </label>
                        {item.item_key === 'note' ? (
                          <textarea
                            name={`professor_info.${item.item_key}`}
                            rows="3"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-green-500 focus:border-green-500"
                            placeholder={item.item_label}
                          >{item.item_value}</textarea>
                        ) : (
                          <input
                            type="text"
                            name={`professor_info.${item.item_key}`}
                            value={item.item_value}
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-green-500 focus:border-green-500"
                            placeholder={item.item_label}
                          />
                        )}
                      </div>
                    ))}
                  </div>
                </div>

                {/* 학습 활동 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-book-open text-blue-600 mr-2"></i>
                    학습 활동
                  </h2>
                  <div class="space-y-4">
                    {academicActivities.results.map((activity: any, index: number) => (
                      <div key={activity.id} class="border border-gray-200 rounded-lg p-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              활동 제목 {index + 1}
                            </label>
                            <input
                              type="text"
                              name={`academic.${activity.id}.title`}
                              value={activity.title}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                              placeholder="활동 제목"
                            />
                          </div>
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              아이콘 클래스
                            </label>
                            <input
                              type="text"
                              name={`academic.${activity.id}.icon`}
                              value={activity.icon}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                              placeholder="예: fas fa-check"
                            />
                          </div>
                        </div>
                        <div class="mt-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2">
                            활동 설명
                          </label>
                          <textarea
                            name={`academic.${activity.id}.description`}
                            rows="2"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                            placeholder="활동에 대한 설명"
                          >{activity.description}</textarea>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                {/* 소통 활동 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-users text-green-600 mr-2"></i>
                    소통 활동
                  </h2>
                  <div class="space-y-4">
                    {communicationActivities.results.map((activity: any, index: number) => (
                      <div key={activity.id} class="border border-gray-200 rounded-lg p-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              활동 제목 {index + 1}
                            </label>
                            <input
                              type="text"
                              name={`communication.${activity.id}.title`}
                              value={activity.title}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-green-500 focus:border-green-500"
                              placeholder="활동 제목"
                            />
                          </div>
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              아이콘 클래스
                            </label>
                            <input
                              type="text"
                              name={`communication.${activity.id}.icon`}
                              value={activity.icon}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-green-500 focus:border-green-500"
                              placeholder="예: fas fa-check"
                            />
                          </div>
                        </div>
                        <div class="mt-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2">
                            활동 설명
                          </label>
                          <textarea
                            name={`communication.${activity.id}.description`}
                            rows="2"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-green-500 focus:border-green-500"
                            placeholder="활동에 대한 설명"
                          >{activity.description}</textarea>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                {/* 우리의 가치와 목표 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-heart text-red-600 mr-2"></i>
                    우리의 가치와 목표
                  </h2>
                  <div class="space-y-4">
                    {valuesGoals.results.map((value: any, index: number) => (
                      <div key={value.id} class="border border-gray-200 rounded-lg p-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              가치/목표 제목 {index + 1}
                            </label>
                            <input
                              type="text"
                              name={`values.${value.id}.title`}
                              value={value.title}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-red-500 focus:border-red-500"
                              placeholder="가치/목표 제목"
                            />
                          </div>
                          <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                              아이콘 클래스
                            </label>
                            <input
                              type="text"
                              name={`values.${value.id}.icon`}
                              value={value.icon}
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-red-500 focus:border-red-500"
                              placeholder="예: fas fa-graduation-cap"
                            />
                          </div>
                        </div>
                        <div class="mt-4">
                          <label class="block text-sm font-medium text-gray-700 mb-2">
                            설명
                          </label>
                          <textarea
                            name={`values.${value.id}.description`}
                            rows="2"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-red-500 focus:border-red-500"
                            placeholder="가치/목표에 대한 설명"
                          >{value.description}</textarea>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                {/* 연혁 정보 섹션 */}
                <div class="bg-white rounded-lg shadow-sm p-6">
                  <h2 class="text-xl font-semibold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-history text-blue-600 mr-2"></i>
                    연혁 페이지 정보
