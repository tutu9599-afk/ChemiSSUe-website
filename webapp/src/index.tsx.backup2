app.get('/static/style.css', (c) => {
  const css = `
/* ChemiSSUe Custom Styles */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  line-height: 1.6;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.gradient-text {
  background: linear-gradient(135deg, #2563eb 0%, #06b6d4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.card-hover {
  transition: all 0.3s ease;
}

.card-hover:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

.hero-pattern {
  background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0);
  background-size: 20px 20px;
}

/* Loading animation */
@keyframes spin {
  to { transform: rotate(360deg); }
}

.animate-spin {
  animation: spin 1s linear infinite;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f5f9;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Mobile responsiveness */
@media (max-width: 640px) {
  .mobile-center {
    text-align: center;
  }
}

/* Notification animations */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100%);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.notification-slide-in {
  animation: slideInRight 0.3s ease-out;
}

/* Button hover effects */
.btn-hover {
  transition: all 0.2s ease;
}

.btn-hover:hover {
  transform: translateY(-1px);
}

/* Form focus styles */
.form-input:focus {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

/* Dark mode support */
@media (prefers-color-scheme: dark) {
  .dark-mode-text {
    color: #f8fafc;
  }
  
  .dark-mode-bg {
    background-color: #1e293b;
  }
}
  `;
  
  return new Response(css, {
    headers: { 
      'Content-Type': 'text/css',
      'Cache-Control': 'public, max-age=86400'
    }
  });
})

app.get('/static/app.js', (c) => {
  const js = `
// ChemiSSUe Frontend JavaScript

// Global utilities
window.ChemiSSUe = {
  showNotification: function(message, type = 'info') {
    console.log('[Notification]', type, message);
  },
  
  debugSession: function() {
    const cookies = document.cookie.split(';').reduce((acc, cookie) => {
      const [name, value] = cookie.trim().split('=');
      acc[name] = value;
      return acc;
    }, {});
    
    console.log('=== SESSION DEBUG ===');
    console.log('All cookies:', document.cookie);
    console.log('Session ID:', cookies.session_id || 'NOT FOUND');
    console.log('Current URL:', window.location.href);
    console.log('User agent:', navigator.userAgent);
    console.log('=====================');
    
    // Test session validation
    if (cookies.session_id) {
      fetch('/api/auth/validate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        credentials: 'include'
      })
      .then(response => response.json())
      .then(data => {
        console.log('Session validation result:', data);
      })
      .catch(error => {
        console.error('Session validation error:', error);
      });
    }
    
    return cookies;
  },
  
  initializeComponents: function() {
    console.log('[ChemiSSUe] Components initialized');
    
    // Auto-debug session on board pages
    if (window.location.pathname.startsWith('/board/')) {
      console.log('[DEBUG] Board page detected, checking session...');
      setTimeout(() => {
        window.ChemiSSUe.debugSession();
      }, 1000);
    }
  }
};

// Initialize on DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => {
    window.ChemiSSUe.initializeComponents();
  });
} else {
  window.ChemiSSUe.initializeComponents();
}

console.log('[ChemiSSUe] App.js loaded successfully');
  `;
  
  return new Response(js, {
    headers: { 
      'Content-Type': 'application/javascript',
      'Cache-Control': 'public, max-age=86400'
    }
  });
})

