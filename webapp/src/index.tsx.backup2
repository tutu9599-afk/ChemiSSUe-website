    });

  } catch (error) {
    console.error('Get user details error:', error);
    return c.json({ error: '사용자 정보를 불러올 수 없습니다.' }, 500);
  }
});

// Admin Reports Page (활동 보고서)
app.get('/admin/reports', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 날짜 범위 설정
    const today = new Date().toISOString().split('T')[0];
    const lastWeek = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    const lastMonth = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

    // 회원 활동 통계
    const userStats = await Promise.all([
      // 활성 회원 수
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = TRUE').first(),
      // 비활성 회원 수  
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = 0').first(),
      // 승인 대기 회원 수
      env.DB.prepare("SELECT COUNT(*) as count FROM users WHERE approval_status = 'pending'").first(),
      // 거부된 회원 수
      env.DB.prepare("SELECT COUNT(*) as count FROM users WHERE approval_status = 'rejected'").first(),
      // 이번 주 신규 가입자
      env.DB.prepare(`SELECT COUNT(*) as count FROM users WHERE created_at >= datetime('${lastWeek}')`).first(),
    ]);

    // 게시글/댓글 활동 통계
    const contentStats = await Promise.all([
      // 총 게시글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM posts').first(),
      // 이번 주 게시글 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM posts WHERE created_at >= datetime('${lastWeek}')`).first(),
      // 총 댓글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM comments').first(),
      // 이번 주 댓글 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM comments WHERE created_at >= datetime('${lastWeek}')`).first(),
      // 총 이벤트 수
      env.DB.prepare('SELECT COUNT(*) as count FROM events').first(),
    ]);

    // 게시판별 활동 통계
    const boardStats = await env.DB.prepare(`
      SELECT 
        c.name as board_name,
        c.id as board_id,
        COUNT(p.id) as post_count,
        COUNT(CASE WHEN p.created_at >= datetime('${lastWeek}') THEN 1 END) as weekly_posts
      FROM categories c
      LEFT JOIN posts p ON c.id = p.category_id
      GROUP BY c.id, c.name
      ORDER BY post_count DESC
    `).all();

    // 최근 활동한 회원 목록
    const activeUsers = await env.DB.prepare(`
      SELECT 
        u.username,
        u.full_name,
        u.role,
        COUNT(DISTINCT p.id) as post_count,
        COUNT(DISTINCT c.id) as comment_count,
        MAX(COALESCE(p.created_at, c.created_at)) as last_activity
      FROM users u
      LEFT JOIN posts p ON u.id = p.user_id AND p.created_at >= datetime('${lastMonth}')
      LEFT JOIN comments c ON u.id = c.user_id AND c.created_at >= datetime('${lastMonth}')
      WHERE u.is_active = 1
      GROUP BY u.id, u.username, u.full_name, u.role
      HAVING (post_count > 0 OR comment_count > 0)
      ORDER BY last_activity DESC
      LIMIT 20
    `).all();

    // 인기 게시글 (좋아요 기준)
    const popularPosts = await env.DB.prepare(`
      SELECT 
        p.title,
        p.created_at,
        u.username as author,
        c.name as board_name,
        p.like_count,
        p.view_count
      FROM posts p
      JOIN users u ON p.user_id = u.id
      JOIN categories c ON p.category_id = c.id
      WHERE p.created_at >= datetime('${lastMonth}')
      ORDER BY p.like_count DESC, p.view_count DESC
      LIMIT 10
    `).all();

    const [activeUserCount, inactiveUserCount, pendingUserCount, rejectedUserCount, weeklyNewUsers] = userStats;
    const [totalPosts, weeklyPosts, totalComments, weeklyComments, totalEvents] = contentStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-chart-bar text-primary-600 mr-3"></i>
                활동 보고서
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">ChemiSSUe 회원 활동 및 콘텐츠 현황 보고서</p>
          </div>

          {/* 회원 활동 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-user-check text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 회원</p>
                  <p class="text-2xl font-bold text-gray-900">{activeUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-gray-100 text-gray-600">
                  <i class="fas fa-user-times text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">비활성 회원</p>
                  <p class="text-2xl font-bold text-gray-900">{inactiveUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
                  <i class="fas fa-user-clock text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">승인 대기</p>
                  <p class="text-2xl font-bold text-gray-900">{pendingUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-red-100 text-red-600">
                  <i class="fas fa-user-slash text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">가입 거부</p>
                  <p class="text-2xl font-bold text-gray-900">{rejectedUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-user-plus text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 신규</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyNewUsers.count}</p>
                </div>
              </div>
            </div>
          </div>

          {/* 콘텐츠 활동 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-file-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 게시글</p>
                  <p class="text-2xl font-bold text-gray-900">{totalPosts.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-indigo-100 text-indigo-600">
                  <i class="fas fa-plus-circle text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 게시글</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyPosts.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-teal-100 text-teal-600">
                  <i class="fas fa-comments text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 댓글</p>
                  <p class="text-2xl font-bold text-gray-900">{totalComments.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-cyan-100 text-cyan-600">
                  <i class="fas fa-comment-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 댓글</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyComments.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-orange-100 text-orange-600">
                  <i class="fas fa-calendar-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 이벤트</p>
                  <p class="text-2xl font-bold text-gray-900">{totalEvents.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {/* 게시판별 활동 현황 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-clipboard-list text-primary-600 mr-2"></i>
                  게시판별 활동 현황
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-4">
                  {boardStats.results.length > 0 ? (
                    boardStats.results.map((board: any) => (
                      <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900">{board.board_name}</h4>
                          <p class="text-sm text-gray-600">이번 주: {board.weekly_posts}개 게시글</p>
                        </div>
                        <div class="text-right">
                          <span class="text-lg font-bold text-primary-600">{board.post_count}</span>
                          <p class="text-xs text-gray-500">총 게시글</p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-inbox text-4xl mb-4"></i>
                      <p>게시판 데이터가 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 최근 활동 회원 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-users text-primary-600 mr-2"></i>
                  최근 활동 회원 (최근 30일)
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-3">
                  {activeUsers.results.length > 0 ? (
                    activeUsers.results.map((activeUser: any) => (
                      <div class="flex justify-between items-center p-3 border border-gray-200 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900">
                            {activeUser.full_name} 
                            <span class="text-sm text-gray-500">(@{activeUser.username})</span>
                          </h4>
                          <div class="flex space-x-4 text-sm text-gray-600">
                            <span>게시글: {activeUser.post_count}</span>
                            <span>댓글: {activeUser.comment_count}</span>
                          </div>
                        </div>
                        <div class="text-right">
                          <span class={`px-2 py-1 text-xs rounded-full ${
                            activeUser.role === 'admin' ? 'bg-red-100 text-red-600' :
                            activeUser.role === 'moderator' ? 'bg-yellow-100 text-yellow-600' :
                            'bg-gray-100 text-gray-600'
                          }`}>
                            {activeUser.role === 'admin' ? '관리자' : 
                             activeUser.role === 'moderator' ? '모더레이터' : '회원'}
                          </span>
                          <p class="text-xs text-gray-500 mt-1">
                            {activeUser.last_activity ? 
                              new Date(activeUser.last_activity).toLocaleDateString('ko-KR') :
                              '-'
                            }
                          </p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-user-friends text-4xl mb-4"></i>
                      <p>최근 활동 회원이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* 인기 게시글 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-fire text-primary-600 mr-2"></i>
                  인기 게시글 (최근 30일)
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-3">
                  {popularPosts.results.length > 0 ? (
                    popularPosts.results.map((post: any, index: number) => (
                      <div class="flex justify-between items-center p-3 border border-gray-200 rounded-lg">
                        <div class="flex items-center space-x-3">
                          <span class={`flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${
                            index < 3 ? 'bg-yellow-100 text-yellow-600' : 'bg-gray-100 text-gray-600'
                          }`}>
                            {index + 1}
                          </span>
                          <div>
                            <h4 class="font-medium text-gray-900">{post.title}</h4>
                            <div class="flex space-x-4 text-sm text-gray-600">
                              <span>작성자: {post.author}</span>
                              <span>게시판: {post.board_name}</span>
                              <span>{new Date(post.created_at).toLocaleDateString('ko-KR')}</span>
                            </div>
                          </div>
                        </div>
                        <div class="flex space-x-4 text-sm">
                          <div class="text-center">
                            <i class="fas fa-heart text-red-500"></i>
                            <span class="ml-1 font-medium">{post.like_count}</span>
                          </div>
                          <div class="text-center">
                            <i class="fas fa-eye text-blue-500"></i>
                            <span class="ml-1 font-medium">{post.view_count}</span>
                          </div>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-chart-line text-4xl mb-4"></i>
                      <p>인기 게시글이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </Layout>,
      { title: '활동 보고서' }
    );

  } catch (error) {
    console.error('Admin reports error:', error);
    console.error('Error details:', error.message, error.stack);
    return c.redirect('/admin');
  }
});

// Admin Backup Management Page (백업 관리)
app.get('/admin/backup', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 주요 테이블들의 통계 (고정 목록으로 처리)
    const mainTables = [
      'users', 'posts', 'comments', 'categories', 'sessions', 
      'notifications', 'messages', 'events', 'meeting_minutes',
      'page_contents', 'page_sections', 'site_settings'
    ];

    const tableStats = [];
    for (const tableName of mainTables) {
      try {
        const count = await env.DB.prepare(`SELECT COUNT(*) as count FROM ${tableName}`).first();
        tableStats.push({
          name: tableName,
          count: count ? count.count : 0
        });
      } catch (error) {
        // 테이블이 존재하지 않으면 0으로 처리
        tableStats.push({
          name: tableName,
          count: 0
        });
      }
    }

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-database text-primary-600 mr-3"></i>
                백업 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">데이터베이스 백업 및 내보내기 관리</p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {/* 데이터베이스 현황 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-table text-primary-600 mr-2"></i>
                  데이터베이스 현황
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-4">
                  {tableStats.length > 0 ? (
                    tableStats.map((table) => (
                      <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900 capitalize">{table.name}</h4>
                          <p class="text-sm text-gray-600">
                            {table.name === 'users' ? '회원 데이터' :
                             table.name === 'posts' ? '게시글 데이터' :
                             table.name === 'comments' ? '댓글 데이터' :
                             table.name === 'boards' ? '게시판 데이터' :
                             table.name === 'events' ? '이벤트 데이터' :
                             table.name === 'sessions' ? '세션 데이터' :
                             table.name === 'board_permissions' ? '권한 데이터' :
                             table.name === 'page_contents' ? '페이지 데이터' :
                             '기타 데이터'
                            }
                          </p>
                        </div>
                        <div class="text-right">
                          <span class="text-lg font-bold text-primary-600">{table.count.toLocaleString()}</span>
                          <p class="text-xs text-gray-500">레코드</p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-database text-4xl mb-4"></i>
                      <p>테이블을 찾을 수 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 백업 작업 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-download text-primary-600 mr-2"></i>
                  데이터 내보내기
                </h3>
              </div>
              <div class="p-6 space-y-4">
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                  <div class="flex items-start">
                    <i class="fas fa-info-circle text-blue-500 mt-1 mr-3"></i>
                    <div>
                      <h4 class="font-medium text-blue-900 mb-2">백업 정보</h4>
                      <p class="text-sm text-blue-700 leading-relaxed">
                        Cloudflare D1 데이터베이스는 자동으로 백업이 관리됩니다. 
                        여기서는 데이터를 SQL 덤프 또는 CSV 형태로 내보낼 수 있습니다.
                      </p>
                    </div>
                  </div>
                </div>

                <div class="space-y-3">
                  <button 
                    onclick="exportFullBackup()" 
                    class="w-full bg-primary-600 text-white py-3 px-4 rounded-lg hover:bg-primary-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-file-export mr-2"></i>
                    전체 데이터 SQL 덤프 생성
                  </button>
                  
                  <button 
                    onclick="exportUsers()" 
                    class="w-full bg-green-600 text-white py-3 px-4 rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-users mr-2"></i>
                    회원 데이터 CSV 내보내기
                  </button>
                  
                  <button 
                    onclick="exportPosts()" 
                    class="w-full bg-purple-600 text-white py-3 px-4 rounded-lg hover:bg-purple-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-file-alt mr-2"></i>
                    게시글 데이터 CSV 내보내기
                  </button>
                  
                  <button 
                    onclick="exportEvents()" 
                    class="w-full bg-orange-600 text-white py-3 px-4 rounded-lg hover:bg-orange-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-calendar-alt mr-2"></i>
                    이벤트 데이터 CSV 내보내기
                  </button>
                </div>

                <div id="backup-status" class="mt-4 p-3 bg-gray-50 rounded-lg text-sm text-gray-600 hidden">
                  <div class="flex items-center">
                    <i class="fas fa-spinner fa-spin mr-2"></i>
                    백업을 생성 중입니다...
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* 백업 기록 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-history text-primary-600 mr-2"></i>
                  백업 작업 가이드
                </h3>
              </div>
              <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="space-y-4">
                    <h4 class="font-medium text-gray-900">자동 백업 (Cloudflare D1)</h4>
                    <ul class="space-y-2 text-sm text-gray-600">
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        데이터베이스는 자동으로 백업됩니다
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        Point-in-time 복구 지원
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        지역별 복제를 통한 안정성
                      </li>
                    </ul>
                  </div>
                  
                  <div class="space-y-4">
                    <h4 class="font-medium text-gray-900">수동 내보내기</h4>
                    <ul class="space-y-2 text-sm text-gray-600">
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        SQL 덤프: 전체 데이터베이스 구조 + 데이터
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        CSV 내보내기: 개별 테이블 데이터
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        분석이나 마이그레이션 용도
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <script dangerouslySetInnerHTML={{__html: `
          async function exportFullBackup() {
            showBackupStatus('전체 데이터 SQL 덤프를 생성하고 있습니다...');
            try {
              const response = await fetch('/api/admin/backup/sql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'chemissue_backup_' + new Date().toISOString().split('T')[0] + '.sql';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
                hideBackupStatus();
              } else {
                throw new Error('백업 생성 실패');
              }
            } catch (error) {
              console.error('Export error:', error);
              alert('백업 생성 중 오류가 발생했습니다.');
              hideBackupStatus();
            }
          }

          async function exportUsers() {
            await exportCSV('users', '회원');
          }

          async function exportPosts() {
            await exportCSV('posts', '게시글');
          }

          async function exportEvents() {
            await exportCSV('events', '이벤트');
          }

          async function exportCSV(table, name) {
            showBackupStatus(name + ' 데이터를 CSV로 내보내고 있습니다...');
            try {
              const response = await fetch('/api/admin/backup/csv/' + table, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'chemissue_' + table + '_' + new Date().toISOString().split('T')[0] + '.csv';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
                hideBackupStatus();
              } else {
                throw new Error(name + ' 데이터 내보내기 실패');
              }
            } catch (error) {
              console.error('Export error:', error);
              alert(name + ' 데이터 내보내기 중 오류가 발생했습니다.');
              hideBackupStatus();
            }
          }

          function showBackupStatus(message) {
            const status = document.getElementById('backup-status');
            status.querySelector('div').innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>' + message;
            status.classList.remove('hidden');
          }

          function hideBackupStatus() {
            const status = document.getElementById('backup-status');
            status.classList.add('hidden');
          }
        `}} />
      </Layout>,
      { title: '백업 관리' }
    );

  } catch (error) {
    console.error('Admin backup page error:', error);
    console.error('Error details:', error.message, error.stack);
    return c.redirect('/admin');
  }
});

// API: SQL 덤프 생성
app.post('/api/admin/backup/sql', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    
    // 테이블 목록 가져오기
    const tables = await env.DB.prepare(`
      SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%'
    `).all();

    let sqlDump = `-- ChemiSSUe Database Backup\n-- Generated on ${new Date().toISOString()}\n\n`;

    for (const table of tables.results) {
      // 테이블 스키마 가져오기
      const schema = await env.DB.prepare(`
        SELECT sql FROM sqlite_master WHERE type='table' AND name = ?
      `).bind(table.name).first();

      if (schema) {
        sqlDump += `-- Table: ${table.name}\n`;
        sqlDump += `${schema.sql};\n\n`;

        // 데이터 가져오기
        const data = await env.DB.prepare(`SELECT * FROM ${table.name}`).all();
        
        if (data.results.length > 0) {
          const columns = Object.keys(data.results[0]);
          
          for (const row of data.results) {
            const values = columns.map(col => {
              const val = row[col];
              if (val === null) return 'NULL';
              if (typeof val === 'string') return `'${val.replace(/'/g, "''")}'`;
              return val;
            }).join(', ');
            
            sqlDump += `INSERT INTO ${table.name} (${columns.join(', ')}) VALUES (${values});\n`;
          }
          sqlDump += '\n';
        }
      }
    }

    return new Response(sqlDump, {
      headers: {
        'Content-Type': 'text/plain',
        'Content-Disposition': `attachment; filename="chemissue_backup_${new Date().toISOString().split('T')[0]}.sql"`
      }
    });

  } catch (error) {
    console.error('SQL backup error:', error);
    return c.json({ error: '백업 생성 중 오류가 발생했습니다.' }, 500);
  }
});

// API: CSV 내보내기
app.post('/api/admin/backup/csv/:table', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const tableName = c.req.param('table');
    
    // 허용된 테이블만 내보내기
    const allowedTables = ['users', 'posts', 'comments', 'events', 'boards'];
    if (!allowedTables.includes(tableName)) {
      return c.json({ error: '허용되지 않은 테이블입니다.' }, 400);
    }

    const data = await env.DB.prepare(`SELECT * FROM ${tableName}`).all();
    
    if (data.results.length === 0) {
      return c.json({ error: '데이터가 없습니다.' }, 404);
    }

    // CSV 헤더
    const columns = Object.keys(data.results[0]);
    let csv = columns.join(',') + '\n';

    // CSV 데이터
    for (const row of data.results) {
      const values = columns.map(col => {
        const val = row[col];
        if (val === null) return '';
        if (typeof val === 'string' && (val.includes(',') || val.includes('"') || val.includes('\n'))) {
          return `"${val.replace(/"/g, '""')}"`;
        }
        return val;
      }).join(',');
      csv += values + '\n';
    }

    return new Response(csv, {
      headers: {
        'Content-Type': 'text/csv',
        'Content-Disposition': `attachment; filename="chemissue_${tableName}_${new Date().toISOString().split('T')[0]}.csv"`
      }
    });

  } catch (error) {
    console.error('CSV export error:', error);
    return c.json({ error: 'CSV 내보내기 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Messages Management Page (메시지 관리)
app.get('/admin/messages', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 메시지 통계
    const messageStats = await Promise.all([
      // 총 메시지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM messages').first(),
      // 읽지 않은 메시지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM messages WHERE is_read = 0').first(),
      // 오늘 보낸 메시지 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM messages WHERE date(created_at) = date('now')`).first(),
      // 이번 주 메시지 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM messages WHERE created_at >= datetime('now', '-7 days')`).first(),
    ]);

    // 최근 메시지 목록
    const recentMessages = await env.DB.prepare(`
      SELECT 
        m.id,
        m.subject,
        m.content,
        m.is_read,
        m.created_at,
        s.username as sender_username,
        s.full_name as sender_name,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      ORDER BY m.created_at DESC
      LIMIT 50
    `).all();

    // 활발한 메시지 사용자
    const activeMessagers = await env.DB.prepare(`
      SELECT 
        u.username,
        u.full_name,
        u.role,
        COUNT(DISTINCT m1.id) as sent_count,
        COUNT(DISTINCT m2.id) as received_count,
        COUNT(DISTINCT m1.id) + COUNT(DISTINCT m2.id) as total_count
      FROM users u
      LEFT JOIN messages m1 ON u.id = m1.sender_id AND m1.created_at >= datetime('now', '-30 days')
      LEFT JOIN messages m2 ON u.id = m2.recipient_id AND m2.created_at >= datetime('now', '-30 days')
      WHERE u.is_active = 1
      GROUP BY u.id, u.username, u.full_name, u.role
      HAVING total_count > 0
      ORDER BY total_count DESC
      LIMIT 15
    `).all();

    const [totalMessages, unreadMessages, todayMessages, weeklyMessages] = messageStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-envelope text-primary-600 mr-3"></i>
                메시지 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">회원 간 메시지 관리 및 통계</p>
          </div>

          {/* 메시지 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-envelope text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 메시지</p>
                  <p class="text-2xl font-bold text-gray-900">{totalMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-red-100 text-red-600">
                  <i class="fas fa-envelope-open text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">읽지 않음</p>
                  <p class="text-2xl font-bold text-gray-900">{unreadMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-calendar-day text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">오늘 메시지</p>
                  <p class="text-2xl font-bold text-gray-900">{todayMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-calendar-week text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">이번 주</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyMessages.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {/* 최근 메시지 목록 */}
            <div class="lg:col-span-2">
              <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                  <h3 class="text-lg font-semibold text-gray-900">
                    <i class="fas fa-list text-primary-600 mr-2"></i>
                    최근 메시지
                  </h3>
                  <div class="flex space-x-2">
                    <button 
                      onclick="window.location.reload()" 
                      class="px-3 py-1 text-sm bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      <i class="fas fa-refresh mr-1"></i>새로고침
                    </button>
                  </div>
                </div>
                <div class="max-h-96 overflow-y-auto">
                  {recentMessages.results.length > 0 ? (
                    <div class="divide-y divide-gray-200">
                      {recentMessages.results.map((message: any) => (
                        <div class="p-4 hover:bg-gray-50">
                          <div class="flex justify-between items-start">
                            <div class="flex-1">
                              <div class="flex items-center space-x-2 mb-2">
                                <span class={`px-2 py-1 text-xs rounded-full ${
                                  message.is_read ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600'
                                }`}>
                                  {message.is_read ? '읽음' : '미읽음'}
                                </span>
                                <span class="text-sm font-medium text-gray-900">{message.subject}</span>
                              </div>
                              <div class="text-sm text-gray-600 mb-2">
                                <span class="font-medium">{message.sender_name}</span> 
                                <span class="text-gray-400 mx-1">→</span>
                                <span class="font-medium">{message.recipient_name}</span>
                              </div>
                              <p class="text-sm text-gray-500 line-clamp-2">
                                {message.content.substring(0, 100)}...
                              </p>
                            </div>
                            <div class="text-right text-xs text-gray-400">
                              {new Date(message.created_at).toLocaleString('ko-KR')}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-12 text-gray-500">
                      <i class="fas fa-inbox text-4xl mb-4"></i>
                      <p>메시지가 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 활발한 메시지 사용자 */}
            <div class="lg:col-span-1">
              <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                  <h3 class="text-lg font-semibold text-gray-900">
                    <i class="fas fa-users text-primary-600 mr-2"></i>
                    활발한 사용자 (30일)
                  </h3>
                </div>
                <div class="max-h-96 overflow-y-auto">
                  {activeMessagers.results.length > 0 ? (
                    <div class="p-4 space-y-3">
                      {activeMessagers.results.map((user: any, index: number) => (
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                          <div class="flex items-center space-x-3">
                            <span class={`flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${
                              index < 3 ? 'bg-yellow-100 text-yellow-600' : 'bg-gray-100 text-gray-600'
                            }`}>
                              {index + 1}
                            </span>
                            <div>
                              <h4 class="text-sm font-medium text-gray-900">{user.full_name}</h4>
                              <p class="text-xs text-gray-500">@{user.username}</p>
                            </div>
                          </div>
                          <div class="text-right">
                            <div class="text-sm font-bold text-primary-600">{user.total_count}</div>
                            <div class="text-xs text-gray-500">
                              보냄 {user.sent_count} | 받음 {user.received_count}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-user-friends text-4xl mb-4"></i>
                      <p>활동이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* 관리 작업 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-cogs text-primary-600 mr-2"></i>
                  관리 작업
                </h3>
              </div>
              <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <button class="bg-blue-600 text-white py-3 px-4 rounded-lg hover:bg-blue-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-check-double mr-2"></i>
                    모든 메시지 읽음 처리
                  </button>
                  
                  <button class="bg-red-600 text-white py-3 px-4 rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-trash-alt mr-2"></i>
                    오래된 메시지 삭제 (30일 이상)
                  </button>
                  
                  <button class="bg-green-600 text-white py-3 px-4 rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-download mr-2"></i>
                    메시지 내역 내보내기
                  </button>
                </div>

                <div id="admin-action-status" class="mt-4 p-3 bg-gray-50 rounded-lg text-sm text-gray-600 hidden">
                  <div class="flex items-center">
                    <i class="fas fa-spinner fa-spin mr-2"></i>
                    작업을 처리하고 있습니다...
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

{/* 메시지 상세 보기 기능은 추후 구현 */}

      </Layout>,
      { title: '메시지 관리' }
    );

  } catch (error) {
    console.error('Admin messages page error:', error);
    console.error('Error details:', error.message, error.stack);
    return c.redirect('/admin');
  }
});

// API: 개별 메시지 조회
app.get('/api/admin/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    const message = await env.DB.prepare(`
      SELECT 
        m.*,
        s.username as sender_username,
        s.full_name as sender_name,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      WHERE m.id = ?
    `).bind(messageId).first();

    if (!message) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    return c.json({ success: true, message });

  } catch (error) {
    console.error('Get message error:', error);
    return c.json({ error: '메시지를 불러올 수 없습니다.' }, 500);
  }
});

// API: 메시지 삭제
app.delete('/api/admin/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    const result = await env.DB.prepare('DELETE FROM messages WHERE id = ?').bind(messageId).run();
    
    if (result.changes === 0) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    return c.json({ success: true });

  } catch (error) {
    console.error('Delete message error:', error);
    return c.json({ error: '메시지 삭제에 실패했습니다.' }, 500);
  }
});

// API: 모든 메시지 읽음 처리
app.post('/api/admin/messages/mark-all-read', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const result = await env.DB.prepare(`
      UPDATE messages 
      SET is_read = 1, read_at = datetime('now') 
      WHERE is_read = 0
    `).run();

    return c.json({ success: true, count: result.changes });

  } catch (error) {
    console.error('Mark all as read error:', error);
    return c.json({ error: '읽음 처리에 실패했습니다.' }, 500);
  }
});

// API: 오래된 메시지 삭제
app.delete('/api/admin/messages/delete-old', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const result = await env.DB.prepare(`
      DELETE FROM messages 
      WHERE created_at < datetime('now', '-30 days')
    `).run();

    return c.json({ success: true, count: result.changes });

  } catch (error) {
    console.error('Delete old messages error:', error);
    return c.json({ error: '오래된 메시지 삭제에 실패했습니다.' }, 500);
  }
});

// API: 메시지 내역 내보내기
app.post('/api/admin/messages/export', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const messages = await env.DB.prepare(`
      SELECT 
        m.id,
        s.username as sender,
        r.username as recipient,
        m.subject,
        m.content,
        m.is_read,
        m.created_at,
        m.read_at
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      ORDER BY m.created_at DESC
    `).all();

    if (messages.results.length === 0) {
      return c.json({ error: '내보낼 메시지가 없습니다.' }, 404);
    }

    // CSV 헤더
    let csv = 'ID,보낸사람,받는사람,제목,내용,읽음여부,보낸시간,읽은시간\n';

    // CSV 데이터
    for (const message of messages.results) {
      const csvRow = [
        message.id,
        message.sender,
        message.recipient,
        `"${message.subject.replace(/"/g, '""')}"`,
        `"${message.content.replace(/"/g, '""').substring(0, 200)}"`,
        message.is_read ? '읽음' : '미읽음',
        message.created_at,
        message.read_at || ''
      ].join(',');
      csv += csvRow + '\n';
    }

    return new Response(csv, {
      headers: {
        'Content-Type': 'text/csv; charset=utf-8',
        'Content-Disposition': `attachment; filename="messages_export_${new Date().toISOString().split('T')[0]}.csv"`
      }
    });

  } catch (error) {
    console.error('Export messages error:', error);
    return c.json({ error: '내보내기에 실패했습니다.' }, 500);
  }
});

// Admin Broadcast/Notification Management Page (공지 발송)
app.get('/admin/broadcast', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 공지 통계
    const broadcastStats = await Promise.all([
      // 총 공지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications').first(),
      // 읽지 않은 공지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications WHERE is_read = FALSE').first(),
      // 총 회원 수 (공지 대상)
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = TRUE').first(),
      // 관리자/모더레이터 수
      env.DB.prepare("SELECT COUNT(*) as count FROM users WHERE role IN ('admin', 'moderator') AND is_active = TRUE").first(),
    ]);

    // 최근 발송 알림 (동일 제목/내용으로 그룹화)
    const recentNotifications = await env.DB.prepare(`
      SELECT 
        title,
        message,
        type,
        notification_type,
        target_type,
        target_value,
        created_at,
        COUNT(*) as recipient_count,
        SUM(CASE WHEN is_read = 1 THEN 1 ELSE 0 END) as read_count
      FROM notifications
      GROUP BY title, message, DATE(created_at)
      ORDER BY created_at DESC
      LIMIT 20
    `).all();

    // 최근 중요 게시글 (공지성 게시글)
    const recentAnnouncements = await env.DB.prepare(`
      SELECT 
        p.*,
        u.username as author_username,
        u.full_name as author_name,
        c.name as category_name
      FROM posts p
      JOIN users u ON p.user_id = u.id
      JOIN categories c ON p.category_id = c.id
      WHERE p.is_featured = TRUE
      ORDER BY p.created_at DESC
      LIMIT 10
    `).all();

    // 게시판 목록 (공고 대상 선택용)
    const boards = await env.DB.prepare('SELECT id, name FROM categories ORDER BY name').all();

    // 역할별 회원 수
    const roleStats = await env.DB.prepare(`
      SELECT 
        role,
        COUNT(*) as count
      FROM users
      WHERE is_active = TRUE
      GROUP BY role
    `).all();

    const [totalNotifications, activeNotifications, totalAnnouncements, activeAnnouncements] = broadcastStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-bullhorn text-primary-600 mr-3"></i>
                공지 발송 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">전체/개별 공지사항 및 알림 발송 관리</p>
          </div>

          {/* 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-bell text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 알림</p>
                  <p class="text-2xl font-bold text-gray-900">{totalNotifications.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-bell-slash text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 알림</p>
                  <p class="text-2xl font-bold text-gray-900">{activeNotifications.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-megaphone text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 공고</p>
                  <p class="text-2xl font-bold text-gray-900">{totalAnnouncements.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-orange-100 text-orange-600">
                  <i class="fas fa-thumbtack text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 공고</p>
                  <p class="text-2xl font-bold text-gray-900">{activeAnnouncements.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            {/* 새 알림 발송 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-paper-plane text-primary-600 mr-2"></i>
                  새 알림 발송
                </h3>
              </div>
              <div class="p-6">
                <form id="notification-form" class="space-y-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">알림 제목</label>
                    <input type="text" id="notification-title" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="알림 제목을 입력하세요" required />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">알림 내용</label>
                    <textarea id="notification-content" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="알림 내용을 입력하세요" required></textarea>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">알림 유형</label>
                      <select id="notification-type" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                        <option value="general">일반</option>
                        <option value="important">중요</option>
                        <option value="system">시스템</option>
                        <option value="event">이벤트</option>
                      </select>
                    </div>
                    
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">발송 대상</label>
                      <select id="target-type" class="w-full border border-gray-300 rounded-lg px-3 py-2" onchange="toggleTargetOptions()">
                        <option value="all">전체 회원</option>
                        <option value="role">역할별</option>
                        <option value="specific">특정 회원</option>
                      </select>
                    </div>
                  </div>
                  
                  <div id="target-options" class="hidden">
                    <label class="block text-sm font-medium text-gray-700 mb-2">대상 선택</label>
                    <div id="role-options" class="space-y-2 hidden">
                      <label class="flex items-center">
                        <input type="checkbox" value="admin" class="mr-2" /> 관리자 ({roleStats.results.find(r => r.role === 'admin')?.count || 0}명)
                      </label>
                      <label class="flex items-center">
                        <input type="checkbox" value="moderator" class="mr-2" /> 모더레이터 ({roleStats.results.find(r => r.role === 'moderator')?.count || 0}명)
                      </label>
                      <label class="flex items-center">
                        <input type="checkbox" value="member" class="mr-2" /> 일반 회원 ({roleStats.results.find(r => r.role === 'member')?.count || 0}명)
                      </label>
                    </div>
                    <input type="text" id="specific-users" placeholder="회원명 또는 이메일 (쉼표로 구분)" class="w-full border border-gray-300 rounded-lg px-3 py-2 hidden" />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">만료일 (선택사항)</label>
                    <input type="datetime-local" id="expires-at" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                  </div>
                  
                  <button type="submit" class="w-full bg-primary-600 text-white py-3 rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="fas fa-paper-plane mr-2"></i>알림 발송
                  </button>
                </form>
              </div>
            </div>

            {/* 새 공고 작성 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-plus-circle text-primary-600 mr-2"></i>
                  새 공고 작성
                </h3>
              </div>
              <div class="p-6">
                <form id="announcement-form" class="space-y-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">공고 제목</label>
                    <input type="text" id="announcement-title" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="공고 제목을 입력하세요" required />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">공고 내용</label>
                    <textarea id="announcement-content" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="공고 내용을 입력하세요" required></textarea>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">공고 유형</label>
                      <select id="announcement-type" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                        <option value="general">일반 공고</option>
                        <option value="urgent">긴급 공고</option>
                        <option value="event">이벤트 공고</option>
                        <option value="notice">공지사항</option>
                      </select>
                    </div>
                    
                    <div>
                      <label class="flex items-center space-x-2">
                        <input type="checkbox" id="is-pinned" checked />
                        <span class="text-sm font-medium text-gray-700">상단 고정</span>
                      </label>
                    </div>
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">대상 게시판 (선택사항)</label>
                    <select id="target-boards" multiple class="w-full border border-gray-300 rounded-lg px-3 py-2 h-24">
                      <option value="">전체 게시판</option>
                      {boards.results.map((board: any) => (
                        <option value={board.id}>{board.name}</option>
                      ))}
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Ctrl+클릭으로 여러 게시판 선택 (미선택시 전체)</p>
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">만료일 (선택사항)</label>
                    <input type="datetime-local" id="announcement-expires-at" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                  </div>
                  
                  <button type="submit" class="w-full bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 transition-colors">
                    <i class="fas fa-plus-circle mr-2"></i>공고 작성
                  </button>
                </form>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {/* 최근 발송 알림 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-history text-primary-600 mr-2"></i>
                  최근 발송 알림
                </h3>
              </div>
              <div class="max-h-96 overflow-y-auto">
                {recentNotifications.results.length > 0 ? (
                  <div class="divide-y divide-gray-200">
                    {recentNotifications.results.map((notification: any) => (
                      <div class="p-4">
                        <div class="flex justify-between items-start mb-2">
                          <h4 class="font-medium text-gray-900">{notification.title}</h4>
                          <div class="flex space-x-2">
                            <span class={`px-2 py-1 text-xs rounded-full ${
                              notification.notification_type === 'important' ? 'bg-red-100 text-red-600' :
                              notification.notification_type === 'system' ? 'bg-blue-100 text-blue-600' :
                              notification.notification_type === 'event' ? 'bg-purple-100 text-purple-600' :
                              'bg-gray-100 text-gray-600'
                            }`}>
                              {notification.notification_type === 'important' ? '중요' :
                               notification.notification_type === 'system' ? '시스템' :
                               notification.notification_type === 'event' ? '이벤트' : '일반'}
                            </span>
                            <span class={`px-2 py-1 text-xs rounded-full ${
                              notification.is_active ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-600'
                            }`}>
                              {notification.is_active ? '활성' : '비활성'}
                            </span>
                          </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-2 line-clamp-2">{notification.message}</p>
                        <div class="flex justify-between items-center text-xs text-gray-500">
                          <span>발송자: 관리자</span>
                          <span>읽음: {notification.read_count}/{notification.recipient_count}</span>
                        </div>
                        <div class="flex justify-between items-center text-xs text-gray-500">
                          <span>대상: {notification.target_type === 'all' ? '전체' : notification.target_type === 'role' ? '역할별' : '특정 사용자'}</span>
                          <span>유형: {notification.notification_type === 'important' ? '중요' : '일반'}</span>
                        </div>
                        <div class="text-xs text-gray-400 mt-1">
                          <span>{new Date(notification.created_at).toLocaleString('ko-KR')}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="text-center py-8 text-gray-500">
                    <i class="fas fa-bell-slash text-4xl mb-4"></i>
                    <p>발송된 알림이 없습니다.</p>
                  </div>
                )}
              </div>
            </div>

            {/* 최근 공고 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-list text-primary-600 mr-2"></i>
                  최근 공고
                </h3>
              </div>
              <div class="max-h-96 overflow-y-auto">
                {recentAnnouncements.results.length > 0 ? (
                  <div class="divide-y divide-gray-200">
                    {recentAnnouncements.results.map((announcement: any) => (
                      <div class="p-4">
                        <div class="flex justify-between items-start mb-2">
                          <h4 class="font-medium text-gray-900">{announcement.title}</h4>
                          <div class="flex space-x-2">
                            {announcement.is_pinned && (
                              <span class="px-2 py-1 text-xs rounded-full bg-yellow-100 text-yellow-600">
                                <i class="fas fa-thumbtack mr-1"></i>고정
                              </span>
                            )}
                            <span class={`px-2 py-1 text-xs rounded-full ${
                              announcement.announcement_type === 'urgent' ? 'bg-red-100 text-red-600' :
                              announcement.announcement_type === 'event' ? 'bg-purple-100 text-purple-600' :
                              announcement.announcement_type === 'notice' ? 'bg-blue-100 text-blue-600' :
                              'bg-gray-100 text-gray-600'
                            }`}>
                              {announcement.announcement_type === 'urgent' ? '긴급' :
                               announcement.announcement_type === 'event' ? '이벤트' :
                               announcement.announcement_type === 'notice' ? '공지' : '일반'}
                            </span>
                          </div>
                        </div>
                        <p class="text-sm text-gray-600 mb-2 line-clamp-2">{announcement.content}</p>
                        <div class="flex justify-between items-center text-xs text-gray-500">
                          <span>작성자: {announcement.author_name}</span>
                          <span>조회: {announcement.view_count}</span>
                        </div>
                        <div class="flex justify-between items-center text-xs text-gray-400 mt-1">
                          <span>{new Date(announcement.created_at).toLocaleString('ko-KR')}</span>
                          <div class="space-x-2">
                            <button onclick={`toggleAnnouncement(${announcement.id}, ${!announcement.is_active})`} class="text-primary-600 hover:text-primary-700">
                              {announcement.is_active ? '비활성화' : '활성화'}
                            </button>
                            <button onclick={`deleteAnnouncement(${announcement.id})`} class="text-red-600 hover:text-red-700">
                              삭제
                            </button>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="text-center py-8 text-gray-500">
                    <i class="fas fa-megaphone text-4xl mb-4"></i>
                    <p>작성된 공고가 없습니다.</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        <script dangerouslySetInnerHTML={{__html: `
          function toggleTargetOptions() {
            const targetType = document.getElementById('target-type').value;
            const targetOptions = document.getElementById('target-options');
            const roleOptions = document.getElementById('role-options');
            const specificUsers = document.getElementById('specific-users');
            
            if (targetType === 'all') {
              targetOptions.classList.add('hidden');
            } else {
              targetOptions.classList.remove('hidden');
              if (targetType === 'role') {
                roleOptions.classList.remove('hidden');
                specificUsers.classList.add('hidden');
              } else {
                roleOptions.classList.add('hidden');
                specificUsers.classList.remove('hidden');
              }
            }
          }

          document.getElementById('notification-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const title = document.getElementById('notification-title').value;
            const content = document.getElementById('notification-content').value;
            const notificationType = document.getElementById('notification-type').value;
            const targetType = document.getElementById('target-type').value;
            const expiresAt = document.getElementById('expires-at').value;
            
            let targetValue = '';
            if (targetType === 'role') {
              const checkedRoles = Array.from(document.querySelectorAll('#role-options input:checked')).map(input => input.value);
              targetValue = checkedRoles.join(',');
            } else if (targetType === 'specific') {
              targetValue = document.getElementById('specific-users').value;
            }
            
            try {
              const response = await fetch('/api/admin/broadcast/notification', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title, content, notification_type: notificationType,
                  target_type: targetType, target_value: targetValue,
                  expires_at: expiresAt || null
                })
              });
              
              const data = await response.json();
              if (data.success) {
                alert('알림이 ' + data.recipient_count + '명에게 발송되었습니다.');
                document.getElementById('notification-form').reset();
                window.location.reload();
              } else {
                alert('발송 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Send notification error:', error);
              alert('알림 발송 중 오류가 발생했습니다.');
            }
          });

          document.getElementById('announcement-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const title = document.getElementById('announcement-title').value;
            const content = document.getElementById('announcement-content').value;
            const announcementType = document.getElementById('announcement-type').value;
            const isPinned = document.getElementById('is-pinned').checked;
            const expiresAt = document.getElementById('announcement-expires-at').value;
            
            const targetBoards = Array.from(document.getElementById('target-boards').selectedOptions).map(option => option.value).filter(v => v);
            
            try {
              const response = await fetch('/api/admin/broadcast/announcement', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title, content, announcement_type: announcementType,
                  is_pinned: isPinned, target_boards: targetBoards,
                  expires_at: expiresAt || null
                })
              });
              
              const data = await response.json();
              if (data.success) {
                alert('공고가 작성되었습니다.');
                document.getElementById('announcement-form').reset();
                window.location.reload();
              } else {
                alert('작성 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Create announcement error:', error);
              alert('공고 작성 중 오류가 발생했습니다.');
            }
          });

          async function toggleNotification(id, active) {
            try {
              const response = await fetch('/api/admin/broadcast/notification/' + id + '/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ is_active: active })
              });
              
              const data = await response.json();
              if (data.success) {
                window.location.reload();
              } else {
                alert('변경 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Toggle notification error:', error);
              alert('상태 변경 중 오류가 발생했습니다.');
            }
          }

          async function deleteNotification(id) {
            if (!confirm('정말 이 알림을 삭제하시겠습니까?')) return;
            
            try {
              const response = await fetch('/api/admin/broadcast/notification/' + id, { method: 'DELETE' });
              const data = await response.json();
              
              if (data.success) {
                window.location.reload();
              } else {
                alert('삭제 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Delete notification error:', error);
              alert('삭제 중 오류가 발생했습니다.');
            }
          }

          async function toggleAnnouncement(id, active) {
            try {
              const response = await fetch('/api/admin/broadcast/announcement/' + id + '/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ is_active: active })
              });
              
              const data = await response.json();
              if (data.success) {
                window.location.reload();
              } else {
                alert('변경 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Toggle announcement error:', error);
              alert('상태 변경 중 오류가 발생했습니다.');
            }
          }

          async function deleteAnnouncement(id) {
            if (!confirm('정말 이 공고를 삭제하시겠습니까?')) return;
            
            try {
              const response = await fetch('/api/admin/broadcast/announcement/' + id, { method: 'DELETE' });
              const data = await response.json();
              
              if (data.success) {
                window.location.reload();
              } else {
                alert('삭제 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Delete announcement error:', error);
              alert('삭제 중 오류가 발생했습니다.');
            }
          }
        `}} />
      </Layout>,
      { title: '공지 발송 관리' }
    );

  } catch (error) {
    console.error('Admin broadcast page error:', error);
    console.error('Error details:', error.message, error.stack);
    return c.redirect('/admin');
  }
});

// API: 알림 발송
app.post('/api/admin/broadcast/notification', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const { title, content, notification_type, target_type, target_value, expires_at } = await c.req.json();

    // undefined 값 처리
    const safeTargetValue = target_value || null;
    const safeExpiresAt = expires_at || null;
    const safeNotificationType = notification_type || 'general';
    const safeTargetType = target_type || 'all';

    // 알림 생성 - 각 사용자별로 생성

    // 대상 회원 찾기
    let targetUsers = [];
    
    switch (target_type) {
      case 'all':
        const allUsers = await env.DB.prepare('SELECT id FROM users WHERE is_active = TRUE').all();
        targetUsers = allUsers.results.map((u: any) => u.id);
        break;
        
      case 'role':
        if (target_value) {
          const roles = target_value.split(',');
          const placeholders = roles.map(() => '?').join(',');
          const roleUsers = await env.DB.prepare('SELECT id FROM users WHERE is_active = TRUE AND role IN (' + placeholders + ')').bind(...roles).all();
          targetUsers = roleUsers.results.map((u: any) => u.id);
        }
        break;
        
      case 'specific':
        if (target_value) {
          const identifiers = target_value.split(',').map((s: string) => s.trim());
          const placeholders2 = identifiers.map(() => '?').join(',');
          const specificUsers = await env.DB.prepare('SELECT id FROM users WHERE is_active = TRUE AND (username IN (' + placeholders2 + ') OR email IN (' + placeholders2 + '))').bind(...identifiers, ...identifiers).all();
          targetUsers = specificUsers.results.map((u: any) => u.id);
        }
        break;
    }

    // 각 대상 사용자에게 개별 알림 생성
    let successCount = 0;
    for (const userId of targetUsers) {
      try {
        await env.DB.prepare(`
          INSERT INTO notifications (user_id, title, message, type, notification_type, target_type, target_value, expires_at) 
          VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        `).bind(userId, title, content, safeNotificationType, safeNotificationType, safeTargetType, safeTargetValue, safeExpiresAt).run();
        successCount++;
      } catch (error) {
        console.error('Failed to create notification for user', userId, error);
      }
    }

    return c.json({ 
      success: true, 
      sent_count: successCount,
      target_count: targetUsers.length
    });

  } catch (error) {
    console.error('Send notification error:', error);
    return c.json({ error: '알림 발송에 실패했습니다.' }, 500);
  }
});

// API: 공고 작성 (posts 테이블 활용)
app.post('/api/admin/broadcast/announcement', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const { title, content, announcement_type, is_pinned, target_boards, expires_at } = await c.req.json();

    // 공지사항 카테고리 찾기 (없으면 첫 번째 카테고리 사용)
    let category = await env.DB.prepare('SELECT id FROM categories WHERE name LIKE "%공지%" OR name LIKE "%안내%" LIMIT 1').first();
    if (!category) {
      category = await env.DB.prepare('SELECT id FROM categories ORDER BY id LIMIT 1').first();
    }

    if (!category) {
      return c.json({ error: '카테고리가 존재하지 않습니다. 먼저 카테고리를 생성해주세요.' }, 400);
    }

    // 공고를 posts 테이블에 is_featured=true로 저장
    const result = await env.DB.prepare(`
      INSERT INTO posts (title, content, author, user_id, category_id, is_featured, created_at) 
      VALUES (?, ?, ?, ?, ?, ?, datetime('now'))
    `).bind(title, content, user.full_name || user.username, user.id, category.id, true).run();

    return c.json({ 
      success: true, 
      announcement_id: result.meta.last_row_id,
      message: '공고가 성공적으로 작성되었습니다.'
    });

  } catch (error) {
    console.error('Create announcement error:', error);
    console.error('Error details:', error.message);
    return c.json({ error: '공고 작성에 실패했습니다: ' + error.message }, 500);
  }
});

// API: 알림 상태 토글
app.post('/api/admin/broadcast/notification/:id/toggle', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const notificationId = c.req.param('id');
    const { is_active } = await c.req.json();

    await env.DB.prepare('UPDATE notifications SET is_active = ? WHERE id = ?').bind(is_active ? 1 : 0, notificationId).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Toggle notification error:', error);
    return c.json({ error: '상태 변경에 실패했습니다.' }, 500);
  }
});

// API: 알림 삭제
app.delete('/api/admin/broadcast/notification/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const notificationId = c.req.param('id');

    await env.DB.prepare('DELETE FROM notifications WHERE id = ?').bind(notificationId).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Delete notification error:', error);
    return c.json({ error: '알림 삭제에 실패했습니다.' }, 500);
  }
});

// API: 공고 상태 토글 (posts 테이블 is_featured 사용)
app.post('/api/admin/broadcast/announcement/:id/toggle', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const announcementId = c.req.param('id');
    const { is_active } = await c.req.json();

    await env.DB.prepare('UPDATE posts SET is_featured = ? WHERE id = ?').bind(is_active, announcementId).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Toggle announcement error:', error);
    return c.json({ error: '상태 변경에 실패했습니다.' }, 500);
  }
});

// API: 공고 삭제 (posts 테이블에서 삭제)
app.delete('/api/admin/broadcast/announcement/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const announcementId = c.req.param('id');

    await env.DB.prepare('DELETE FROM posts WHERE id = ? AND is_featured = TRUE').bind(announcementId).run();

    return c.json({ success: true });

  } catch (error) {
    console.error('Delete announcement error:', error);
    return c.json({ error: '공고 삭제에 실패했습니다.' }, 500);
  }
});

// =================
// USER MESSAGE SYSTEM (일반 회원용 메시지)
// =================

// 메시지 목록 페이지
app.get('/messages', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;

    // 받은 메시지 목록
    const receivedMessages = await env.DB.prepare(`
      SELECT 
        m.*,
        s.username as sender_username,
        s.full_name as sender_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      WHERE m.recipient_id = ?
      ORDER BY m.created_at DESC
      LIMIT 20
    `).bind(user.id).all();

    // 보낸 메시지 목록
    const sentMessages = await env.DB.prepare(`
      SELECT 
        m.*,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users r ON m.recipient_id = r.id
      WHERE m.sender_id = ?
      ORDER BY m.created_at DESC
      LIMIT 20
    `).bind(user.id).all();

    // 안읽은 메시지 수
    const unreadCount = await env.DB.prepare(
      'SELECT COUNT(*) as count FROM messages WHERE recipient_id = ? AND is_read = 0'
    ).bind(user.id).first();

    // 활성 사용자 목록 (메시지 대상 선택용)
    const activeUsers = await env.DB.prepare(`
      SELECT id, username, full_name 
      FROM users 
      WHERE is_active = TRUE AND id != ?
      ORDER BY full_name
    `).bind(user.id).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">
              <i class="fas fa-envelope text-primary-600 mr-3"></i>
              메시지
            </h1>
            <p class="text-gray-600 mt-2">
              다른 회원들과 개인 메시지를 주고받을 수 있습니다.
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {/* 메시지 요약 */}
            <div class="lg:col-span-3">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                  <div class="flex items-center">
                    <div class="flex-shrink-0">
                      <i class="fas fa-inbox text-blue-600 text-2xl"></i>
                    </div>
                    <div class="ml-4">
                      <h3 class="text-lg font-semibold text-blue-900">받은 메시지</h3>
                      <p class="text-3xl font-bold text-blue-600">{receivedMessages.results.length}</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                  <div class="flex items-center">
                    <div class="flex-shrink-0">
                      <i class="fas fa-paper-plane text-green-600 text-2xl"></i>
                    </div>
                    <div class="ml-4">
                      <h3 class="text-lg font-semibold text-green-900">보낸 메시지</h3>
                      <p class="text-3xl font-bold text-green-600">{sentMessages.results.length}</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                  <div class="flex items-center">
                    <div class="flex-shrink-0">
                      <i class="fas fa-bell text-red-600 text-2xl"></i>
                    </div>
                    <div class="ml-4">
                      <h3 class="text-lg font-semibold text-red-900">안읽은 메시지</h3>
                      <p class="text-3xl font-bold text-red-600">{unreadCount.count}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* 새 메시지 작성 */}
            <div class="lg:col-span-1">
              <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                  <h3 class="text-lg font-semibold text-gray-900">
                    <i class="fas fa-plus-circle text-primary-600 mr-2"></i>
                    새 메시지 작성
                  </h3>
                </div>
                <div class="p-6">
                  <form id="message-form" class="space-y-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">받는 사람</label>
                      <select id="recipient" class="w-full border border-gray-300 rounded-lg px-3 py-2" required>
                        <option value="">받는 사람 선택</option>
                        {activeUsers.results.map((user: any) => (
                          <option value={user.id}>{user.full_name} ({user.username})</option>
                        ))}
                      </select>
                    </div>
                    
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">제목</label>
                      <input type="text" id="subject" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="메시지 제목" required />
                    </div>
                    
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">내용</label>
                      <textarea id="content" rows="6" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="메시지 내용을 입력하세요" required></textarea>
                    </div>
                    
                    <button type="submit" class="w-full bg-primary-600 text-white py-2 rounded-lg hover:bg-primary-700 transition-colors">
                      <i class="fas fa-paper-plane mr-2"></i>메시지 보내기
                    </button>
                  </form>
                </div>
              </div>
            </div>

            {/* 메시지 목록 */}
            <div class="lg:col-span-2">
              <div class="bg-white rounded-lg shadow">
                <div class="border-b border-gray-200">
                  <nav class="-mb-px flex">
                    <button onclick="showTab('received')" class="tab-button px-6 py-3 text-sm font-medium border-b-2 border-primary-600 text-primary-600" id="received-tab">
                      <i class="fas fa-inbox mr-2"></i>받은 메시지
                    </button>
                    <button onclick="showTab('sent')" class="tab-button px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" id="sent-tab">
                      <i class="fas fa-paper-plane mr-2"></i>보낸 메시지
                    </button>
                  </nav>
                </div>

                {/* 받은 메시지 탭 */}
                <div id="received-messages" class="tab-content p-6">
                  {receivedMessages.results.length > 0 ? (
                    <div class="space-y-4">
                      {receivedMessages.results.map((message: any) => (
                        <div class={`border rounded-lg p-4 cursor-pointer hover:bg-gray-50 ${message.is_read ? 'bg-white' : 'bg-blue-50 border-blue-200'}`} onclick={`viewMessage(${message.id})`}>
                          <div class="flex justify-between items-start mb-2">
                            <div class="flex items-center space-x-2">
                              {!message.is_read && (
                                <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
                              )}
                              <h4 class="font-semibold text-gray-900">{message.subject}</h4>
                            </div>
                            <span class="text-xs text-gray-500">{new Date(message.created_at).toLocaleDateString('ko-KR')}</span>
                          </div>
                          <p class="text-sm text-gray-600 mb-2">보낸 사람: <span class="font-medium">{message.sender_name}</span></p>
                          <p class="text-sm text-gray-500 line-clamp-2">{message.content.substring(0, 100)}...</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-12 text-gray-500">
                      <i class="fas fa-inbox text-4xl mb-4"></i>
                      <p>받은 메시지가 없습니다.</p>
                    </div>
                  )}
                </div>

                {/* 보낸 메시지 탭 */}
                <div id="sent-messages" class="tab-content p-6 hidden">
                  {sentMessages.results.length > 0 ? (
                    <div class="space-y-4">
                      {sentMessages.results.map((message: any) => (
                        <div class="border rounded-lg p-4 cursor-pointer hover:bg-gray-50" onclick={`viewMessage(${message.id})`}>
                          <div class="flex justify-between items-start mb-2">
                            <h4 class="font-semibold text-gray-900">{message.subject}</h4>
                            <span class="text-xs text-gray-500">{new Date(message.created_at).toLocaleDateString('ko-KR')}</span>
                          </div>
                          <p class="text-sm text-gray-600 mb-2">받는 사람: <span class="font-medium">{message.recipient_name}</span></p>
                          <p class="text-sm text-gray-500 line-clamp-2">{message.content.substring(0, 100)}...</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-12 text-gray-500">
                      <i class="fas fa-paper-plane text-4xl mb-4"></i>
                      <p>보낸 메시지가 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* 메시지 상세 모달 */}
        <div id="message-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
          <div class="relative top-20 mx-auto p-5 border w-11/12 md:w-1/2 shadow-lg rounded-md bg-white">
            <div id="message-detail-content">
              {/* 메시지 내용이 여기에 로드됩니다 */}
            </div>
            <div class="flex justify-end mt-4">
              <button onclick="closeMessageModal()" class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400 transition-colors">
                닫기
              </button>
            </div>
          </div>
        </div>

        <script>
          {`
            // 탭 전환
            function showTab(tabName) {
              // 모든 탭 버튼 비활성화
              document.querySelectorAll('.tab-button').forEach(btn => {
                btn.classList.remove('border-primary-600', 'text-primary-600');
                btn.classList.add('border-transparent', 'text-gray-500');
              });
              
              // 모든 탭 내용 숨기기
              document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
              });
              
              // 선택한 탭 활성화
              document.getElementById(tabName + '-tab').classList.remove('border-transparent', 'text-gray-500');
              document.getElementById(tabName + '-tab').classList.add('border-primary-600', 'text-primary-600');
              document.getElementById(tabName + '-messages').classList.remove('hidden');
            }

            // 메시지 작성 폼 제출
            document.getElementById('message-form').addEventListener('submit', async (e) => {
              e.preventDefault();
              
              const recipient = document.getElementById('recipient').value;
              const subject = document.getElementById('subject').value;
              const content = document.getElementById('content').value;
              
              if (!recipient || !subject || !content) {
                alert('모든 필드를 입력해주세요.');
                return;
              }
              
              try {
                const response = await fetch('/api/messages/send', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ recipient_id: recipient, subject, content })
                });
                
                const data = await response.json();
                if (data.success) {
                  alert('메시지가 성공적으로 전송되었습니다!');
                  document.getElementById('message-form').reset();
                  window.location.reload();
                } else {
                  alert('전송 실패: ' + data.error);
                }
              } catch (error) {
                console.error('Send message error:', error);
                alert('메시지 전송 중 오류가 발생했습니다.');
              }
            });

            // 메시지 상세 보기
            async function viewMessage(messageId) {
              try {
                const response = await fetch('/api/messages/' + messageId);
                const data = await response.json();
                
                if (data.success) {
                  const message = data.message;
                  document.getElementById('message-detail-content').innerHTML = \`
                    <div class="mb-4">
                      <h3 class="text-xl font-bold text-gray-900 mb-2">\${message.subject}</h3>
                      <div class="text-sm text-gray-500 mb-4">
                        <p>보낸 사람: <span class="font-medium">\${message.sender_name}</span></p>
                        <p>받는 사람: <span class="font-medium">\${message.recipient_name}</span></p>
                        <p>보낸 시간: \${new Date(message.created_at).toLocaleString('ko-KR')}</p>
                      </div>
                    </div>
                    <div class="border-t pt-4">
                      <p class="whitespace-pre-wrap">\${message.content}</p>
                    </div>
                  \`;
                  
                  document.getElementById('message-modal').classList.remove('hidden');
                } else {
                  alert('메시지를 불러올 수 없습니다.');
                }
              } catch (error) {
                console.error('View message error:', error);
                alert('메시지를 불러오는 중 오류가 발생했습니다.');
              }
            }

            // 메시지 모달 닫기
            function closeMessageModal() {
              document.getElementById('message-modal').classList.add('hidden');
            }
          `}
        </script>
      </Layout>,
      { title: '메시지' }
    );

  } catch (error) {
    console.error('Messages page error:', error);
    return c.redirect('/');
  }
});

// API: 메시지 전송
app.post('/api/messages/send', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.json({ error: '로그인이 필요합니다.' }, 401);
  }

  try {
    const { env } = c;
    const { recipient_id, subject, content } = await c.req.json();

    // 받는 사람이 유효한지 확인
    const recipient = await env.DB.prepare(
      'SELECT id, full_name FROM users WHERE id = ? AND is_active = TRUE'
    ).bind(recipient_id).first();

    if (!recipient) {
      return c.json({ error: '받는 사람을 찾을 수 없습니다.' }, 404);
    }

    // 메시지 저장
    const result = await env.DB.prepare(`
      INSERT INTO messages (sender_id, recipient_id, subject, content) 
      VALUES (?, ?, ?, ?)
    `).bind(user.id, recipient_id, subject, content).run();

    return c.json({ 
      success: true, 
      message_id: result.meta.last_row_id,
      message: '메시지가 성공적으로 전송되었습니다.'
    });

  } catch (error) {
    console.error('Send message error:', error);
    return c.json({ error: '메시지 전송에 실패했습니다.' }, 500);
  }
});

// API: 메시지 상세 조회
app.get('/api/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.json({ error: '로그인이 필요합니다.' }, 401);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    const message = await env.DB.prepare(`
      SELECT 
        m.*,
        s.username as sender_username,
        s.full_name as sender_name,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      WHERE m.id = ? AND (m.sender_id = ? OR m.recipient_id = ?)
    `).bind(messageId, user.id, user.id).first();

    if (!message) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    // 받은 메시지인 경우 읽음 처리
    if (message.recipient_id === user.id && !message.is_read) {
      await env.DB.prepare(
        'UPDATE messages SET is_read = 1, read_at = datetime(\'now\') WHERE id = ?'
      ).bind(messageId).run();
    }

    return c.json({ success: true, message });

  } catch (error) {
    console.error('Get message error:', error);
    return c.json({ error: '메시지를 불러오는데 실패했습니다.' }, 500);
  }
});

// API: 메시지 삭제
app.delete('/api/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.json({ error: '로그인이 필요합니다.' }, 401);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    // 자신이 보내거나 받은 메시지인지 확인
    const message = await env.DB.prepare(
      'SELECT * FROM messages WHERE id = ? AND (sender_id = ? OR recipient_id = ?)'
    ).bind(messageId, user.id, user.id).first();

    if (!message) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    await env.DB.prepare('DELETE FROM messages WHERE id = ?').bind(messageId).run();

    return c.json({ success: true, message: '메시지가 삭제되었습니다.' });

  } catch (error) {
    console.error('Delete message error:', error);
    return c.json({ error: '메시지 삭제에 실패했습니다.' }, 500);
  }
});

