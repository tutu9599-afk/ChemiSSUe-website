// Content Section Edit Page
app.get('/admin/content/sections/:sectionKey', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const sectionKey = c.req.param('sectionKey');

    // Get section info
    const section = await env.DB.prepare(`
      SELECT * FROM content_sections WHERE section_key = ?
    `).bind(sectionKey).first();

    if (!section) {
      return c.redirect('/admin/content');
    }

    // Get content items for this section
    const items = await env.DB.prepare(`
      SELECT * FROM content_items 
      WHERE section_key = ? AND is_active = TRUE 
      ORDER BY item_order ASC, item_key ASC
    `).bind(sectionKey).all();

    return c.render(
      <Layout user={user}>
        <ContentSectionEditor 
          section={section}
          items={items.results}
        />
      </Layout>,
      { title: `${section.section_title} 편집` }
    );

  } catch (error) {
    console.error('Section editor error:', error);
    return c.redirect('/admin/content');
  }
});

// Content Section Editor Component
const ContentSectionEditor = ({ section, items }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">
              <i class="fas fa-edit text-primary-600 mr-3"></i>
              {section.section_title} 편집
            </h1>
            <p class="text-gray-600">{section.section_description}</p>
          </div>
          <div class="flex space-x-3">
            <a 
              href="/admin/content" 
              class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors"
            >
              <i class="fas fa-arrow-left mr-2"></i>뒤로
            </a>
            <button 
              onclick="saveAllItems()" 
              id="save-btn"
              class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
            >
              <i class="fas fa-save mr-2"></i>저장
            </button>
          </div>
        </div>
      </div>
    </section>

    {/* Editor */}
    <section class="py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">편집 가능한 항목</h2>
            <p class="text-sm text-gray-500">각 항목을 클릭하여 내용을 수정하세요</p>
          </div>
          <div class="p-6">
            <form id="content-form" class="space-y-6">
              {items.map((item: any, index: number) => (
                <div class="border border-gray-200 rounded-lg p-4">
                  <label class="block text-sm font-medium text-gray-700 mb-2">
                    {item.item_label}
                    {item.is_required && <span class="text-red-500 ml-1">*</span>}
                  </label>
                  
                  {item.item_type === 'textarea' ? (
                    <textarea 
                      id={`item-${item.id}`}
                      data-item-id={item.id}
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                      rows="4"
                      placeholder={`${item.item_label}을(를) 입력하세요`}
                      required={item.is_required}
                    >{item.item_value || ''}</textarea>
                  ) : item.item_type === 'email' ? (
                    <input 
                      type="email"
                      id={`item-${item.id}`}
                      data-item-id={item.id}
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                      value={item.item_value || ''}
                      placeholder={`${item.item_label}을(를) 입력하세요`}
                      required={item.is_required}
                    />
                  ) : item.item_type === 'phone' ? (
                    <input 
                      type="tel"
                      id={`item-${item.id}`}
                      data-item-id={item.id}
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                      value={item.item_value || ''}
                      placeholder={`${item.item_label}을(를) 입력하세요`}
                      required={item.is_required}
                    />
                  ) : (
                    <input 
                      type="text"
                      id={`item-${item.id}`}
                      data-item-id={item.id}
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                      value={item.item_value || ''}
                      placeholder={`${item.item_label}을(를) 입력하세요`}
                      required={item.is_required}
                    />
                  )}
                  
                  <div class="mt-2 text-xs text-gray-500">
                    항목 유형: {
                      item.item_type === 'text' ? '텍스트' :
                      item.item_type === 'textarea' ? '긴 텍스트' :
                      item.item_type === 'email' ? '이메일' :
                      item.item_type === 'phone' ? '전화번호' :
                      '기타'
                    }
                  </div>
                </div>
              ))}
            </form>
            
            {items.length === 0 && (
              <div class="text-center py-12 text-gray-500">
                <i class="fas fa-inbox text-4xl mb-4"></i>
                <p>편집 가능한 항목이 없습니다.</p>
              </div>
            )}
          </div>
        </div>

        {/* Help */}
        <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-blue-900 mb-3">
            <i class="fas fa-info-circle mr-2"></i>
            도움말
          </h3>
          <ul class="text-sm text-blue-700 space-y-2">
            <li>• 각 입력 필드에 원하는 내용을 입력하세요</li>
            <li>• 빨간색 별표(*)가 있는 항목은 필수 입력 항목입니다</li>
            <li>• 변경사항은 '저장' 버튼을 클릭해야 적용됩니다</li>
            <li>• 저장 후 홈페이지에서 바로 확인할 수 있습니다</li>
          </ul>
        </div>
      </div>
    </section>

    <script>{`
      // 모든 항목 저장
      async function saveAllItems() {
        const saveBtn = document.getElementById('save-btn');
        const originalText = saveBtn.innerHTML;
        saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>저장 중...';
        saveBtn.disabled = true;

        const items = [];
        const inputs = document.querySelectorAll('[data-item-id]');
        
        inputs.forEach(input => {
          items.push({
            id: input.dataset.itemId,
            value: input.value
          });
        });

        try {
          const response = await fetch('/api/admin/content/items/batch', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ items })
          });

          const data = await response.json();
          
          if (data.success) {
            showNotification('모든 변경사항이 저장되었습니다!', 'success');
          } else {
            showNotification(data.error || '저장에 실패했습니다.', 'error');
          }
        } catch (error) {
          console.error('Save error:', error);
          showNotification('저장 중 오류가 발생했습니다.', 'error');
        } finally {
          saveBtn.innerHTML = originalText;
          saveBtn.disabled = false;
        }
      }

      // 알림 표시
      function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = \`fixed top-4 right-4 z-50 px-6 py-3 rounded-md shadow-lg border \${
          type === 'success' 
            ? 'bg-green-50 text-green-800 border-green-200' 
            : 'bg-red-50 text-red-800 border-red-200'
        }\`;
        notification.innerHTML = \`
          <div class="flex items-center">
            <i class="fas \${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-2"></i>
            \${message}
          </div>
        \`;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
          if (document.body.contains(notification)) {
            document.body.removeChild(notification);
          }
        }, 5000);
      }

      // 실시간 미리보기 (선택 사항)
      document.addEventListener('DOMContentLoaded', function() {
        console.log('Content editor loaded');
        
        // 입력 필드 변경 감지
        const inputs = document.querySelectorAll('[data-item-id]');
        inputs.forEach(input => {
          input.addEventListener('input', function() {
            // 변경사항이 있음을 표시 (필요시 구현)
          });
        });
      });
    `}</script>
  </div>
);

// API: Batch update content items
app.post('/api/admin/content/items/batch', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const { items } = await c.req.json();

    if (!items || !Array.isArray(items)) {
      return c.json({ error: '유효하지 않은 데이터입니다.' }, 400);
    }

    let updatedCount = 0;

    // Update each item
    for (const item of items) {
      if (!item.id || item.value === undefined) continue;

      try {
        await env.DB.prepare(`
          UPDATE content_items 
          SET item_value = ?, updated_at = datetime('now')
          WHERE id = ?
        `).bind(item.value, item.id).run();

        // Log the change
        await env.DB.prepare(`
          INSERT INTO content_change_log (table_name, record_id, field_name, new_value, changed_by)
          VALUES ('content_items', ?, 'item_value', ?, ?)
        `).bind(item.id, item.value, user.id).run();

        updatedCount++;
      } catch (error) {
        console.error(`Failed to update item ${item.id}:`, error);
      }
    }

    return c.json({ 
      success: true, 
      message: `${updatedCount}개 항목이 업데이트되었습니다.`,
      updated_count: updatedCount
    });

  } catch (error) {
    console.error('Batch update error:', error);
    return c.json({ error: '업데이트 중 오류가 발생했습니다.' }, 500);
  }
});

// Activities Management Page
app.get('/admin/content/activities/:category', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  const category = c.req.param('category');
  if (category !== 'academic' && category !== 'communication') {
    return c.redirect('/admin/content');
  }

  try {
    const { env } = c;

    const activities = await env.DB.prepare(`
      SELECT * FROM activity_items 
      WHERE category = ? AND is_active = TRUE 
      ORDER BY item_order ASC, id ASC
    `).bind(category).all();

    const categoryName = category === 'academic' ? '학업 활동' : '소통 활동';

    return c.render(
      <Layout user={user}>
        <ActivityEditor 
          category={category}
          categoryName={categoryName}
          activities={activities.results}
        />
      </Layout>,
      { title: `${categoryName} 관리` }
    );

  } catch (error) {
    console.error('Activities page error:', error);
    return c.redirect('/admin/content');
  }
});

// Activity Editor Component
const ActivityEditor = ({ category, categoryName, activities }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">
              <i class={`fas ${category === 'academic' ? 'fa-graduation-cap' : 'fa-comments'} text-primary-600 mr-3`}></i>
              {categoryName} 관리
            </h1>
            <p class="text-gray-600">활동 목록을 추가, 수정, 삭제할 수 있습니다</p>
          </div>
          <div class="flex space-x-3">
            <a 
              href="/admin/content" 
              class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors"
            >
              <i class="fas fa-arrow-left mr-2"></i>뒤로
            </a>
            <button 
              onclick="addNewActivity()" 
              class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
            >
              <i class="fas fa-plus mr-2"></i>새 활동 추가
            </button>
          </div>
        </div>
      </div>
    </section>

    {/* Activities List */}
    <section class="py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg shadow">
          <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">현재 활동 목록</h2>
            <p class="text-sm text-gray-500">드래그하여 순서를 변경하거나 항목을 편집하세요</p>
          </div>
          <div class="p-6">
            <div id="activities-list" class="space-y-4">
              {activities.map((activity: any, index: number) => (
                <div class="activity-item border border-gray-200 rounded-lg p-4 cursor-move" data-id={activity.id}>
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center space-x-2 mb-2">
                        <i class={`fas ${activity.icon || 'fa-check'} text-primary-600`}></i>
                        <input 
                          type="text" 
                          class="activity-title font-medium text-gray-900 border-none bg-transparent flex-1 focus:ring-2 focus:ring-primary-500 focus:border-transparent rounded px-2 py-1"
                          value={activity.title}
                          placeholder="활동 제목"
                        />
                      </div>
                      <textarea 
                        class="activity-description w-full text-sm text-gray-600 border-none bg-transparent resize-none focus:ring-2 focus:ring-primary-500 focus:border-transparent rounded px-2 py-1"
                        rows="2"
                        placeholder="활동 설명"
                      >{activity.description}</textarea>
                    </div>
                    <div class="flex items-center space-x-2 ml-4">
                      <button 
                        onclick={`saveActivity(${activity.id})`} 
                        class="text-green-600 hover:text-green-800 p-1"
                        title="저장"
                      >
                        <i class="fas fa-save"></i>
                      </button>
                      <button 
                        onclick={`deleteActivity(${activity.id})`} 
                        class="text-red-600 hover:text-red-800 p-1"
                        title="삭제"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                      <div class="text-gray-400 cursor-move">
                        <i class="fas fa-grip-vertical"></i>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            
            {activities.length === 0 && (
              <div class="text-center py-12 text-gray-500">
                <i class="fas fa-clipboard-list text-4xl mb-4"></i>
                <p>활동 항목이 없습니다.</p>
                <button 
                  onclick="addNewActivity()" 
                  class="mt-4 bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors"
                >
                  첫 번째 활동 추가하기
                </button>
              </div>
            )}
          </div>
        </div>

        {/* Help */}
        <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-blue-900 mb-3">
            <i class="fas fa-lightbulb mr-2"></i>
            사용 팁
          </h3>
          <ul class="text-sm text-blue-700 space-y-2">
            <li>• 항목을 드래그하여 순서를 변경할 수 있습니다</li>
            <li>• 제목과 설명을 클릭하여 바로 편집하세요</li>
            <li>• 각 항목을 수정한 후 저장 버튼을 클릭해주세요</li>
            <li>• 삭제된 항목은 복구할 수 없으니 주의하세요</li>
          </ul>
        </div>
      </div>
    </section>

    <script>{`
      const category = '${category}';
      
      // 새 활동 추가
      async function addNewActivity() {
        const title = prompt('새 활동의 제목을 입력하세요:');
        if (!title) return;
        
        const description = prompt('활동 설명을 입력하세요 (선택사항):') || '';
        
        try {
          const response = await fetch('/api/admin/content/activities', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              category,
              title,
              description,
              icon: 'fa-check'
            })
          });
          
          const data = await response.json();
          if (data.success) {
            location.reload();
          } else {
            alert('추가 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 활동 저장
      async function saveActivity(id) {
        const item = document.querySelector(\`[data-id="\${id}"]\`);
        const title = item.querySelector('.activity-title').value;
        const description = item.querySelector('.activity-description').value;
        
        if (!title) {
          alert('제목을 입력해주세요.');
          return;
        }
        
        try {
          const response = await fetch(\`/api/admin/content/activities/\${id}\`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title, description })
          });
          
          const data = await response.json();
          if (data.success) {
            showNotification('저장되었습니다!', 'success');
          } else {
            alert('저장 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }
      
      // 활동 삭제
      async function deleteActivity(id) {
        if (!confirm('정말로 이 활동을 삭제하시겠습니까?')) return;
        
        try {
          const response = await fetch(\`/api/admin/content/activities/\${id}\`, {
            method: 'DELETE'
          });
          
          const data = await response.json();
          if (data.success) {
            document.querySelector(\`[data-id="\${id}"]\`).remove();
            showNotification('삭제되었습니다!', 'success');
          } else {
            alert('삭제 실패: ' + data.error);
          }
        } catch (error) {
          alert('오류가 발생했습니다.');
        }
      }

      // 알림 표시
      function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = \`fixed top-4 right-4 z-50 px-6 py-3 rounded-md shadow-lg border \${
          type === 'success' 
            ? 'bg-green-50 text-green-800 border-green-200' 
            : 'bg-red-50 text-red-800 border-red-200'
        }\`;
        notification.innerHTML = \`
          <div class="flex items-center">
            <i class="fas \${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-2"></i>
            \${message}
          </div>
        \`;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
          if (document.body.contains(notification)) {
            document.body.removeChild(notification);
          }
        }, 3000);
      }
    `}</script>
  </div>
);

// Values & Goals Management Page
app.get('/admin/content/values-goals', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;

    const valuesGoals = await env.DB.prepare(`
      SELECT * FROM values_goals 
      WHERE is_active = TRUE 
      ORDER BY item_order ASC, id ASC
    `).all();

    return c.render(
      <Layout user={user}>
        <ValuesGoalsEditor values={valuesGoals.results} />
      </Layout>,
      { title: '가치와 목표 관리' }
    );

  } catch (error) {
    console.error('Values goals page error:', error);
    return c.redirect('/admin/content');
  }
});

// Values Goals Editor Component
const ValuesGoalsEditor = ({ values }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">
