// User Notifications Page
app.get('/notifications', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get user's notifications
    const notifications = await env.DB.prepare(`
      SELECT 
        n.*,
        CASE 
          WHEN n.type = 'post' THEN (SELECT title FROM posts WHERE id = n.related_id)
          WHEN n.type = 'event' THEN (SELECT title FROM events WHERE id = n.related_id)
          ELSE NULL
        END as related_title
      FROM notifications n
      WHERE n.user_id = ?
      ORDER BY n.created_at DESC
      LIMIT 50
    `).bind(user.id).all();

    // Get notification stats
    const unreadCount = await env.DB.prepare(`
      SELECT COUNT(*) as count FROM notifications WHERE user_id = ? AND is_read = 0
    `).bind(user.id).first();

    return c.render(
      <Layout user={user} userNotificationCount={unreadCount.count}>
        <UserNotificationsPage 
          notifications={notifications.results}
          unreadCount={unreadCount.count}
        />
      </Layout>,
      { title: '알림' }
    );

  } catch (error) {
    console.error('Notifications page error:', error);
    return c.redirect('/');
  }
});

// User Notifications Component
const UserNotificationsPage = ({ notifications, unreadCount }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-4xl font-bold text-gray-900 mb-4">
              <i class="fas fa-bell text-blue-600 mr-3"></i>
              내 알림
            </h1>
            <p class="text-gray-600 text-lg">
              읽지 않은 알림 {unreadCount}개가 있습니다
            </p>
          </div>
          <div class="flex space-x-3">
            <button 
              onclick="markAllAsRead()" 
              class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
            >
              <i class="fas fa-check-double mr-2"></i>모두 읽음
            </button>
          </div>
        </div>
      </div>
    </section>

    {/* Notifications */}
    <section class="py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg shadow overflow-hidden">
          {notifications && notifications.length > 0 ? (
            <div class="divide-y divide-gray-200">
              {notifications.map((notification: any) => (
                <div class={`p-6 ${!notification.is_read ? 'bg-blue-50 border-l-4 border-blue-500' : ''}`}>
                  <div class="flex items-start justify-between">
                    <div class="flex space-x-4">
                      <div class={`p-3 rounded-full ${
                        notification.type === 'system' ? 'bg-gray-100 text-gray-600' :
                        notification.type === 'post' ? 'bg-blue-100 text-blue-600' :
                        notification.type === 'event' ? 'bg-green-100 text-green-600' :
                        'bg-yellow-100 text-yellow-600'
                      }`}>
                        <i class={`fas ${
                          notification.type === 'system' ? 'fa-cog' :
                          notification.type === 'post' ? 'fa-file-alt' :
                          notification.type === 'event' ? 'fa-calendar' :
                          'fa-bell'
                        }`}></i>
                      </div>
                      <div class="flex-1">
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">
                          {notification.title}
                        </h3>
                        <p class="text-gray-700 mb-3">{notification.message}</p>
                        
                        {notification.related_title && (
                          <div class="mb-3">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                              <i class="fas fa-link mr-2"></i>
                              {notification.related_title}
                            </span>
                          </div>
                        )}
                        
                        <div class="flex items-center text-sm text-gray-500 space-x-4">
                          <span class="flex items-center">
                            <i class="fas fa-clock mr-1"></i>
                            {new Date(notification.created_at).toLocaleDateString('ko-KR', {
                              year: 'numeric',
                              month: 'short',
                              day: 'numeric',
                              hour: '2-digit',
                              minute: '2-digit'
                            })}
                          </span>
                          <span class={`flex items-center ${
                            notification.is_read ? 'text-green-600' : 'text-blue-600'
                          }`}>
                            <i class={`fas ${notification.is_read ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-1`}></i>
                            {notification.is_read ? '읽음' : '새 알림'}
                          </span>
                        </div>
                      </div>
                    </div>
                    
                    <div class="flex items-center space-x-2">
                      {!notification.is_read && (
                        <button 
                          onclick={`markAsRead(${notification.id})`}
                          class="text-green-600 hover:text-green-800 transition-colors p-2"
                          title="읽음 처리"
                        >
                          <i class="fas fa-check"></i>
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="p-12 text-center">
              <i class="fas fa-bell-slash text-gray-400 text-5xl mb-4"></i>
              <h3 class="text-xl font-medium text-gray-900 mb-2">알림이 없습니다</h3>
              <p class="text-gray-500">아직 받은 알림이 없습니다.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    {/* JavaScript */}
    <script>
      {`
        function markAsRead(id) {
          fetch('/api/notifications/' + id + '/read', {
            method: 'POST'
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              location.reload();
            }
          });
        }

        function markAllAsRead() {
          if (!confirm('모든 알림을 읽음 처리하시겠습니까?')) return;

          // Get all unread notification IDs and mark them individually
          const unreadNotifications = document.querySelectorAll('[onclick*="markAsRead"]');
          let promises = [];
          
          unreadNotifications.forEach(btn => {
            const match = btn.getAttribute('onclick').match(/markAsRead\\((\\d+)\\)/);
            if (match) {
              const id = match[1];
              promises.push(
                fetch('/api/notifications/' + id + '/read', {
                  method: 'POST'
                })
              );
            }
          });

          Promise.all(promises).then(() => {
            location.reload();
          });
        }
      `}
    </script>
  </div>
);

// User Profile Page
app.get('/profile', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get user's recent activity
    const recentActivity = await env.DB.prepare(`
      SELECT 'post' as type, title, created_at FROM posts WHERE user_id = ?
      UNION ALL
      SELECT 'comment' as type, content as title, created_at FROM comments WHERE user_id = ?
      ORDER BY created_at DESC
      LIMIT 10
    `).bind(user.id, user.id).all();

    // Get user notification count
    const notificationCount = await env.DB.prepare(`
      SELECT COUNT(*) as count FROM notifications WHERE user_id = ? AND is_read = 0
    `).bind(user.id).first();

    return c.render(
      <Layout user={user} userNotificationCount={notificationCount.count}>
        <UserProfilePage 
          user={user}
          recentActivity={recentActivity.results}
        />
      </Layout>,
      { title: '내 프로필' }
    );

  } catch (error) {
    console.error('Profile page error:', error);
    return c.redirect('/');
  }
});

// User Profile Component
const UserProfilePage = ({ user, recentActivity }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="text-center">
          <div class="mb-6">
            {user.profile_image ? (
              <img 
                class="w-24 h-24 rounded-full mx-auto mb-4" 
                src={user.profile_image} 
                alt={user.full_name} 
              />
            ) : (
              <div class="w-24 h-24 rounded-full bg-primary-600 flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-white">{user.full_name.charAt(0)}</span>
              </div>
            )}
          </div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2">{user.full_name}</h1>
          <p class="text-gray-600 text-lg">@{user.username}</p>
          <div class="flex items-center justify-center space-x-6 mt-4">
            <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${
              user.role === 'admin' ? 'bg-red-100 text-red-800' :
              user.role === 'moderator' ? 'bg-blue-100 text-blue-800' :
              'bg-gray-100 text-gray-800'
            }`}>
              <i class={`fas ${
                user.role === 'admin' ? 'fa-crown' :
                user.role === 'moderator' ? 'fa-shield-alt' :
                'fa-user'
              } mr-1`}></i>
              {user.role === 'admin' ? '관리자' :
               user.role === 'moderator' ? '운영진' : '회원'}
            </span>
            {user.email_verified && (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                <i class="fas fa-check-circle mr-1"></i>
                인증됨
              </span>
            )}
          </div>
        </div>
      </div>
    </section>

    {/* Content */}
    <section class="py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          {/* User Info */}
          <div class="lg:col-span-1">
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-id-card text-blue-600 mr-2"></i>기본 정보
              </h2>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-500">이메일</label>
                  <p class="text-gray-900">{user.email}</p>
                </div>
                {user.student_id && (
                  <div>
                    <label class="block text-sm font-medium text-gray-500">학번</label>
                    <p class="text-gray-900">{user.student_id}</p>
                  </div>
                )}
                <div>
                  <label class="block text-sm font-medium text-gray-500">가입일</label>
                  <p class="text-gray-900">
                    {new Date(user.created_at).toLocaleDateString('ko-KR')}
                  </p>
                </div>
                {user.last_login && (
                  <div>
                    <label class="block text-sm font-medium text-gray-500">마지막 로그인</label>
                    <p class="text-gray-900">
                      {new Date(user.last_login).toLocaleDateString('ko-KR')}
                    </p>
                  </div>
                )}
              </div>
              
              <div class="mt-6 pt-6 border-t">
                <button class="w-full bg-primary-600 text-white py-2 px-4 rounded-lg hover:bg-primary-700 transition-colors">
                  <i class="fas fa-edit mr-2"></i>프로필 수정
                </button>
              </div>
            </div>
          </div>

          {/* Recent Activity */}
          <div class="lg:col-span-2">
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-history text-green-600 mr-2"></i>최근 활동
              </h2>
              
              {recentActivity && recentActivity.length > 0 ? (
                <div class="space-y-4">
                  {recentActivity.map((activity: any) => (
                    <div class="flex items-start space-x-3 p-3 bg-gray-50 rounded-lg">
                      <div class={`p-2 rounded-full ${
                        activity.type === 'post' ? 'bg-blue-100 text-blue-600' : 'bg-green-100 text-green-600'
                      }`}>
                        <i class={`fas ${activity.type === 'post' ? 'fa-file-alt' : 'fa-comment'} text-sm`}></i>
                      </div>
                      <div class="flex-1">
                        <p class="text-gray-900 font-medium">
                          {activity.type === 'post' ? '게시글 작성' : '댓글 작성'}
                        </p>
                        <p class="text-gray-600 text-sm mt-1">
                          {activity.title.length > 50 ? 
                            activity.title.substring(0, 50) + '...' : 
                            activity.title}
                        </p>
                        <p class="text-gray-500 text-xs mt-2">
                          {new Date(activity.created_at).toLocaleDateString('ko-KR')}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="text-center py-8">
                  <i class="fas fa-clock text-gray-400 text-4xl mb-4"></i>
                  <p class="text-gray-500">최근 활동이 없습니다.</p>
                </div>
              )}
            </div>

            {/* Quick Actions */}
            <div class="bg-white rounded-lg shadow p-6 mt-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-bolt text-yellow-600 mr-2"></i>빠른 작업
              </h2>
              <div class="grid grid-cols-2 gap-4">
                <a 
                  href="/notifications" 
                  class="flex items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <i class="fas fa-bell text-blue-600 mr-2"></i>
                  내 알림
                </a>
                <a 
                  href="/board/notices" 
                  class="flex items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <i class="fas fa-bullhorn text-green-600 mr-2"></i>
                  공지사항
                </a>
                <a 
                  href="/board/schedule" 
                  class="flex items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <i class="fas fa-calendar text-purple-600 mr-2"></i>
                  일정표
                </a>
                <a 
                  href="/board/photos" 
                  class="flex items-center justify-center p-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <i class="fas fa-images text-orange-600 mr-2"></i>
                  활동사진
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
);

// Authentication Routes
app.get('/auth/login', (c) => {
  const user = c.get('user');
  if (user) {
    return c.redirect('/');
  }
  
  return c.render(<LoginForm />, { title: '로그인' });
});

app.get('/auth/register', (c) => {
  const user = c.get('user');
  if (user) {
    return c.redirect('/');
  }
  
  return c.render(<RegisterForm />, { title: '회원가입' });
});

// Login API
app.post('/api/auth/login', async (c) => {
  const { env } = c;
  const { username, password, rememberMe } = await c.req.json();

  try {
    // Find user by username or email (including pending users for approval check)
    const user = await env.DB.prepare(`
      SELECT * FROM users 
      WHERE (username = ? OR email = ?)
    `).bind(username, username).first();

    if (!user) {
      return c.json({ error: '아이디 또는 비밀번호가 잘못되었습니다.' }, 401);
    }

    // Verify password
    const isValid = await verifyPassword(password, user.password_hash);
    if (!isValid) {
      return c.json({ error: '아이디 또는 비밀번호가 잘못되었습니다.' }, 401);
    }

    // Check approval status
    if (user.approval_status === 'pending') {
      return c.json({ 
        error: '회원가입 승인이 대기 중입니다. 관리자 승인 후 로그인이 가능합니다.',
        status: 'pending_approval'
      }, 403);
    }

    if (user.approval_status === 'rejected') {
      return c.json({ 
        error: '회원가입이 거부되었습니다. 자세한 사항은 관리자에게 문의해주세요.',
        status: 'rejected'
      }, 403);
    }

    if (!user.is_active) {
      return c.json({ error: '계정이 비활성화되었습니다.' }, 403);
    }

    // Create session
    const sessionId = generateSessionId();
    const expiresAt = new Date();
    expiresAt.setDate(expiresAt.getDate() + (rememberMe ? 30 : 7)); // 30 days or 7 days

    await env.DB.prepare(`
      INSERT INTO sessions (id, user_id, expires_at)
      VALUES (?, ?, ?)
    `).bind(sessionId, user.id, expiresAt.toISOString()).run();

    // Update last login
    await env.DB.prepare(`
      UPDATE users SET last_login = datetime('now') WHERE id = ?
    `).bind(user.id).run();

    // Set cookie - secure set to false for development
    // Simple cookie settings for maximum compatibility
    setCookie(c, 'session_id', sessionId, {
      expires: expiresAt,
      httpOnly: true,
      secure: false,
      path: '/'
    });

    return c.json({ 
      success: true, 
      user: {
        id: user.id,
        username: user.username,
        email: user.email,
        full_name: user.full_name,
        role: user.role
      }
    });

  } catch (error) {
    console.error('Login error:', error);
    return c.json({ error: '로그인 중 오류가 발생했습니다.' }, 500);
  }
});

// Register API
app.post('/api/auth/register', async (c) => {
  const { env } = c;
  const { fullName, studentId, email, username, password, confirmPassword } = await c.req.json();

  try {
    // Validation
    if (password !== confirmPassword) {
      return c.json({ error: '비밀번호가 일치하지 않습니다.' }, 400);
    }

    if (password.length < 6) {
      return c.json({ error: '비밀번호는 최소 6자 이상이어야 합니다.' }, 400);
    }

    // Check if username or email already exists
    const existingUser = await env.DB.prepare(`
      SELECT id FROM users WHERE username = ? OR email = ?
    `).bind(username, email).first();

    if (existingUser) {
      return c.json({ error: '이미 사용 중인 아이디 또는 이메일입니다.' }, 400);
    }

    // Hash password
    const passwordHash = await hashPassword(password);

    // Create user with pending approval status
    const result = await env.DB.prepare(`
      INSERT INTO users (username, email, password_hash, full_name, student_id, approval_status, is_active)
      VALUES (?, ?, ?, ?, ?, 'pending', 0)
    `).bind(username, email, passwordHash, fullName, studentId || null).run();

    return c.json({ 
      success: true, 
      message: '회원가입 신청이 완료되었습니다. 관리자 승인 후 로그인이 가능합니다.',
      status: 'pending_approval'
    });

  } catch (error) {
    console.error('Register error:', error);
    return c.json({ error: '회원가입 중 오류가 발생했습니다.' }, 500);
  }
});

// Logout API
app.post('/api/auth/logout', async (c) => {
  const { env } = c;
  const sessionId = getCookie(c, 'session_id');

  if (sessionId) {
    // Delete session from database
    await env.DB.prepare(`
      DELETE FROM sessions WHERE id = ?
    `).bind(sessionId).run();
  }

  // Delete cookie
  deleteCookie(c, 'session_id', { path: '/' });

  return c.json({ success: true });
});

// Session Validation API (for debugging)
app.post('/api/auth/validate', async (c) => {
  const sessionId = getCookie(c, 'session_id');
  const user = c.get('user');
  
  const result = {
    hasSessionCookie: !!sessionId,
    sessionId: sessionId || null,
    hasUser: !!user,
    user: user ? {
      id: user.id,
      username: user.username,
      email: user.email,
      role: user.role
    } : null,
    timestamp: new Date().toISOString(),
    cookies: c.req.header('Cookie') || 'none'
  };
  
  return c.json(result);
});

// File Upload API (using FormData)
app.post('/api/upload', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.json({ error: '로그인이 필요합니다.' }, 401);
  }

  try {
    const { env } = c;
    const formData = await c.req.formData();
    const file = formData.get('file') as File;
    const purpose = formData.get('purpose') as string || 'general';

    if (!file) {
      return c.json({ error: '파일이 선택되지 않았습니다.' }, 400);
    }

    // File validation
    const maxSize = 10 * 1024 * 1024; // 10MB
    if (file.size > maxSize) {
      return c.json({ error: '파일 크기는 10MB 이하여야 합니다.' }, 400);
    }

    const allowedTypes = [
      'image/jpeg', 'image/png', 'image/gif', 'image/webp',
      'application/pdf', 'application/msword', 
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'text/plain'
    ];

    if (!allowedTypes.includes(file.type)) {
      return c.json({ error: '지원하지 않는 파일 형식입니다.' }, 400);
    }

    // Generate unique filename
    const timestamp = Date.now();
    const randomString = Math.random().toString(36).substring(7);
    const extension = file.name.split('.').pop();
    const filename = `${timestamp}_${randomString}.${extension}`;
    const filePath = `/uploads/${filename}`;

    // In a real implementation, you would save to R2 or similar storage
    // For now, we'll just save the metadata
    const result = await env.DB.prepare(`
      INSERT INTO uploaded_files (
        filename, original_name, file_path, file_size, 
        mime_type, uploaded_by, upload_purpose, is_public
      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `).bind(
      filename, 
      file.name, 
      filePath, 
      file.size, 
      file.type, 
      user.id, 
      purpose, 
      purpose === 'profile_image' ? true : false
    ).run();

    // JavaScript에서 예상하는 형식으로 응답
    return c.json({
      success: true,
      id: result.meta.last_row_id,
      filename,
      original_name: file.name,
      file_size: file.size,
      file_type: file.type,
      url: filePath  // 임시로 filePath 사용, 나중에 실제 URL로 변경
    });

  } catch (error) {
    console.error('Upload error:', error);
    return c.json({ error: '파일 업로드 중 오류가 발생했습니다.' }, 500);
  }
});

// Create Post API (with file attachments)
app.post('/api/posts', async (c) => {
  const user = c.get('user');
  if (!user) {
    return c.json({ error: '로그인이 필요합니다.' }, 401);
  }

  try {
    const { env } = c;
    const { title, content, category_slug, attachments, is_featured } = await c.req.json();

    // Get category
    const category = await env.DB.prepare(`
      SELECT id FROM categories WHERE slug = ?
    `).bind(category_slug).first();

    if (!category) {
      return c.json({ error: '존재하지 않는 카테고리입니다.' }, 400);
    }

    // Check if user can create posts in this category
    const canCreate = await canUserCreatePost(env, user.id, category_slug);
    if (!canCreate) {
      return c.json({ error: '이 게시판에 글을 작성할 권한이 없습니다.' }, 403);
    }

    // Check if user can create featured posts (admin only)
    const canFeature = user.role === 'admin' || user.role === 'moderator';
    const featuredFlag = canFeature && is_featured ? 1 : 0;

    // Create post
    const result = await env.DB.prepare(`
      INSERT INTO posts (title, content, category_id, user_id, author, is_featured)
      VALUES (?, ?, ?, ?, ?, ?)
    `).bind(title, content, category.id, user.id, user.full_name, featuredFlag).run();

    const postId = result.meta.last_row_id;

    // Add attachments
    if (attachments && attachments.length > 0) {
      for (const fileId of attachments) {
        await env.DB.prepare(`
          UPDATE uploaded_files 
          SET upload_purpose = 'post_attachment'
          WHERE id = ? AND uploaded_by = ?
        `).bind(fileId, user.id).run();

        await env.DB.prepare(`
          INSERT INTO attachments (post_id, filename, file_url, file_size)
          SELECT ?, filename, file_path, file_size
          FROM uploaded_files WHERE id = ?
        `).bind(postId, fileId).run();
      }
    }

    // Notify all users about new post (for important categories)
    if (category_slug === 'notices' && featuredFlag) {
      // Get all users for notification
      const users = await env.DB.prepare(`
        SELECT id FROM users WHERE is_active = TRUE AND id != ?
      `).bind(user.id).all();

      for (const notifyUser of users.results) {
        await createNotification(
          env,
          notifyUser.id,
          '새 공지사항',
          `${title}`,
          'post',
          postId
        );
      }
    }

    return c.json({ success: true, post_id: postId });

  } catch (error) {
    console.error('Create post error:', error);
    return c.json({ error: '게시글 작성 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Panel
app.get('/admin', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get stats
    const stats = await Promise.all([
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = TRUE').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM posts').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM events WHERE start_date >= datetime("now")').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications WHERE is_read = 0').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE approval_status = "pending"').first()
    ]);

    const [usersCount, postsCount, eventsCount, unreadNotifications, pendingApprovals] = stats;

    return c.render(
      <Layout user={user}>
        <AdminPanel 
          stats={{
            users: usersCount.count,
            posts: postsCount.count,
            events: eventsCount.count,
            notifications: unreadNotifications.count,
            pendingApprovals: pendingApprovals.count
          }}
        />
      </Layout>,
      { title: '관리자 패널' }
    );

  } catch (error) {
    console.error('Admin panel error:', error);
    return c.render(
      <Layout user={user}>
        <div class="max-w-4xl mx-auto px-4 py-16">
          <div class="bg-red-50 border border-red-200 rounded-lg p-8 text-center">
            <i class="fas fa-exclamation-triangle text-red-600 text-4xl mb-4"></i>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">오류가 발생했습니다</h2>
            <p class="text-gray-600">관리자 패널을 로드하는 중 문제가 발생했습니다.</p>
          </div>
        </div>
      </Layout>,
      { title: '오류' }
    );
  }
});

