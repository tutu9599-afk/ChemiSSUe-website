// Admin Board Permissions Page
app.get('/admin/permissions', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const permissions = await env.DB.prepare(`
      SELECT 
        c.id as category_id,
        c.name as category_name,
        c.slug as category_slug,
        bp.role,
        bp.can_create,
        bp.can_edit_own,
        bp.can_edit_all,
        bp.can_delete_own,
        bp.can_delete_all,
        bp.can_comment
      FROM categories c
      LEFT JOIN board_permissions bp ON c.id = bp.category_id
      ORDER BY c.name, bp.role
    `).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="bg-white rounded-lg shadow-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
              <h1 class="text-2xl font-bold text-gray-900">게시판 권한 관리</h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700">← 관리자 패널</a>
            </div>
            <div class="p-6">
              <div class="mb-6">
                <p class="text-gray-600 mb-4">
                  각 게시판별로 역할(관리자, 운영진, 일반회원)에 따른 권한을 설정할 수 있습니다.
                </p>
              </div>

              <div class="space-y-8">
                {permissions.results
                  .reduce((acc: any[], curr: any) => {
                    if (!acc.find((item: any) => item.category_id === curr.category_id)) {
                      acc.push({
                        category_id: curr.category_id,
                        category_name: curr.category_name,
                        category_slug: curr.category_slug,
                        permissions: permissions.results.filter((p: any) => p.category_id === curr.category_id)
                      });
                    }
                    return acc;
                  }, [])
                  .map((category: any) => (
                    <div class="border border-gray-200 rounded-lg p-6">
                      <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-folder-open text-primary-600 mr-2"></i>
                        {category.category_name} ({category.category_slug})
                      </h3>
                      
                      <div class="overflow-x-auto">
                        <table class="min-w-full">
                          <thead>
                            <tr class="border-b border-gray-200">
                              <th class="text-left py-2 px-4 font-medium text-gray-700">역할</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">글 작성</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">본인 글 편집</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">모든 글 편집</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">본인 글 삭제</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">모든 글 삭제</th>
                              <th class="text-center py-2 px-4 font-medium text-gray-700">댓글 작성</th>
                            </tr>
                          </thead>
                          <tbody>
                            {['admin', 'moderator', 'member'].map((role: string) => {
                              const perm = category.permissions.find((p: any) => p.role === role);
                              const roleNames = {
                                'admin': '관리자',
                                'moderator': '운영진', 
                                'member': '일반회원'
                              };
                              
                              return (
                                <tr class="border-b border-gray-100">
                                  <td class="py-3 px-4 font-medium">
                                    <span class={`px-2 py-1 rounded text-sm ${
                                      role === 'admin' ? 'bg-red-100 text-red-800' :
                                      role === 'moderator' ? 'bg-blue-100 text-blue-800' :
                                      'bg-gray-100 text-gray-800'
                                    }`}>
                                      {roleNames[role as keyof typeof roleNames]}
                                    </span>
                                  </td>
                                  {['can_create', 'can_edit_own', 'can_edit_all', 'can_delete_own', 'can_delete_all', 'can_comment'].map((permission: string) => (
                                    <td class="py-3 px-4 text-center">
                                      <label class="inline-flex items-center">
                                        <input
                                          type="checkbox"
                                          class="form-checkbox h-4 w-4 text-primary-600 rounded"
                                          checked={perm ? perm[permission] : false}
                                          onchange={`updatePermission(${category.category_id}, '${role}', '${permission}', this.checked)`}
                                          disabled={role === 'admin'}
                                        />
                                      </label>
                                    </td>
                                  ))}
                                </tr>
                              );
                            })}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  ))}
              </div>
              
              {/* 저장/취소 버튼 */}
              <div class="mt-8 flex justify-between items-center bg-gray-50 px-6 py-4 rounded-lg">
                <div class="text-sm text-gray-600">
                  <span id="changes-indicator">
                    <i class="fas fa-info-circle text-blue-500 mr-2"></i>
                    권한을 변경한 후 저장 버튼을 클릭하세요.
                  </span>
                  <span id="changes-count" class="hidden">
                    <i class="fas fa-exclamation-circle text-amber-500 mr-2"></i>
                    <span id="count-number">0</span>개의 변경사항이 있습니다.
                  </span>
                </div>
                <div class="space-x-3">
                  <button
                    id="cancel-btn"
                    onclick="cancelChanges()"
                    class="px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled
                  >
                    <i class="fas fa-times mr-2"></i>취소
                  </button>
                  <button
                    id="save-btn"
                    onclick="saveAllChanges()"
                    class="px-6 py-2 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled
                  >
                    <i class="fas fa-save mr-2"></i>변경사항 저장
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <script>{`
          // 변경사항을 추적하는 전역 변수
          window.permissionChanges = {};
          window.originalValues = {};
          
          // 페이지 로드시 원본 값들을 저장
          document.addEventListener('DOMContentLoaded', function() {
            console.log('Permission management page loaded');
            
            // 모든 체크박스의 원본 값을 저장
            const checkboxes = document.querySelectorAll('input[type="checkbox"]:not([disabled])');
            checkboxes.forEach(checkbox => {
              const onchangeAttr = checkbox.getAttribute('onchange');
              if (onchangeAttr && onchangeAttr.includes('updatePermission')) {
                // onchange 속성에서 파라미터 추출
                const match = onchangeAttr.match(/updatePermission\\((\\d+), '(\\w+)', '(\\w+)',/);
                if (match) {
                  const [, categoryId, role, permission] = match;
                  const key = \`\${categoryId}-\${role}-\${permission}\`;
                  originalValues[key] = checkbox.checked;
                }
              }
            });
            
            console.log('Original values saved:', originalValues);
          });
          
          // 권한 변경 추적 함수
          window.updatePermission = function(categoryId, role, permission, checked) {
            const key = \`\${categoryId}-\${role}-\${permission}\`;
            const originalValue = originalValues[key];
            
            console.log('Permission change:', { categoryId, role, permission, checked, originalValue });
            
            // 변경사항 추적
            if (checked !== originalValue) {
              permissionChanges[key] = {
                categoryId: parseInt(categoryId),
                role: role,
                permission: permission,
                value: checked,
                originalValue: originalValue
              };
            } else {
              // 원본 값과 같으면 변경사항에서 제거
              delete permissionChanges[key];
            }
            
            console.log('Current changes:', permissionChanges);
            updateUI();
          }
          
          // UI 업데이트 함수
          function updateUI() {
            const hasChanges = Object.keys(permissionChanges).length > 0;
            const indicator = document.getElementById('changes-indicator');
            const changesCount = document.getElementById('changes-count');
            const countNumber = document.getElementById('count-number');
            const saveBtn = document.getElementById('save-btn');
            const cancelBtn = document.getElementById('cancel-btn');
            
            if (hasChanges) {
              // 변경사항이 있을 때
              indicator.classList.add('hidden');
              changesCount.classList.remove('hidden');
              
              const count = Object.keys(permissionChanges).length;
              countNumber.textContent = count;
              
              // 버튼 활성화
              saveBtn.disabled = false;
              cancelBtn.disabled = false;
              saveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
              cancelBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            } else {
              // 변경사항이 없을 때
              indicator.classList.remove('hidden');
              changesCount.classList.add('hidden');
              
              // 버튼 비활성화
              saveBtn.disabled = true;
              cancelBtn.disabled = true;
              saveBtn.classList.add('opacity-50', 'cursor-not-allowed');
              cancelBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }
          }
          
          // 모든 변경사항 저장
          window.saveAllChanges = async function() {
            if (Object.keys(permissionChanges).length === 0) {
              showNotification('저장할 변경사항이 없습니다.', 'info');
              return;
            }
            
            const saveBtn = document.getElementById('save-btn');
            const originalText = saveBtn.innerHTML;
            saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>저장 중...';
            saveBtn.disabled = true;
            
            try {
              const changes = Object.values(permissionChanges);
              console.log('Saving changes:', changes);
              
              // 배치로 권한 업데이트 API 호출
              const response = await fetch('/api/admin/permissions/batch', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'Accept': 'application/json'
                },
                credentials: 'include',
                body: JSON.stringify({ changes })
              });
              
              if (response.ok) {
                const result = await response.json();
                console.log('Batch save successful:', result);
                
                // 원본 값들을 현재 값으로 업데이트
                Object.keys(permissionChanges).forEach(key => {
                  originalValues[key] = permissionChanges[key].value;
                });
                
                // 변경사항 초기화
                permissionChanges = {};
                updateUI();
                
                showNotification(\`\${changes.length}개의 권한이 성공적으로 저장되었습니다.\`, 'success');
              } else {
                const error = await response.json();
                console.error('Batch save failed:', error);
                showNotification(error.error || '권한 저장에 실패했습니다.', 'error');
              }
            } catch (error) {
              console.error('Save error:', error);
              showNotification('네트워크 오류로 저장에 실패했습니다.', 'error');
            } finally {
              saveBtn.innerHTML = originalText;
              saveBtn.disabled = false;
            }
          }
          
          // 변경사항 취소
          window.cancelChanges = function() {
            // 모든 체크박스를 원본 값으로 되돌리기
            Object.keys(permissionChanges).forEach(key => {
              const change = permissionChanges[key];
              const checkbox = document.querySelector(\`input[onchange*="updatePermission(\${change.categoryId}, '\${change.role}', '\${change.permission}'"]\`);
              if (checkbox) {
                checkbox.checked = change.originalValue;
              }
            });
            
            // 변경사항 초기화
            permissionChanges = {};
            updateUI();
            
            showNotification('변경사항이 취소되었습니다.', 'info');
          }

          window.showNotification = function(message, type) {
            console.log('Showing notification:', message, type);
            
            // 기존 알림 제거
            const existingNotification = document.querySelector('.permission-notification');
            if (existingNotification) {
              existingNotification.remove();
            }
            
            const notification = document.createElement('div');
            notification.className = 'permission-notification fixed top-16 right-4 z-50 px-6 py-3 rounded-md shadow-lg border ' + 
              (type === 'success' 
                ? 'bg-green-50 text-green-800 border-green-200' 
                : type === 'info'
                  ? 'bg-blue-50 text-blue-800 border-blue-200'
                  : 'bg-red-50 text-red-800 border-red-200');
            notification.innerHTML = \`
              <div class="flex items-center">
                <i class="fas \${type === 'success' ? 'fa-check-circle' : type === 'info' ? 'fa-info-circle' : 'fa-exclamation-circle'} mr-2"></i>
                \${message}
              </div>
            \`;
            document.body.appendChild(notification);
            
            // 애니메이션 효과
            notification.style.transform = 'translateX(100%)';
            notification.style.transition = 'transform 0.3s ease-in-out';
            setTimeout(() => {
              notification.style.transform = 'translateX(0)';
            }, 10);
            
            // 5초 후 자동 제거
            setTimeout(() => {
              if (document.body.contains(notification)) {
                notification.style.transform = 'translateX(100%)';
                setTimeout(() => {
                  if (document.body.contains(notification)) {
                    document.body.removeChild(notification);
                  }
                }, 300);
              }
            }, 5000);
          }
          
          // DOM이 로드된 후 이벤트 리스너 설정
          document.addEventListener('DOMContentLoaded', function() {
            console.log('Permission management page loaded');
          });
        `}</script>
      </Layout>,
      { title: '게시판 권한 관리' }
    );

  } catch (error) {
    console.error('Admin permissions error:', error);
    return c.redirect('/admin');
  }
});

// API: Update Board Permissions
app.post('/api/admin/permissions', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const body = await c.req.json();
    const { category_id, role, permission, value } = body;

    console.log('Permission update request:', { category_id, role, permission, value, user_role: user.role });

    // 입력 검증
    if (!category_id || !role || !permission || value === undefined) {
      return c.json({ error: '필수 파라미터가 누락되었습니다.' }, 400);
    }

    // 관리자 권한은 변경 불가
    if (role === 'admin') {
      return c.json({ error: '관리자 권한은 변경할 수 없습니다.' }, 400);
    }

    // 유효한 권한 필드인지 확인
    const validPermissions = ['can_create', 'can_edit_own', 'can_edit_all', 'can_delete_own', 'can_delete_all', 'can_comment'];
    if (!validPermissions.includes(permission)) {
      return c.json({ error: '유효하지 않은 권한입니다.' }, 400);
    }

    // 유효한 역할인지 확인
    const validRoles = ['moderator', 'member'];
    if (!validRoles.includes(role)) {
      return c.json({ error: '유효하지 않은 역할입니다.' }, 400);
    }

    // 카테고리가 존재하는지 확인
    const categoryExists = await env.DB.prepare(`
      SELECT id FROM categories WHERE id = ?
    `).bind(category_id).first();

    if (!categoryExists) {
      return c.json({ error: '존재하지 않는 카테고리입니다.' }, 400);
    }

    // 현재 권한 상태 확인 (안전한 방식)
    const currentPermission = await env.DB.prepare(`
      SELECT can_create, can_edit_own, can_edit_all, can_delete_own, can_delete_all, can_comment 
      FROM board_permissions 
      WHERE category_id = ? AND role = ?
    `).bind(category_id, role).first();

    let oldValue = 0;
    if (currentPermission) {
      oldValue = currentPermission[permission] || 0;
    }

    // 안전한 권한 업데이트 (완전한 동적 SQL 제거)
    let updateQuery;
    switch (permission) {
      case 'can_create':
        updateQuery = 'UPDATE board_permissions SET can_create = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      case 'can_edit_own':
        updateQuery = 'UPDATE board_permissions SET can_edit_own = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      case 'can_edit_all':
        updateQuery = 'UPDATE board_permissions SET can_edit_all = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      case 'can_delete_own':
        updateQuery = 'UPDATE board_permissions SET can_delete_own = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      case 'can_delete_all':
        updateQuery = 'UPDATE board_permissions SET can_delete_all = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      case 'can_comment':
        updateQuery = 'UPDATE board_permissions SET can_comment = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
        break;
      default:
        return c.json({ error: '지원하지 않는 권한 유형입니다.' }, 400);
    }

    const result = await env.DB.prepare(updateQuery).bind(value ? 1 : 0, category_id, role).run();
    console.log('Permission update result:', result);

    // 로그 기록
    try {
      await env.DB.prepare(`
        INSERT INTO board_permission_logs (category_id, role, permission_field, old_value, new_value, changed_by)
        VALUES (?, ?, ?, ?, ?, ?)
      `).bind(
        category_id, 
        role, 
        permission, 
        oldValue,
        value ? 1 : 0, 
        user.id
      ).run();
    } catch (logError) {
      console.error('Log error (non-blocking):', logError);
    }

    console.log('Permission updated successfully');
    return c.json({ success: true, message: '권한이 성공적으로 업데이트되었습니다.' });

  } catch (error) {
    console.error('Update permission error:', error);
    return c.json({ error: '권한 업데이트 중 오류가 발생했습니다.' }, 500);
  }
});

// API: Batch Update Board Permissions
app.post('/api/admin/permissions/batch', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const body = await c.req.json();
    const { changes } = body;

    console.log('Batch permission update request:', { changes, user_role: user.role });

    if (!changes || !Array.isArray(changes) || changes.length === 0) {
      return c.json({ error: '변경사항이 없습니다.' }, 400);
    }

    // 입력 검증
    const validPermissions = ['can_create', 'can_edit_own', 'can_edit_all', 'can_delete_own', 'can_delete_all', 'can_comment'];
    const validRoles = ['moderator', 'member'];

    for (const change of changes) {
      const { categoryId, role, permission, value } = change;
      
      if (!categoryId || !role || !permission || value === undefined) {
        return c.json({ error: '필수 파라미터가 누락되었습니다.' }, 400);
      }

      if (role === 'admin') {
        return c.json({ error: '관리자 권한은 변경할 수 없습니다.' }, 400);
      }

      if (!validPermissions.includes(permission)) {
        return c.json({ error: `유효하지 않은 권한입니다: ${permission}` }, 400);
      }

      if (!validRoles.includes(role)) {
        return c.json({ error: `유효하지 않은 역할입니다: ${role}` }, 400);
      }
    }

    // 트랜잭션으로 모든 변경사항을 적용
    const updatePromises = changes.map(async (change) => {
      const { categoryId, role, permission, value, originalValue } = change;
      
      // 카테고리 존재 확인
      const categoryExists = await env.DB.prepare(`
        SELECT id FROM categories WHERE id = ?
      `).bind(categoryId).first();

      if (!categoryExists) {
        throw new Error(`존재하지 않는 카테고리입니다: ${categoryId}`);
      }

      // 권한별로 안전한 업데이트 쿼리 실행
      let updateQuery = '';
      switch (permission) {
        case 'can_create':
          updateQuery = 'UPDATE board_permissions SET can_create = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        case 'can_edit_own':
          updateQuery = 'UPDATE board_permissions SET can_edit_own = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        case 'can_edit_all':
          updateQuery = 'UPDATE board_permissions SET can_edit_all = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        case 'can_delete_own':
          updateQuery = 'UPDATE board_permissions SET can_delete_own = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        case 'can_delete_all':
          updateQuery = 'UPDATE board_permissions SET can_delete_all = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        case 'can_comment':
          updateQuery = 'UPDATE board_permissions SET can_comment = ?, updated_at = datetime(\'now\') WHERE category_id = ? AND role = ?';
          break;
        default:
          throw new Error(`지원하지 않는 권한 유형입니다: ${permission}`);
      }

      const result = await env.DB.prepare(updateQuery).bind(value ? 1 : 0, categoryId, role).run();
      
      // 로그 기록
      try {
        await env.DB.prepare(`
          INSERT INTO board_permission_logs (category_id, role, permission_field, old_value, new_value, changed_by)
          VALUES (?, ?, ?, ?, ?, ?)
        `).bind(
          categoryId, 
          role, 
          permission, 
          originalValue ? 1 : 0,
          value ? 1 : 0, 
          user.id
        ).run();
      } catch (logError) {
        console.error('Log error (non-blocking):', logError);
      }
      
      return result;
    });

    // 모든 업데이트 실행
    await Promise.all(updatePromises);

    console.log('Batch permission update successful');
    return c.json({ 
      success: true, 
      message: `${changes.length}개의 권한이 성공적으로 업데이트되었습니다.`,
      updated_count: changes.length
    });

  } catch (error) {
    console.error('Batch update permission error:', error);
    return c.json({ error: error.message || '권한 업데이트 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin User Password Change API
app.post('/api/admin/users/:id/password', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const userId = c.req.param('id');
    const { password } = await c.req.json();

    // Validation
    if (!password || password.length < 6) {
      return c.json({ error: '비밀번호는 최소 6자 이상이어야 합니다.' }, 400);
    }

    // Check if user exists
    const existingUser = await env.DB.prepare(`
      SELECT id, role FROM users WHERE id = ?
    `).bind(userId).first();

    if (!existingUser) {
      return c.json({ error: '사용자를 찾을 수 없습니다.' }, 404);
    }

    // Hash new password
    const passwordHash = await hashPassword(password);

    // Update password
    await env.DB.prepare(`
      UPDATE users SET password_hash = ? WHERE id = ?
    `).bind(passwordHash, userId).run();

    return c.json({ 
      success: true, 
      message: '비밀번호가 변경되었습니다.' 
    });

  } catch (error) {
    console.error('Password change error:', error);
    return c.json({ error: '비밀번호 변경 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin User Delete API
app.delete('/api/admin/users/:id/delete', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const userId = c.req.param('id');

    // Check if user exists
    const existingUser = await env.DB.prepare(`
      SELECT id, role, username FROM users WHERE id = ?
    `).bind(userId).first();

    if (!existingUser) {
      return c.json({ error: '사용자를 찾을 수 없습니다.' }, 404);
    }

    // Prevent deleting admin accounts
    if (existingUser.role === 'admin') {
      return c.json({ error: '관리자 계정은 삭제할 수 없습니다.' }, 400);
    }

    // Prevent deleting self
    if (parseInt(userId) === user.id) {
      return c.json({ error: '자신의 계정은 삭제할 수 없습니다.' }, 400);
    }

    // Begin transaction-like operations
    // Delete related records first to maintain referential integrity
    
    // Delete user's posts
    await env.DB.prepare(`
      DELETE FROM posts WHERE author_id = ?
    `).bind(userId).run();

    // Delete user's comments
    await env.DB.prepare(`
      DELETE FROM comments WHERE user_id = ?
    `).bind(userId).run();

    // Delete user's notifications
    await env.DB.prepare(`
      DELETE FROM notifications WHERE user_id = ?
    `).bind(userId).run();

    // Delete user's sessions
    await env.DB.prepare(`
      DELETE FROM sessions WHERE user_id = ?
    `).bind(userId).run();

    // Finally delete the user
    await env.DB.prepare(`
      DELETE FROM users WHERE id = ?
    `).bind(userId).run();

    return c.json({ 
      success: true, 
      message: '계정이 삭제되었습니다.',
      deletedUser: existingUser.username 
    });

  } catch (error) {
    console.error('User delete error:', error);
    return c.json({ error: '계정 삭제 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Approve User API
app.post('/api/admin/users/:id/approve', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const userId = c.req.param('id');

    // Check if user exists and is pending
    const existingUser = await env.DB.prepare(`
      SELECT id, username, full_name, approval_status FROM users WHERE id = ?
    `).bind(userId).first();

    if (!existingUser) {
      return c.json({ error: '사용자를 찾을 수 없습니다.' }, 404);
    }

    if (existingUser.approval_status !== 'pending') {
      return c.json({ error: '이미 처리된 회원가입 신청입니다.' }, 400);
    }

    // Approve user
    await env.DB.prepare(`
      UPDATE users 
      SET approval_status = 'approved', 
          is_active = 1, 
          approved_by = ?, 
          approved_at = datetime('now')
      WHERE id = ?
    `).bind(user.id, userId).run();

    // Create notification for approved user
    await env.DB.prepare(`
      INSERT INTO notifications (user_id, type, title, message, is_read)
      VALUES (?, 'success', '회원가입 승인', '회원가입이 승인되었습니다. 로그인하여 서비스를 이용해보세요!', 0)
    `).bind(userId).run();

    return c.json({ 
      success: true, 
      message: '회원가입이 승인되었습니다.',
      approvedUser: existingUser.full_name
    });

  } catch (error) {
    console.error('Approve user error:', error);
    return c.json({ error: '승인 처리 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Reject User API
app.post('/api/admin/users/:id/reject', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const userId = c.req.param('id');
    const { reason } = await c.req.json();

    // Check if user exists and is pending
    const existingUser = await env.DB.prepare(`
      SELECT id, username, full_name, approval_status FROM users WHERE id = ?
    `).bind(userId).first();

    if (!existingUser) {
      return c.json({ error: '사용자를 찾을 수 없습니다.' }, 404);
    }

    if (existingUser.approval_status !== 'pending') {
      return c.json({ error: '이미 처리된 회원가입 신청입니다.' }, 400);
    }

    // Reject user
    await env.DB.prepare(`
      UPDATE users 
      SET approval_status = 'rejected', 
          approved_by = ?, 
          approved_at = datetime('now'),
          rejection_reason = ?
      WHERE id = ?
    `).bind(user.id, reason, userId).run();

    return c.json({ 
      success: true, 
      message: '회원가입이 거부되었습니다.',
      rejectedUser: existingUser.full_name,
      reason: reason
    });

  } catch (error) {
    console.error('Reject user error:', error);
    return c.json({ error: '거부 처리 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Get User Details API
app.get('/api/admin/users/:id/details', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
