                방문 통계
              </a>
              <a href="/admin/reports" class="block border border-gray-300 text-gray-700 text-center py-2 px-4 rounded hover:bg-gray-50 transition-colors">
                활동 보고서
              </a>
              <a href="/admin/backup" class="block border border-gray-300 text-gray-700 text-center py-2 px-4 rounded hover:bg-gray-50 transition-colors">
                백업 관리
              </a>
            </div>
          </div>
        </div>

        {/* Recent Activity */}
        <div class="mt-8">
          <div class="bg-white rounded-lg shadow">
            <div class="px-6 py-4 border-b">
              <h3 class="text-lg font-semibold text-gray-900">
                <i class="fas fa-clock text-gray-500 mr-2"></i>
                최근 활동
              </h3>
            </div>
            <div class="p-6">
              <div class="text-gray-500 text-center py-8">
                <i class="fas fa-inbox text-4xl mb-4"></i>
                <p>최근 활동 내역이 여기에 표시됩니다.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
);

// =================
// PAGE CONTENT MANAGEMENT APIs
// =================

// Get page content
app.get('/api/admin/pages/:pageKey', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const pageKey = c.req.param('pageKey');

    const pageContent = await env.DB.prepare(`
      SELECT * FROM page_contents WHERE page_key = ?
    `).bind(pageKey).first();

    const sections = await env.DB.prepare(`
      SELECT * FROM page_sections WHERE page_key = ? ORDER BY sort_order ASC
    `).bind(pageKey).all();

    return c.json({
      page: pageContent,
      sections: sections.results
    });
  } catch (error) {
    return c.json({ error: 'Failed to fetch page content' }, 500);
  }
});

// Update page content
app.put('/api/admin/pages/:pageKey', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const pageKey = c.req.param('pageKey');
    const { title, description, content, meta_title, meta_description, is_published } = await c.req.json();

    // Update or insert page content
    await env.DB.prepare(`
      INSERT INTO page_contents (page_key, title, description, content, meta_title, meta_description, is_published, updated_by, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, datetime('now'))
      ON CONFLICT(page_key) DO UPDATE SET
        title = excluded.title,
        description = excluded.description,
        content = excluded.content,
        meta_title = excluded.meta_title,
        meta_description = excluded.meta_description,
        is_published = excluded.is_published,
        updated_by = excluded.updated_by,
        updated_at = excluded.updated_at
    `).bind(pageKey, title, description, content, meta_title, meta_description, is_published ? 1 : 0, user.id).run();

    return c.json({ success: true });
  } catch (error) {
    return c.json({ error: 'Failed to update page content' }, 500);
  }
});

// Update page section
app.put('/api/admin/pages/:pageKey/sections/:sectionKey', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const pageKey = c.req.param('pageKey');
    const sectionKey = c.req.param('sectionKey');
    const { section_name, content, image_url, is_visible, sort_order } = await c.req.json();

    // Update or insert section
    await env.DB.prepare(`
      INSERT INTO page_sections (page_key, section_key, section_name, content, image_url, is_visible, sort_order, updated_by, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, datetime('now'))
      ON CONFLICT(page_key, section_key) DO UPDATE SET
        section_name = excluded.section_name,
        content = excluded.content,
        image_url = excluded.image_url,
        is_visible = excluded.is_visible,
        sort_order = excluded.sort_order,
        updated_by = excluded.updated_by,
        updated_at = excluded.updated_at
    `).bind(pageKey, sectionKey, section_name, content, image_url, is_visible ? 1 : 0, sort_order, user.id).run();

    return c.json({ success: true });
  } catch (error) {
    return c.json({ error: 'Failed to update section' }, 500);
  }
});

// Get all pages list
app.get('/api/admin/pages', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    
    const pages = await env.DB.prepare(`
      SELECT 
        page_key, 
        title, 
        description, 
        is_published,
        updated_at,
        (SELECT COUNT(*) FROM page_sections WHERE page_key = page_contents.page_key) as sections_count
      FROM page_contents 
      ORDER BY updated_at DESC
    `).all();

    return c.json(pages.results);
  } catch (error) {
    return c.json({ error: 'Failed to fetch pages list' }, 500);
  }
});

// Get site settings
app.get('/api/admin/settings', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    
    const settings = await env.DB.prepare(`
      SELECT * FROM site_settings ORDER BY setting_key
    `).all();

    return c.json(settings.results);
  } catch (error) {
    return c.json({ error: 'Failed to fetch settings' }, 500);
  }
});

// Update site settings
app.put('/api/admin/settings/:settingKey', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const settingKey = c.req.param('settingKey');
    const { setting_value } = await c.req.json();

    await env.DB.prepare(`
      UPDATE site_settings 
      SET setting_value = ?, updated_by = ?, updated_at = datetime('now')
      WHERE setting_key = ?
    `).bind(setting_value, user.id, settingKey).run();

    return c.json({ success: true });
  } catch (error) {
    return c.json({ error: 'Failed to update setting' }, 500);
  }
});

// Page Editor Component for Admin Panel
const PageEditor = ({ pageKey, pageData, sections }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Quill.js CSS */}
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    
    <section class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">
              <i class="fas fa-edit text-primary-600 mr-3"></i>
              페이지 편집: {pageData?.title || pageKey}
            </h1>
            <p class="text-gray-600 mt-2">페이지 콘텐츠와 섹션을 쉽게 편집할 수 있습니다.</p>
          </div>
          <div class="flex space-x-3">
            <a 
              href="/admin" 
              class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors"
            >
              <i class="fas fa-arrow-left mr-2"></i>관리자 패널
            </a>
            <button 
              onclick="toggleEditMode()" 
              id="edit-mode-btn"
              class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
            >
              <i class="fas fa-code mr-2"></i>HTML 모드
            </button>
            <button 
              onclick="savePageContent()" 
              class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors"
            >
              <i class="fas fa-save mr-2"></i>저장
            </button>
          </div>
        </div>
      </div>
    </section>

    <section class="py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          {/* Main Content Editor */}
          <div class="lg:col-span-2 space-y-6">
            
            {/* Page Basic Info */}
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-info-circle text-blue-600 mr-2"></i>기본 정보
              </h2>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">페이지 제목</label>
                  <input 
                    type="text" 
                    id="page-title"
                    value={pageData?.title || ''}
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                    placeholder="페이지 제목을 입력하세요"
                  />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">페이지 설명</label>
                  <textarea 
                    id="page-description"
                    rows="3"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500"
                    placeholder="페이지 설명을 입력하세요"
                  >{pageData?.description || ''}</textarea>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">
                    메인 콘텐츠
                    <span class="text-xs text-gray-500 ml-2">(텍스트 에디터를 사용하세요)</span>
                  </label>
                  
                  {/* WYSIWYG Editor */}
                  <div id="editor-container" class="border border-gray-300 rounded-lg">
                    <div id="quill-editor" style="min-height: 300px;"></div>
                  </div>
                  
                  {/* HTML Source Editor (Hidden by default) */}
                  <div id="html-editor" class="hidden">
                    <textarea 
                      id="page-content-html"
                      rows="12"
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm mt-2"
                      placeholder="HTML 콘텐츠"
                    >{pageData?.content || ''}</textarea>
                  </div>
                  
                  {/* Markdown Editor (Hidden by default) */}
                  <div id="markdown-editor" class="hidden">
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-3">
                      <h4 class="text-sm font-medium text-blue-900 mb-2">마크다운 사용법:</h4>
                      <div class="text-xs text-blue-700 space-y-1">
                        <div><code># 제목</code> → 큰 제목</div>
                        <div><code>## 소제목</code> → 중간 제목</div>
                        <div><code>**굵게**</code> → <strong>굵게</strong></div>
                        <div><code>*기울임*</code> → <em>기울임</em></div>
                        <div><code>[링크](URL)</code> → 링크</div>
                        <div><code>![이미지](URL)</code> → 이미지</div>
                      </div>
                    </div>
                    <textarea 
                      id="page-content-markdown"
                      rows="12"
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm"
                      placeholder="마크다운으로 작성하세요..."
                    ></textarea>
                    <div class="flex justify-end mt-2">
                      <button 
                        onclick="convertMarkdownToHtml()" 
                        class="text-sm bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700 transition-colors"
                      >
                        HTML로 변환
                      </button>
                    </div>
                  </div>
                  
                  <div class="flex items-center justify-between mt-2">
                    <div class="flex space-x-4 text-xs text-gray-500">
                      <span><i class="fas fa-bold mr-1"></i>굵게: Ctrl+B</span>
                      <span><i class="fas fa-italic mr-1"></i>기울임: Ctrl+I</span>
                      <span><i class="fas fa-underline mr-1"></i>밑줄: Ctrl+U</span>
                    </div>
                    <div class="flex space-x-2">
                      <button 
                        onclick="insertImage()" 
                        class="text-blue-600 hover:text-blue-800 text-sm"
                        type="button"
                      >
                        <i class="fas fa-image mr-1"></i>이미지 삽입
                      </button>
                      <button 
                        onclick="insertLink()" 
                        class="text-blue-600 hover:text-blue-800 text-sm"
                        type="button"
                      >
                        <i class="fas fa-link mr-1"></i>링크 삽입
                      </button>
                      <button 
                        onclick="toggleMarkdownMode()" 
                        class="text-green-600 hover:text-green-800 text-sm"
                        type="button"
                        id="markdown-btn"
                      >
                        <i class="fab fa-markdown mr-1"></i>마크다운
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Sections Editor */}
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">
                <i class="fas fa-puzzle-piece text-green-600 mr-2"></i>페이지 섹션
              </h2>
              <div id="sections-container" class="space-y-4">
                {sections && sections.length > 0 ? sections.map((section: any) => (
                  <div class="border border-gray-200 rounded-lg p-4">
                    <div class="flex items-center justify-between mb-3">
                      <h3 class="font-medium text-gray-900">{section.section_name}</h3>
                      <div class="flex items-center space-x-2">
                        <label class="text-sm text-gray-600">
                          <input 
                            type="checkbox" 
                            checked={section.is_visible}
                            class="mr-1"
                          /> 표시
                        </label>
                        <input 
                          type="number" 
                          value={section.sort_order}
                          class="w-16 text-sm border border-gray-300 rounded px-2 py-1"
                          placeholder="순서"
                        />
                      </div>
                    </div>
                    <textarea 
                      rows="4"
                      class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500 text-sm"
                      placeholder="섹션 콘텐츠"
                    >{section.content}</textarea>
                  </div>
                )) : (
                  <div class="text-center py-8 text-gray-500">
                    <i class="fas fa-inbox text-4xl mb-4"></i>
                    <p>섹션이 없습니다.</p>
                  </div>
                )}
              </div>
            </div>
          </div>

          {/* Sidebar */}
          <div class="space-y-6">
            
            {/* SEO Settings */}
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-search text-purple-600 mr-2"></i>SEO 설정
              </h3>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">메타 제목</label>
                  <input 
                    type="text" 
                    id="meta-title"
                    value={pageData?.meta_title || ''}
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500 text-sm"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">메타 설명</label>
                  <textarea 
                    id="meta-description"
                    rows="3"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-primary-500 focus:border-primary-500 text-sm"
                  >{pageData?.meta_description || ''}</textarea>
                </div>
              </div>
            </div>

            {/* Page Status */}
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-toggle-on text-green-600 mr-2"></i>페이지 상태
              </h3>
              <label class="flex items-center">
                <input 
                  type="checkbox" 
                  id="is-published"
                  checked={pageData?.is_published}
                  class="mr-3"
                />
                <span class="text-sm text-gray-700">페이지 공개</span>
              </label>
              <p class="text-xs text-gray-500 mt-2">체크 해제시 페이지가 비공개됩니다.</p>
            </div>

            {/* Quick Actions */}
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-4">
                <i class="fas fa-bolt text-yellow-600 mr-2"></i>빠른 작업
              </h3>
              <div class="space-y-3">
                <button 
                  onclick="previewPage()" 
                  class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors text-sm"
                >
                  <i class="fas fa-eye mr-2"></i>미리보기
                </button>
                <button 
                  onclick="resetToDefault()" 
                  class="w-full bg-gray-500 text-white py-2 px-4 rounded-lg hover:bg-gray-600 transition-colors text-sm"
                >
                  <i class="fas fa-undo mr-2"></i>기본값으로 복원
                </button>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    {/* Quill.js JavaScript */}
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    
    {/* JavaScript for Page Editor */}
    <script>
      {`
        let quillEditor;
        let isHtmlMode = false;
        let isMarkdownMode = false;

        // Initialize Quill editor when page loads
        document.addEventListener('DOMContentLoaded', function() {
          initializeEditor();
        });

        function initializeEditor() {
          // Quill editor configuration
          quillEditor = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: '여기에 내용을 작성하세요...',
            modules: {
              toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'color': [] }, { 'background': [] }],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                [{ 'indent': '-1'}, { 'indent': '+1' }],
                [{ 'align': [] }],
                ['link', 'image', 'video'],
                ['clean']
              ]
            }
          });

          // Set initial content from pageData
          const initialContent = ${JSON.stringify(pageData?.content || '')};
          if (initialContent) {
            quillEditor.root.innerHTML = initialContent;
          }

          // Auto-save on content change
          let saveTimeout;
          quillEditor.on('text-change', function() {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => {
              console.log('Content changed - auto-saving in 3 seconds...');
            }, 3000);
          });
        }

        function toggleEditMode() {
          const btn = document.getElementById('edit-mode-btn');
          const quillContainer = document.getElementById('editor-container');
          const htmlEditor = document.getElementById('html-editor');
          const markdownEditor = document.getElementById('markdown-editor');
          
          if (isHtmlMode) {
            // Switch to WYSIWYG mode
            quillContainer.classList.remove('hidden');
            htmlEditor.classList.add('hidden');
            markdownEditor.classList.add('hidden');
            btn.innerHTML = '<i class="fas fa-code mr-2"></i>HTML 모드';
            
            // Update Quill with HTML content
            const htmlContent = document.getElementById('page-content-html').value;
            quillEditor.root.innerHTML = htmlContent;
            isHtmlMode = false;
            isMarkdownMode = false;
          } else {
            // Switch to HTML mode
            quillContainer.classList.add('hidden');
            htmlEditor.classList.remove('hidden');
            markdownEditor.classList.add('hidden');
            btn.innerHTML = '<i class="fas fa-eye mr-2"></i>에디터 모드';
            
            // Update HTML textarea with Quill content
            document.getElementById('page-content-html').value = quillEditor.root.innerHTML;
            isHtmlMode = true;
            isMarkdownMode = false;
          }
        }

        function toggleMarkdownMode() {
          const quillContainer = document.getElementById('editor-container');
          const htmlEditor = document.getElementById('html-editor');
          const markdownEditor = document.getElementById('markdown-editor');
          const editBtn = document.getElementById('edit-mode-btn');
          const markdownBtn = document.getElementById('markdown-btn');
          
          if (isMarkdownMode) {
            // Switch back to WYSIWYG mode
            quillContainer.classList.remove('hidden');
            htmlEditor.classList.add('hidden');
            markdownEditor.classList.add('hidden');
            markdownBtn.innerHTML = '<i class="fab fa-markdown mr-1"></i>마크다운';
            isMarkdownMode = false;
            isHtmlMode = false;
            editBtn.innerHTML = '<i class="fas fa-code mr-2"></i>HTML 모드';
          } else {
            // Switch to Markdown mode
            quillContainer.classList.add('hidden');
            htmlEditor.classList.add('hidden');
            markdownEditor.classList.remove('hidden');
            markdownBtn.innerHTML = '<i class="fas fa-eye mr-1"></i>에디터';
            
            // Convert current content to markdown (basic conversion)
            const currentHtml = quillEditor.root.innerHTML;
            const markdown = htmlToMarkdown(currentHtml);
            document.getElementById('page-content-markdown').value = markdown;
            
            isMarkdownMode = true;
            isHtmlMode = false;
            editBtn.innerHTML = '<i class="fas fa-code mr-2"></i>HTML 모드';
          }
        }

        function convertMarkdownToHtml() {
          const markdownText = document.getElementById('page-content-markdown').value;
          const html = markdownToHtml(markdownText);
          quillEditor.root.innerHTML = html;
          
          // Switch back to editor mode
          toggleMarkdownMode();
        }

        function markdownToHtml(markdown) {
          let html = markdown;
          
          // Headers
          html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
          html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
          html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
          
          // Bold
          html = html.replace(/\\*\\*(.*?)\\*\\*/gim, '<strong>$1</strong>');
          
          // Italic  
          html = html.replace(/\\*(.*?)\\*/gim, '<em>$1</em>');
          
          // Links
          html = html.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/gim, '<a href="$2">$1</a>');
          
          // Images
          html = html.replace(/!\\[([^\\]]*)\\]\\(([^)]+)\\)/gim, '<img src="$2" alt="$1" style="max-width: 100%; height: auto;">');
          
          // Line breaks
          html = html.replace(/\\n/gim, '<br>');
          
          // Lists (simple)
          html = html.replace(/^\\* (.*$)/gim, '<li>$1</li>');
          
          // Paragraphs
          const lines = html.split('<br>');
          const paragraphs = lines.map(function(line) {
            const trimmed = line.trim();
            if (trimmed && !trimmed.startsWith('<h') && !trimmed.startsWith('<ul') && !trimmed.startsWith('<li')) {
              return '<p>' + trimmed + '</p>';
            }
            return trimmed;
          });
          
          return paragraphs.join('\\n');
        }

        function htmlToMarkdown(html) {
          let markdown = html;
          
          // Remove HTML tags and convert to markdown
          markdown = markdown.replace(/<h1>(.*?)<\\/h1>/gim, '# $1\\n\\n');
          markdown = markdown.replace(/<h2>(.*?)<\\/h2>/gim, '## $1\\n\\n');
          markdown = markdown.replace(/<h3>(.*?)<\\/h3>/gim, '### $1\\n\\n');
          markdown = markdown.replace(/<strong>(.*?)<\\/strong>/gim, '**$1**');
          markdown = markdown.replace(/<em>(.*?)<\\/em>/gim, '*$1*');
          markdown = markdown.replace(/<a href="([^"]+)"[^>]*>(.*?)<\\/a>/gim, '[$2]($1)');
          markdown = markdown.replace(/<img[^>]+src="([^"]+)"[^>]*alt="([^"]*)"[^>]*>/gim, '![$2]($1)');
          markdown = markdown.replace(/<p>(.*?)<\\/p>/gim, '$1\\n\\n');
          markdown = markdown.replace(/<br\\s*\\/?>/gim, '\\n');
          markdown = markdown.replace(/<li>(.*?)<\\/li>/gim, '* $1\\n');
          markdown = markdown.replace(/<\\/?(ul|ol)>/gim, '');
          
          // Clean up extra newlines
          markdown = markdown.replace(/\\n{3,}/g, '\\n\\n');
          
          return markdown.trim();
        }

        function savePageContent() {
          const pageKey = ${JSON.stringify(pageKey)};
          
          // Get content from appropriate editor
          let content;
          if (isMarkdownMode) {
            // Convert markdown to HTML before saving
            const markdownText = document.getElementById('page-content-markdown').value;
            content = markdownToHtml(markdownText);
          } else if (isHtmlMode) {
            content = document.getElementById('page-content-html').value;
          } else {
            content = quillEditor.root.innerHTML;
          }
          
          const data = {
            title: document.getElementById('page-title').value,
            description: document.getElementById('page-description').value,
            content: content,
            meta_title: document.getElementById('meta-title').value,
            meta_description: document.getElementById('meta-description').value,
            is_published: document.getElementById('is-published').checked
          };

          fetch('/api/admin/pages/' + pageKey, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              showNotification('페이지가 성공적으로 저장되었습니다!', 'success');
            } else {
              showNotification('저장 중 오류가 발생했습니다: ' + data.error, 'error');
            }
          })
          .catch(error => {
            showNotification('저장 중 오류가 발생했습니다: ' + error, 'error');
          });
        }

        function insertImage() {
          // Create file input element
          const input = document.createElement('input');
          input.type = 'file';
          input.accept = 'image/*';
          
          input.onchange = function(e) {
            const file = e.target.files[0];
            if (file) {
              // Show loading indicator
              showNotification('이미지를 업로드하는 중...', 'info');
              
              // Upload file
              const formData = new FormData();
              formData.append('file', file);
              formData.append('purpose', 'page_image');
              
              fetch('/api/upload', {
                method: 'POST',
                body: formData
              })
              .then(response => response.json())
              .then(data => {
                if (data.success) {
                  // Insert image into editor
                  const range = quillEditor.getSelection(true);
                  quillEditor.insertEmbed(range.index, 'image', data.file.file_path);
                  showNotification('이미지가 성공적으로 업로드되었습니다!', 'success');
                } else {
                  // Fallback to URL input
                  const url = prompt('이미지 업로드에 실패했습니다. 이미지 URL을 직접 입력하세요:');
                  if (url) {
                    const range = quillEditor.getSelection(true);
                    quillEditor.insertEmbed(range.index, 'image', url);
                  }
                }
              })
              .catch(error => {
                console.error('Upload error:', error);
                // Fallback to URL input
                const url = prompt('이미지 업로드에 실패했습니다. 이미지 URL을 직접 입력하세요:');
                if (url) {
                  const range = quillEditor.getSelection(true);
                  quillEditor.insertEmbed(range.index, 'image', url);
                }
              });
            }
          };
          
          // Trigger file selector
          input.click();
        }

        function insertLink() {
          const url = prompt('링크 URL을 입력하세요:');
          if (url) {
            const text = prompt('링크 텍스트를 입력하세요:') || url;
            const range = quillEditor.getSelection(true);
            quillEditor.insertText(range.index, text, 'link', url);
          }
        }

        function previewPage() {
          window.open('/' + ${pageKey === 'home' ? "''" : `'${pageKey}'`}, '_blank');
        }

        function resetToDefault() {
          if (confirm('정말로 기본값으로 복원하시겠습니까? 현재 내용이 모두 사라집니다.')) {
            location.reload();
          }
        }

        function showNotification(message, type) {
          // Create notification element
          const notification = document.createElement('div');
          const colors = {
            success: 'bg-green-500 text-white',
            error: 'bg-red-500 text-white',
            info: 'bg-blue-500 text-white',
            warning: 'bg-yellow-500 text-white'
          };
          
          const icons = {
            success: 'check-circle',
            error: 'exclamation-circle',
            info: 'info-circle',
            warning: 'exclamation-triangle'
          };
          
          notification.className = 'fixed top-4 right-4 z-50 p-4 rounded-lg shadow-lg ' + (colors[type] || colors.info);
          notification.innerHTML = 
            '<div class="flex items-center">' +
              '<i class="fas fa-' + (icons[type] || icons.info) + ' mr-2"></i>' +
              message +
            '</div>';
          
          document.body.appendChild(notification);
          
          // Auto remove after 3 seconds (longer for info messages)
          const duration = type === 'info' ? 5000 : 3000;
          setTimeout(() => {
            notification.remove();
          }, duration);
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
          if (e.ctrlKey || e.metaKey) {
            switch(e.key) {
              case 's':
                e.preventDefault();
                savePageContent();
                break;
              case 'p':
                e.preventDefault();
                previewPage();
                break;
            }
          }
        });
      `}
    </script>
  </div>
);

// Admin Notifications Management
app.get('/admin/notifications', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get all notifications with user info
    const notifications = await env.DB.prepare(`
      SELECT 
        n.*,
        u.username,
        u.full_name,
        CASE 
          WHEN n.type = 'post' THEN (SELECT title FROM posts WHERE id = n.related_id)
          WHEN n.type = 'event' THEN (SELECT title FROM events WHERE id = n.related_id)
          ELSE NULL
        END as related_title
      FROM notifications n
      JOIN users u ON n.user_id = u.id
      ORDER BY n.created_at DESC
      LIMIT 50
    `).all();

    // Get notification stats
    const stats = await Promise.all([
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications WHERE is_read = 0').first(),
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications').first(),
      env.DB.prepare('SELECT COUNT(DISTINCT user_id) as count FROM notifications').first()
    ]);

    const [unreadCount, totalCount, userCount] = stats;

    return c.render(
      <Layout user={user}>
        <NotificationsPanel 
          notifications={notifications.results}
          stats={{
            unread: unreadCount.count,
            total: totalCount.count,
            users: userCount.count
          }}
        />
      </Layout>,
      { title: '알림 관리' }
    );

  } catch (error) {
    console.error('Notifications panel error:', error);
    return c.redirect('/admin');
  }
});

// Mark all notifications as read (Admin)
app.post('/api/admin/notifications/mark-all-read', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    
    await env.DB.prepare(`
      UPDATE notifications SET is_read = 1 WHERE is_read = 0
    `).run();

    return c.json({ success: true });
  } catch (error) {
    return c.json({ error: 'Failed to mark notifications as read' }, 500);
  }
});

// Delete notification (Admin)
app.delete('/api/admin/notifications/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const notificationId = c.req.param('id');
    
    await env.DB.prepare(`
      DELETE FROM notifications WHERE id = ?
    `).bind(notificationId).run();

    return c.json({ success: true });
  } catch (error) {
    return c.json({ error: 'Failed to delete notification' }, 500);
  }
});

// Send system notification to all users (Admin)
app.post('/api/admin/notifications/broadcast', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '관리자 권한이 필요합니다.' }, 403);
  }

  try {
    const { env } = c;
    const { title, message, type } = await c.req.json();

    // Get all active users
    const users = await env.DB.prepare(`
      SELECT id FROM users WHERE is_active = 1
    `).all();

    // Send notification to each user
    for (const targetUser of users.results) {
      await env.DB.prepare(`
        INSERT INTO notifications (user_id, title, message, type)
        VALUES (?, ?, ?, ?)
      `).bind(targetUser.id, title, message, type || 'system').run();
    }

    return c.json({ 
      success: true, 
      sent_to: users.results.length 
    });
  } catch (error) {
    return c.json({ error: 'Failed to send broadcast notification' }, 500);
  }
});

// Notifications Panel Component
const NotificationsPanel = ({ notifications, stats }: any) => (
  <div class="bg-gray-50 min-h-screen">
    {/* Header */}
    <section class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-4xl font-bold text-gray-900 mb-4">
              <i class="fas fa-bell text-red-600 mr-3"></i>
              알림 관리
            </h1>
            <p class="text-gray-600 text-lg">시스템 알림과 사용자 알림을 관리합니다</p>
          </div>
          <div class="flex space-x-3">
            <a 
              href="/admin" 
              class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors"
            >
              <i class="fas fa-arrow-left mr-2"></i>관리자 패널
            </a>
            <button 
              onclick="showBroadcastModal()" 
              class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
            >
              <i class="fas fa-bullhorn mr-2"></i>전체 알림 보내기
            </button>
          </div>
        </div>
      </div>
    </section>

    {/* Stats */}
    <section class="py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <i class="fas fa-bell text-red-600 text-2xl"></i>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-500">읽지 않은 알림</div>
                <div class="text-2xl font-bold text-gray-900">{stats.unread}</div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <i class="fas fa-list text-blue-600 text-2xl"></i>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-500">전체 알림</div>
                <div class="text-2xl font-bold text-gray-900">{stats.total}</div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <i class="fas fa-users text-green-600 text-2xl"></i>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-500">알림 받는 사용자</div>
                <div class="text-2xl font-bold text-gray-900">{stats.users}</div>
              </div>
            </div>
          </div>
        </div>

        {/* Actions */}
        <div class="bg-white rounded-lg shadow p-6 mb-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">
            <i class="fas fa-cogs text-gray-600 mr-2"></i>알림 관리 작업
          </h2>
          <div class="flex flex-wrap gap-4">
            <button 
              onclick="markAllAsRead()" 
              class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors"
            >
              <i class="fas fa-check-double mr-2"></i>모든 알림 읽음 처리
            </button>
            <button 
              onclick="deleteReadNotifications()" 
              class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700 transition-colors"
            >
              <i class="fas fa-trash mr-2"></i>읽은 알림 삭제
            </button>
            <button 
              onclick="exportNotifications()" 
              class="bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors"
            >
              <i class="fas fa-download mr-2"></i>알림 내역 내보내기
            </button>
          </div>
        </div>

        {/* Notifications List */}
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <div class="bg-gray-50 px-6 py-4 border-b">
            <h2 class="text-lg font-semibold text-gray-900">
              알림 목록 ({notifications.length}개)
            </h2>
          </div>
          
          {notifications && notifications.length > 0 ? (
            <div class="divide-y divide-gray-200">
              {notifications.map((notification: any) => (
                <div class={`p-6 ${!notification.is_read ? 'bg-blue-50 border-l-4 border-blue-500' : ''}`}>
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center space-x-3 mb-2">
                        <div class={`p-2 rounded-full ${
                          notification.type === 'system' ? 'bg-gray-100 text-gray-600' :
                          notification.type === 'post' ? 'bg-blue-100 text-blue-600' :
                          notification.type === 'event' ? 'bg-green-100 text-green-600' :
                          'bg-yellow-100 text-yellow-600'
                        }`}>
                          <i class={`fas ${
                            notification.type === 'system' ? 'fa-cog' :
                            notification.type === 'post' ? 'fa-file-alt' :
                            notification.type === 'event' ? 'fa-calendar' :
                            'fa-bell'
                          } text-sm`}></i>
                        </div>
                        <div>
                          <h3 class="font-semibold text-gray-900">{notification.title}</h3>
                          <p class="text-sm text-gray-600">
                            {notification.full_name} ({notification.username})
                          </p>
                        </div>
                      </div>
                      
                      <p class="text-gray-700 mb-3">{notification.message}</p>
                      
                      {notification.related_title && (
                        <div class="mb-3">
                          <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                            <i class="fas fa-link mr-1"></i>
                            {notification.related_title}
                          </span>
                        </div>
                      )}
                      
                      <div class="flex items-center text-sm text-gray-500 space-x-4">
                        <span class="flex items-center">
                          <i class="fas fa-clock mr-1"></i>
                          {new Date(notification.created_at).toLocaleDateString('ko-KR', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                          })}
                        </span>
                        <span class={`flex items-center ${
                          notification.is_read ? 'text-green-600' : 'text-red-600'
                        }`}>
                          <i class={`fas ${notification.is_read ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-1`}></i>
                          {notification.is_read ? '읽음' : '읽지 않음'}
                        </span>
                      </div>
                    </div>
                    
                    <div class="flex items-center space-x-2 ml-4">
                      {!notification.is_read && (
                        <button 
                          onclick={`markAsRead(${notification.id})`}
                          class="text-green-600 hover:text-green-800 transition-colors"
                          title="읽음 처리"
                        >
                          <i class="fas fa-check"></i>
                        </button>
                      )}
                      <button 
                        onclick={`deleteNotification(${notification.id})`}
                        class="text-red-600 hover:text-red-800 transition-colors"
                        title="삭제"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="p-12 text-center">
              <i class="fas fa-bell-slash text-gray-400 text-5xl mb-4"></i>
              <h3 class="text-xl font-medium text-gray-900 mb-2">알림이 없습니다</h3>
              <p class="text-gray-500">아직 시스템 알림이 없습니다.</p>
            </div>
          )}
        </div>
      </div>
    </section>

    {/* Broadcast Modal */}
    <div id="broadcastModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3">
          <h3 class="text-lg font-medium text-gray-900 mb-4">전체 알림 보내기</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">제목</label>
              <input 
                type="text" 
                id="broadcast-title"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="알림 제목을 입력하세요"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">내용</label>
              <textarea 
                id="broadcast-message"
                rows="4"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-blue-500 focus:border-blue-500"
                placeholder="알림 내용을 입력하세요"
              ></textarea>
            </div>
          </div>
          <div class="flex justify-end space-x-3 mt-6">
            <button 
              onclick="closeBroadcastModal()" 
              class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400 transition-colors"
            >
              취소
            </button>
            <button 
              onclick="sendBroadcast()" 
              class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
            >
              전송
            </button>
          </div>
        </div>
      </div>
    </div>

    {/* JavaScript */}
    <script>
      {`
        function showBroadcastModal() {
          document.getElementById('broadcastModal').classList.remove('hidden');
        }

        function closeBroadcastModal() {
          document.getElementById('broadcastModal').classList.add('hidden');
          document.getElementById('broadcast-title').value = '';
          document.getElementById('broadcast-message').value = '';
        }

        function sendBroadcast() {
          const title = document.getElementById('broadcast-title').value;
          const message = document.getElementById('broadcast-message').value;

          if (!title || !message) {
            alert('제목과 내용을 모두 입력해주세요.');
            return;
          }

          fetch('/api/admin/notifications/broadcast', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ title, message, type: 'system' })
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              alert('전체 알림이 ' + data.sent_to + '명에게 전송되었습니다!');
              closeBroadcastModal();
              location.reload();
            } else {
              alert('알림 전송 중 오류가 발생했습니다: ' + data.error);
            }
          });
        }

        function markAllAsRead() {
          if (!confirm('모든 알림을 읽음 처리하시겠습니까?')) return;

          fetch('/api/admin/notifications/mark-all-read', {
            method: 'POST'
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              alert('모든 알림이 읽음 처리되었습니다!');
              location.reload();
            } else {
              alert('오류가 발생했습니다: ' + data.error);
            }
          });
        }

        function markAsRead(id) {
          fetch('/api/notifications/' + id + '/read', {
            method: 'POST'
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              location.reload();
            }
          });
        }

        function deleteNotification(id) {
          if (!confirm('이 알림을 삭제하시겠습니까?')) return;

          fetch('/api/admin/notifications/' + id, {
            method: 'DELETE'
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert('삭제 중 오류가 발생했습니다: ' + data.error);
            }
          });
        }

        function deleteReadNotifications() {
          if (!confirm('읽은 모든 알림을 삭제하시겠습니까?')) return;
          alert('이 기능은 곧 구현될 예정입니다.');
        }

        function exportNotifications() {
          alert('알림 내역 내보내기 기능은 곧 구현될 예정입니다.');
        }
      `}
    </script>
  </div>
);

// Admin page editor routes
app.get('/admin/pages/:pageKey/edit', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const pageKey = c.req.param('pageKey');

    const pageContent = await env.DB.prepare(`
      SELECT * FROM page_contents WHERE page_key = ?
    `).bind(pageKey).first();

    const sections = await env.DB.prepare(`
      SELECT * FROM page_sections WHERE page_key = ? ORDER BY sort_order ASC
    `).bind(pageKey).all();

    return c.render(
      <Layout user={user}>
        <PageEditor 
          pageKey={pageKey}
          pageData={pageContent}
          sections={sections.results}
        />
      </Layout>,
      { title: `페이지 편집: ${pageContent?.title || pageKey}` }
    );

  } catch (error) {
    console.error('Page editor error:', error);
    return c.redirect('/admin');
  }
});

// Admin Users Page
app.get('/admin/users', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const users = await env.DB.prepare(`
      SELECT id, username, email, full_name, role, is_active, created_at, last_login
      FROM users
      ORDER BY created_at DESC
    `).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="bg-white rounded-lg shadow-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
              <h1 class="text-2xl font-bold text-gray-900">사용자 관리</h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700">← 관리자 패널</a>
            </div>
            <div class="p-6">
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">사용자</th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">역할</th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">가입일</th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">마지막 로그인</th>
                      <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    {users.results.map((userData: any) => (
                      <tr>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <div>
                            <div class="text-sm font-medium text-gray-900">{userData.full_name}</div>
                            <div class="text-sm text-gray-500">{userData.email}</div>
                          </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          {user.id === userData.id ? (
                            // 자신의 계정은 역할 변경 불가
                            <span class="text-sm text-gray-500 font-medium">{
                              userData.role === 'admin' ? '관리자' : 
                              userData.role === 'moderator' ? '운영진' : '회원'
                            }</span>
                          ) : (
                            // 다른 사용자는 역할 변경 가능
                            <div class="flex items-center space-x-2">
                              <select 
                                id={`role-${userData.id}`}
                                class="text-sm border rounded px-2 py-1"
                                data-original-role={userData.role}
                                onchange={`markRoleChanged(${userData.id})`}
                              >
                                <option value="member" selected={userData.role === 'member'}>회원</option>
                                <option value="moderator" selected={userData.role === 'moderator'}>운영진</option>
                                <option value="admin" selected={userData.role === 'admin'}>관리자</option>
                              </select>
                              <button 
                                id={`save-role-${userData.id}`}
                                onclick={`saveUserRole(${userData.id})`}
                                class="hidden px-2 py-1 bg-green-600 text-white text-xs rounded hover:bg-green-700 transition-colors"
                                title="역할 변경 저장"
                              >
                                <i class="fas fa-check"></i>
                              </button>
                              <button 
                                id={`cancel-role-${userData.id}`}
                                onclick={`cancelRoleChange(${userData.id})`}
                                class="hidden px-2 py-1 bg-gray-500 text-white text-xs rounded hover:bg-gray-600 transition-colors"
                                title="취소"
                              >
                                <i class="fas fa-times"></i>
                              </button>
                            </div>
                          )}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${
                            userData.is_active ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'
                          }`}>
                            {userData.is_active ? '활성' : '비활성'}
                          </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {new Date(userData.created_at).toLocaleDateString('ko-KR')}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                          {userData.last_login ? new Date(userData.last_login).toLocaleDateString('ko-KR') : '-'}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                          <div class="flex space-x-2">
                            <button 
                              onclick={`changePassword(${userData.id}, '${userData.full_name}')`}
                              class="text-indigo-600 hover:text-indigo-900 px-2 py-1 rounded bg-indigo-50 hover:bg-indigo-100 transition-colors"
                              title="비밀번호 변경"
                            >
                              <i class="fas fa-key"></i>
                            </button>
                            {user.id !== userData.id && (
                              <button 
                                onclick={`deleteUser(${userData.id}, '${userData.full_name}')`}
                                class="text-red-600 hover:text-red-900 px-2 py-1 rounded bg-red-50 hover:bg-red-100 transition-colors"
                                title="계정 삭제"
                              >
                                <i class="fas fa-trash"></i>
                              </button>
                            )}
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
        <script>{`
          // 역할 변경 감지
          function markRoleChanged(userId) {
            const select = document.getElementById('role-' + userId);
            const originalRole = select.getAttribute('data-original-role');
            const currentRole = select.value;
            
            const saveBtn = document.getElementById('save-role-' + userId);
            const cancelBtn = document.getElementById('cancel-role-' + userId);
            
            if (originalRole !== currentRole) {
              saveBtn.classList.remove('hidden');
              cancelBtn.classList.remove('hidden');
            } else {
              saveBtn.classList.add('hidden');
              cancelBtn.classList.add('hidden');
            }
          }

          // 역할 변경 저장
          async function saveUserRole(userId) {
            const select = document.getElementById('role-' + userId);
            const newRole = select.value;
            
            try {
              const response = await fetch('/api/admin/users/' + userId + '/role', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ role: newRole })
              });
              
              if (response.ok) {
                alert('역할이 변경되었습니다.');
                // 원래 역할을 새 역할로 업데이트
                select.setAttribute('data-original-role', newRole);
                // 버튼 숨기기
                document.getElementById('save-role-' + userId).classList.add('hidden');
                document.getElementById('cancel-role-' + userId).classList.add('hidden');
              } else {
                const errorData = await response.json();
                alert('역할 변경에 실패했습니다: ' + (errorData.error || '알 수 없는 오류'));
              }
            } catch (error) {
              alert('오류가 발생했습니다: ' + error.message);
            }
          }

          // 역할 변경 취소
          function cancelRoleChange(userId) {
            const select = document.getElementById('role-' + userId);
            const originalRole = select.getAttribute('data-original-role');
            
            // 원래 역할로 되돌리기
            select.value = originalRole;
            
            // 버튼 숨기기
            document.getElementById('save-role-' + userId).classList.add('hidden');
            document.getElementById('cancel-role-' + userId).classList.add('hidden');
          }

          // 비밀번호 변경
          async function changePassword(userId, userName) {
            const newPassword = prompt(userName + '님의 새로운 비밀번호를 입력하세요 (최소 6자):');
            if (!newPassword) return;
            
            if (newPassword.length < 6) {
              alert('비밀번호는 최소 6자 이상이어야 합니다.');
              return;
            }

            const confirmPassword = prompt('비밀번호를 다시 입력하세요:');
            if (newPassword !== confirmPassword) {
              alert('비밀번호가 일치하지 않습니다.');
              return;
            }

            if (!confirm('정말로 ' + userName + '님의 비밀번호를 변경하시겠습니까?')) {
              return;
            }

            try {
              const response = await fetch('/api/admin/users/' + userId + '/password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password: newPassword })
              });
              
              if (response.ok) {
                const result = await response.json();
                alert('✅ ' + userName + '님의 비밀번호가 성공적으로 변경되었습니다.');
              } else {
                const errorData = await response.json();
                alert('❌ 비밀번호 변경에 실패했습니다: ' + (errorData.error || '알 수 없는 오류'));
              }
            } catch (error) {
              console.error('Password change error:', error);
              alert('❌ 네트워크 오류가 발생했습니다. 다시 시도해주세요.');
            }
          }

          // 계정 삭제
          async function deleteUser(userId, userName) {
            if (!confirm('⚠️ ' + userName + '님의 계정을 정말 삭제하시겠습니까?\\n\\n이 작업은 되돌릴 수 없으며, 해당 사용자의 모든 데이터가 삭제됩니다.')) {
              return;
            }

            const confirmText = prompt('삭제를 확인하려면 정확히 "삭제확인"을 입력하세요:');
            if (confirmText !== '삭제확인') {
              alert('삭제가 취소되었습니다.');
              return;
            }

            try {
              const response = await fetch('/api/admin/users/' + userId + '/delete', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                const result = await response.json();
                alert('✅ ' + userName + '님의 계정이 성공적으로 삭제되었습니다.');
                // 페이지 새로고침으로 목록 업데이트
                location.reload();
              } else {
                const errorData = await response.json();
                alert('❌ 계정 삭제에 실패했습니다: ' + (errorData.error || '알 수 없는 오류'));
              }
            } catch (error) {
              console.error('Delete user error:', error);
              alert('❌ 네트워크 오류가 발생했습니다. 다시 시도해주세요.');
            }
          }
        `}</script>
      </Layout>,
      { title: '사용자 관리' }
    );

  } catch (error) {
    console.error('Admin users error:', error);
    return c.redirect('/admin');
  }
});

// Admin Pending Users Page
app.get('/admin/users/pending', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const pendingUsers = await env.DB.prepare(`
      SELECT id, username, email, full_name, student_id, created_at, approval_status, rejection_reason
      FROM users
      WHERE approval_status = 'pending'
      ORDER BY created_at DESC
    `).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="bg-white rounded-lg shadow-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
              <h1 class="text-2xl font-bold text-gray-900">
                <i class="fas fa-user-clock text-amber-600 mr-3"></i>
                가입 승인 대기
              </h1>
              <div class="flex space-x-3">
                <a href="/admin/users" class="text-primary-600 hover:text-primary-700">
                  <i class="fas fa-users mr-2"></i>회원 목록
                </a>
                <a href="/admin" class="text-primary-600 hover:text-primary-700">← 관리자 패널</a>
              </div>
            </div>
            <div class="p-6">
              {pendingUsers.results.length === 0 ? (
                <div class="text-center py-12">
                  <i class="fas fa-check-circle text-green-500 text-4xl mb-4"></i>
                  <h3 class="text-lg font-semibold text-gray-900 mb-2">승인 대기 중인 회원이 없습니다</h3>
                  <p class="text-gray-600">모든 회원가입 신청이 처리되었습니다.</p>
                </div>
              ) : (
                <div>
                  <div class="mb-4 bg-amber-50 border border-amber-200 rounded-lg p-4">
                    <div class="flex items-center">
                      <i class="fas fa-info-circle text-amber-600 mr-3"></i>
                      <div>
                        <h4 class="font-semibold text-amber-800">승인 대기 중인 회원: {pendingUsers.results.length}명</h4>
                        <p class="text-amber-700 text-sm">각 회원의 정보를 검토한 후 승인 또는 거부를 선택해주세요.</p>
                      </div>
                    </div>
                  </div>
                  
                  <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                      <thead class="bg-gray-50">
                        <tr>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">신청자 정보</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">학번</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">신청일</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
                        </tr>
                      </thead>
                      <tbody class="bg-white divide-y divide-gray-200">
                        {pendingUsers.results.map((userData: any) => (
                          <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                              <div>
                                <div class="text-sm font-medium text-gray-900">{userData.full_name}</div>
                                <div class="text-sm text-gray-500">{userData.email}</div>
                                <div class="text-xs text-gray-400">아이디: {userData.username}</div>
                              </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                              {userData.student_id || '-'}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                              {new Date(userData.created_at).toLocaleDateString('ko-KR')}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800">
                                승인 대기
                              </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                              <div class="flex space-x-2">
                                <button 
                                  onclick={`approveUser(${userData.id}, '${userData.full_name}')`}
                                  class="bg-green-600 text-white px-3 py-1 rounded text-xs hover:bg-green-700 transition-colors"
                                  title="승인"
                                >
                                  <i class="fas fa-check mr-1"></i>승인
                                </button>
                                <button 
                                  onclick={`rejectUser(${userData.id}, '${userData.full_name}')`}
                                  class="bg-red-600 text-white px-3 py-1 rounded text-xs hover:bg-red-700 transition-colors"
                                  title="거부"
                                >
                                  <i class="fas fa-times mr-1"></i>거부
                                </button>
                                <button 
                                  onclick={`viewUserDetails(${userData.id})`}
                                  class="bg-gray-600 text-white px-3 py-1 rounded text-xs hover:bg-gray-700 transition-colors"
                                  title="상세 정보"
                                >
                                  <i class="fas fa-eye mr-1"></i>상세
                                </button>
                              </div>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
        <script>{`
          // 회원 승인
          async function approveUser(userId, userName) {
            if (!confirm('✅ ' + userName + '님의 회원가입을 승인하시겠습니까?')) {
              return;
            }

            try {
              const response = await fetch('/api/admin/users/' + userId + '/approve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                alert('✅ ' + userName + '님의 회원가입이 승인되었습니다.');
                location.reload();
              } else {
                const errorData = await response.json();
                alert('❌ 승인에 실패했습니다: ' + (errorData.error || '알 수 없는 오류'));
              }
            } catch (error) {
              console.error('Approve user error:', error);
              alert('❌ 네트워크 오류가 발생했습니다. 다시 시도해주세요.');
            }
          }

          // 회원 거부
          async function rejectUser(userId, userName) {
            const reason = prompt('🚫 ' + userName + '님의 회원가입을 거부하는 이유를 입력해주세요:');
            if (!reason) return;

            if (!confirm('정말로 ' + userName + '님의 회원가입을 거부하시겠습니까?')) {
              return;
            }

            try {
              const response = await fetch('/api/admin/users/' + userId + '/reject', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: reason })
              });
              
              if (response.ok) {
                alert('🚫 ' + userName + '님의 회원가입이 거부되었습니다.');
                location.reload();
              } else {
                const errorData = await response.json();
                alert('❌ 거부 처리에 실패했습니다: ' + (errorData.error || '알 수 없는 오류'));
              }
            } catch (error) {
              console.error('Reject user error:', error);
              alert('❌ 네트워크 오류가 발생했습니다. 다시 시도해주세요.');
            }
          }

          // 사용자 상세 정보 보기
          async function viewUserDetails(userId) {
            try {
              const response = await fetch('/api/admin/users/' + userId + '/details');
              if (response.ok) {
                const data = await response.json();
                const user = data.user;
                
                const details = 
                  '📋 회원 정보\\n\\n' +
                  '• 이름: ' + user.full_name + '\\n' +
                  '• 아이디: ' + user.username + '\\n' +
                  '• 이메일: ' + user.email + '\\n' +
                  '• 학번: ' + (user.student_id || '없음') + '\\n' +
                  '• 신청일: ' + new Date(user.created_at).toLocaleString('ko-KR') + '\\n' +
                  '• 상태: ' + (user.approval_status === 'pending' ? '승인 대기' : user.approval_status);
                
                alert(details);
              }
            } catch (error) {
              alert('❌ 사용자 정보를 불러올 수 없습니다.');
            }
          }
        `}</script>
      </Layout>,
      { title: '가입 승인 대기' }
    );

  } catch (error) {
    console.error('Admin pending users error:', error);
    return c.redirect('/admin');
  }
});

// Admin Analytics Page
app.get('/admin/analytics', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // Get basic statistics
    const today = new Date().toISOString().split('T')[0];
    const lastWeek = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    const lastMonth = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

    const stats = await Promise.all([
      // 총 회원수 (활성)
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = 1').first(),
      // 이번 달 신규 가입자
      env.DB.prepare(`SELECT COUNT(*) as count FROM users WHERE created_at >= datetime('${lastMonth}')`).first(),
      // 이번 주 신규 가입자  
      env.DB.prepare(`SELECT COUNT(*) as count FROM users WHERE created_at >= datetime('${lastWeek}')`).first(),
      // 오늘 신규 가입자
      env.DB.prepare(`SELECT COUNT(*) as count FROM users WHERE created_at >= datetime('${today}')`).first(),
      // 총 게시글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM posts').first(),
      // 이번 달 게시글
      env.DB.prepare(`SELECT COUNT(*) as count FROM posts WHERE created_at >= datetime('${lastMonth}')`).first(),
      // 총 댓글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM comments').first(),
      // 총 이벤트 수
      env.DB.prepare('SELECT COUNT(*) as count FROM events').first(),
    ]);

    const [totalUsers, monthlyUsers, weeklyUsers, dailyUsers, totalPosts, monthlyPosts, totalComments, totalEvents] = stats;

    // 최근 활동 (최근 가입한 회원들)
    const recentUsers = await env.DB.prepare(`
      SELECT username, full_name, created_at 
      FROM users 
      ORDER BY created_at DESC 
      LIMIT 10
    `).all();

    // 인기 게시글 (좋아요가 많은 게시글)
    const popularPosts = await env.DB.prepare(`
      SELECT p.title, p.created_at, u.full_name as author,
             (SELECT COUNT(*) FROM likes WHERE post_id = p.id) as like_count
      FROM posts p
      LEFT JOIN users u ON p.author_id = u.id
      ORDER BY like_count DESC, p.created_at DESC
      LIMIT 10
    `).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="bg-white rounded-lg shadow-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
              <h1 class="text-2xl font-bold text-gray-900">
                <i class="fas fa-chart-line text-blue-600 mr-3"></i>
                방문 통계 & 분석
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700">← 관리자 패널</a>
            </div>
            
            <div class="p-6">
              {/* 주요 통계 */}
              <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 rounded-lg p-6 text-white">
                  <div class="flex items-center">
                    <i class="fas fa-users text-2xl mr-4"></i>
                    <div>
                      <h3 class="text-lg font-semibold">총 회원</h3>
                      <p class="text-3xl font-bold">{totalUsers.count}</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-r from-green-500 to-green-600 rounded-lg p-6 text-white">
                  <div class="flex items-center">
                    <i class="fas fa-user-plus text-2xl mr-4"></i>
                    <div>
                      <h3 class="text-lg font-semibold">이번 달 가입</h3>
                      <p class="text-3xl font-bold">{monthlyUsers.count}</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-r from-purple-500 to-purple-600 rounded-lg p-6 text-white">
                  <div class="flex items-center">
                    <i class="fas fa-file-alt text-2xl mr-4"></i>
                    <div>
                      <h3 class="text-lg font-semibold">총 게시글</h3>
                      <p class="text-3xl font-bold">{totalPosts.count}</p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-r from-orange-500 to-orange-600 rounded-lg p-6 text-white">
                  <div class="flex items-center">
                    <i class="fas fa-comments text-2xl mr-4"></i>
                    <div>
                      <h3 class="text-lg font-semibold">총 댓글</h3>
                      <p class="text-3xl font-bold">{totalComments.count}</p>
                    </div>
                  </div>
                </div>
              </div>

              {/* 기간별 통계 */}
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <div class="bg-gray-50 rounded-lg p-6">
                  <h3 class="text-lg font-semibold text-gray-900 mb-4">
                    <i class="fas fa-calendar text-primary-600 mr-2"></i>
                    기간별 가입자 통계
                  </h3>
                  <div class="space-y-4">
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">오늘</span>
                      <span class="font-semibold text-green-600">+{dailyUsers.count}명</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">이번 주</span>
                      <span class="font-semibold text-blue-600">+{weeklyUsers.count}명</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">이번 달</span>
                      <span class="font-semibold text-purple-600">+{monthlyUsers.count}명</span>
                    </div>
                  </div>
                </div>

                <div class="bg-gray-50 rounded-lg p-6">
                  <h3 class="text-lg font-semibold text-gray-900 mb-4">
                    <i class="fas fa-chart-bar text-primary-600 mr-2"></i>
                    콘텐츠 통계
                  </h3>
                  <div class="space-y-4">
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">이번 달 게시글</span>
                      <span class="font-semibold text-blue-600">{monthlyPosts.count}개</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">총 이벤트</span>
                      <span class="font-semibold text-green-600">{totalEvents.count}개</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-600">활동 비율</span>
                      <span class="font-semibold text-orange-600">
                        {totalUsers.count > 0 ? Math.round((monthlyPosts.count / totalUsers.count) * 100) : 0}%
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              {/* 최근 활동 및 인기 콘텐츠 */}
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white border rounded-lg p-6">
                  <h3 class="text-lg font-semibold text-gray-900 mb-4">
                    <i class="fas fa-user-clock text-primary-600 mr-2"></i>
                    최근 가입 회원
                  </h3>
                  <div class="space-y-3">
                    {recentUsers.results.length === 0 ? (
                      <p class="text-gray-500 text-center py-4">최근 가입한 회원이 없습니다</p>
                    ) : (
                      recentUsers.results.map((user: any) => (
                        <div class="flex justify-between items-center py-2 border-b border-gray-100">
                          <div>
                            <span class="font-medium text-gray-900">{user.full_name}</span>
                            <span class="text-sm text-gray-500 ml-2">({user.username})</span>
                          </div>
                          <span class="text-xs text-gray-500">
                            {new Date(user.created_at).toLocaleDateString('ko-KR')}
                          </span>
                        </div>
                      ))
                    )}
                  </div>
                </div>

                <div class="bg-white border rounded-lg p-6">
                  <h3 class="text-lg font-semibold text-gray-900 mb-4">
                    <i class="fas fa-fire text-primary-600 mr-2"></i>
                    인기 게시글
                  </h3>
                  <div class="space-y-3">
                    {popularPosts.results.length === 0 ? (
                      <p class="text-gray-500 text-center py-4">게시글이 없습니다</p>
                    ) : (
                      popularPosts.results.map((post: any) => (
                        <div class="py-2 border-b border-gray-100">
                          <div class="flex justify-between items-start">
                            <div class="flex-1">
                              <h4 class="font-medium text-gray-900 text-sm line-clamp-1">{post.title}</h4>
                              <p class="text-xs text-gray-500">
                                {post.author} • {new Date(post.created_at).toLocaleDateString('ko-KR')}
                              </p>
                            </div>
                            <span class="text-xs text-red-500 ml-2">
                              <i class="fas fa-heart mr-1"></i>{post.like_count}
                            </span>
                          </div>
                        </div>
                      ))
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </Layout>,
      { title: '방문 통계' }
    );

  } catch (error) {
    console.error('Admin analytics error:', error);
    return c.redirect('/admin');
  }
});

// Admin Pages Management
app.get('/admin/pages', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    const pages = await env.DB.prepare(`
      SELECT * FROM page_contents ORDER BY updated_at DESC
    `).all();

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="bg-white rounded-lg shadow-lg">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
              <h1 class="text-2xl font-bold text-gray-900">페이지 관리</h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700">← 관리자 패널</a>
            </div>
            <div class="p-6">
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <a href="/admin/pages/home/edit" class="block p-4 border border-gray-200 rounded-lg hover:border-primary-300 hover:shadow-md transition-all">
                  <h3 class="font-semibold text-gray-900 mb-2">홈 페이지</h3>
                  <p class="text-sm text-gray-600">메인 페이지 내용 관리</p>
                </a>
                <a href="/admin/pages/professor/edit" class="block p-4 border border-gray-200 rounded-lg hover:border-primary-300 hover:shadow-md transition-all">
                  <h3 class="font-semibold text-gray-900 mb-2">교수님 소개</h3>
                  <p class="text-sm text-gray-600">교수님 소개 페이지 관리</p>
                </a>
                <a href="/admin/pages/about/edit" class="block p-4 border border-gray-200 rounded-lg hover:border-primary-300 hover:shadow-md transition-all">
                  <h3 class="font-semibold text-gray-900 mb-2">소개 페이지</h3>
                  <p class="text-sm text-gray-600">소모임 소개 페이지 관리</p>
                </a>
              </div>
              
              {pages.results.length > 0 && (
                <div class="mt-8">
                  <h2 class="text-lg font-semibold text-gray-900 mb-4">페이지 목록</h2>
                  <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                      <thead class="bg-gray-50">
                        <tr>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">페이지</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">제목</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">수정일</th>
                          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">동작</th>
                        </tr>
                      </thead>
                      <tbody class="bg-white divide-y divide-gray-200">
                        {pages.results.map((page: any) => (
                          <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                              {page.page_key}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                              {page.title}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                              {new Date(page.updated_at).toLocaleDateString('ko-KR')}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                              <a href={`/admin/pages/${page.page_key}/edit`} class="text-primary-600 hover:text-primary-700">편집</a>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </Layout>,
      { title: '페이지 관리' }
    );

  } catch (error) {
    console.error('Admin pages error:', error);
    return c.redirect('/admin');
  }
});

