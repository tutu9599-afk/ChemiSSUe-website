            <h2 class="text-2xl font-semibold text-gray-900 mb-4">오류가 발생했습니다</h2>
            <p class="text-gray-600">페이지를 불러오는 중 문제가 발생했습니다.</p>
          </div>
        </div>
      </Layout>,
      { title: '오류' }
    );
