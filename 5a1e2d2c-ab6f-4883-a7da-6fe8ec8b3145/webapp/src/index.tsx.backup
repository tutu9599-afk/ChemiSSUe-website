// Admin Reports Page (활동 보고서)
app.get('/admin/reports', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 날짜 범위 설정
    const today = new Date().toISOString().split('T')[0];
    const lastWeek = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    const lastMonth = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

    // 회원 활동 통계
    const userStats = await Promise.all([
      // 활성 회원 수
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = 1').first(),
      // 비활성 회원 수  
      env.DB.prepare('SELECT COUNT(*) as count FROM users WHERE is_active = 0').first(),
      // 승인 대기 회원 수
      env.DB.prepare("SELECT COUNT(*) as count FROM users WHERE approval_status = 'pending'").first(),
      // 거부된 회원 수
      env.DB.prepare("SELECT COUNT(*) as count FROM users WHERE approval_status = 'rejected'").first(),
      // 이번 주 신규 가입자
      env.DB.prepare(`SELECT COUNT(*) as count FROM users WHERE created_at >= datetime('${lastWeek}')`).first(),
    ]);

    // 게시글/댓글 활동 통계
    const contentStats = await Promise.all([
      // 총 게시글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM posts').first(),
      // 이번 주 게시글 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM posts WHERE created_at >= datetime('${lastWeek}')`).first(),
      // 총 댓글 수
      env.DB.prepare('SELECT COUNT(*) as count FROM comments').first(),
      // 이번 주 댓글 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM comments WHERE created_at >= datetime('${lastWeek}')`).first(),
      // 총 이벤트 수
      env.DB.prepare('SELECT COUNT(*) as count FROM events').first(),
    ]);

    // 게시판별 활동 통계
    const boardStats = await env.DB.prepare(`
      SELECT 
        b.name as board_name,
        b.id as board_id,
        COUNT(p.id) as post_count,
        COUNT(CASE WHEN p.created_at >= datetime('${lastWeek}') THEN 1 END) as weekly_posts
      FROM boards b
      LEFT JOIN posts p ON b.id = p.board_id
      GROUP BY b.id, b.name
      ORDER BY post_count DESC
    `).all();

    // 최근 활동한 회원 목록
    const activeUsers = await env.DB.prepare(`
      SELECT 
        u.username,
        u.full_name,
        u.role,
        COUNT(DISTINCT p.id) as post_count,
        COUNT(DISTINCT c.id) as comment_count,
        MAX(COALESCE(p.created_at, c.created_at)) as last_activity
      FROM users u
      LEFT JOIN posts p ON u.id = p.author_id AND p.created_at >= datetime('${lastMonth}')
      LEFT JOIN comments c ON u.id = c.author_id AND c.created_at >= datetime('${lastMonth}')
      WHERE u.is_active = 1
      GROUP BY u.id, u.username, u.full_name, u.role
      HAVING (post_count > 0 OR comment_count > 0)
      ORDER BY last_activity DESC
      LIMIT 20
    `).all();

    // 인기 게시글 (좋아요 기준)
    const popularPosts = await env.DB.prepare(`
      SELECT 
        p.title,
        p.created_at,
        u.username as author,
        b.name as board_name,
        p.like_count,
        p.view_count
      FROM posts p
      JOIN users u ON p.author_id = u.id
      JOIN boards b ON p.board_id = b.id
      WHERE p.created_at >= datetime('${lastMonth}')
      ORDER BY p.like_count DESC, p.view_count DESC
      LIMIT 10
    `).all();

    const [activeUserCount, inactiveUserCount, pendingUserCount, rejectedUserCount, weeklyNewUsers] = userStats;
    const [totalPosts, weeklyPosts, totalComments, weeklyComments, totalEvents] = contentStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-chart-bar text-primary-600 mr-3"></i>
                활동 보고서
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">ChemiSSUe 회원 활동 및 콘텐츠 현황 보고서</p>
          </div>

          {/* 회원 활동 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-user-check text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 회원</p>
                  <p class="text-2xl font-bold text-gray-900">{activeUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-gray-100 text-gray-600">
                  <i class="fas fa-user-times text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">비활성 회원</p>
                  <p class="text-2xl font-bold text-gray-900">{inactiveUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
                  <i class="fas fa-user-clock text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">승인 대기</p>
                  <p class="text-2xl font-bold text-gray-900">{pendingUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-red-100 text-red-600">
                  <i class="fas fa-user-slash text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">가입 거부</p>
                  <p class="text-2xl font-bold text-gray-900">{rejectedUserCount.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-user-plus text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 신규</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyNewUsers.count}</p>
                </div>
              </div>
            </div>
          </div>

          {/* 콘텐츠 활동 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-file-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 게시글</p>
                  <p class="text-2xl font-bold text-gray-900">{totalPosts.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-indigo-100 text-indigo-600">
                  <i class="fas fa-plus-circle text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 게시글</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyPosts.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-teal-100 text-teal-600">
                  <i class="fas fa-comments text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 댓글</p>
                  <p class="text-2xl font-bold text-gray-900">{totalComments.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-cyan-100 text-cyan-600">
                  <i class="fas fa-comment-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">주간 댓글</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyComments.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-orange-100 text-orange-600">
                  <i class="fas fa-calendar-alt text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 이벤트</p>
                  <p class="text-2xl font-bold text-gray-900">{totalEvents.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {/* 게시판별 활동 현황 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-clipboard-list text-primary-600 mr-2"></i>
                  게시판별 활동 현황
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-4">
                  {boardStats.results.length > 0 ? (
                    boardStats.results.map((board: any) => (
                      <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900">{board.board_name}</h4>
                          <p class="text-sm text-gray-600">이번 주: {board.weekly_posts}개 게시글</p>
                        </div>
                        <div class="text-right">
                          <span class="text-lg font-bold text-primary-600">{board.post_count}</span>
                          <p class="text-xs text-gray-500">총 게시글</p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-inbox text-4xl mb-4"></i>
                      <p>게시판 데이터가 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 최근 활동 회원 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-users text-primary-600 mr-2"></i>
                  최근 활동 회원 (최근 30일)
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-3">
                  {activeUsers.results.length > 0 ? (
                    activeUsers.results.map((activeUser: any) => (
                      <div class="flex justify-between items-center p-3 border border-gray-200 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900">
                            {activeUser.full_name} 
                            <span class="text-sm text-gray-500">(@{activeUser.username})</span>
                          </h4>
                          <div class="flex space-x-4 text-sm text-gray-600">
                            <span>게시글: {activeUser.post_count}</span>
                            <span>댓글: {activeUser.comment_count}</span>
                          </div>
                        </div>
                        <div class="text-right">
                          <span class={`px-2 py-1 text-xs rounded-full ${
                            activeUser.role === 'admin' ? 'bg-red-100 text-red-600' :
                            activeUser.role === 'moderator' ? 'bg-yellow-100 text-yellow-600' :
                            'bg-gray-100 text-gray-600'
                          }`}>
                            {activeUser.role === 'admin' ? '관리자' : 
                             activeUser.role === 'moderator' ? '모더레이터' : '회원'}
                          </span>
                          <p class="text-xs text-gray-500 mt-1">
                            {activeUser.last_activity ? 
                              new Date(activeUser.last_activity).toLocaleDateString('ko-KR') :
                              '-'
                            }
                          </p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-user-friends text-4xl mb-4"></i>
                      <p>최근 활동 회원이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* 인기 게시글 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-fire text-primary-600 mr-2"></i>
                  인기 게시글 (최근 30일)
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-3">
                  {popularPosts.results.length > 0 ? (
                    popularPosts.results.map((post: any, index: number) => (
                      <div class="flex justify-between items-center p-3 border border-gray-200 rounded-lg">
                        <div class="flex items-center space-x-3">
                          <span class={`flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${
                            index < 3 ? 'bg-yellow-100 text-yellow-600' : 'bg-gray-100 text-gray-600'
                          }`}>
                            {index + 1}
                          </span>
                          <div>
                            <h4 class="font-medium text-gray-900">{post.title}</h4>
                            <div class="flex space-x-4 text-sm text-gray-600">
                              <span>작성자: {post.author}</span>
                              <span>게시판: {post.board_name}</span>
                              <span>{new Date(post.created_at).toLocaleDateString('ko-KR')}</span>
                            </div>
                          </div>
                        </div>
                        <div class="flex space-x-4 text-sm">
                          <div class="text-center">
                            <i class="fas fa-heart text-red-500"></i>
                            <span class="ml-1 font-medium">{post.like_count}</span>
                          </div>
                          <div class="text-center">
                            <i class="fas fa-eye text-blue-500"></i>
                            <span class="ml-1 font-medium">{post.view_count}</span>
                          </div>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-chart-line text-4xl mb-4"></i>
                      <p>인기 게시글이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </Layout>,
      { title: '활동 보고서' }
    );

  } catch (error) {
    console.error('Admin reports error:', error);
    return c.redirect('/admin');
  }
});

// Admin Backup Management Page (백업 관리)
app.get('/admin/backup', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 데이터베이스 테이블 목록 가져오기
    const tables = await env.DB.prepare(`
      SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%'
    `).all();

    // 각 테이블의 행 수 확인
    const tableStats = [];
    for (const table of tables.results) {
      const count = await env.DB.prepare(`SELECT COUNT(*) as count FROM ${table.name}`).first();
      tableStats.push({
        name: table.name,
        count: count.count
      });
    }

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-database text-primary-600 mr-3"></i>
                백업 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">데이터베이스 백업 및 내보내기 관리</p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            {/* 데이터베이스 현황 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-table text-primary-600 mr-2"></i>
                  데이터베이스 현황
                </h3>
              </div>
              <div class="p-6">
                <div class="space-y-4">
                  {tableStats.length > 0 ? (
                    tableStats.map((table) => (
                      <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                        <div>
                          <h4 class="font-medium text-gray-900 capitalize">{table.name}</h4>
                          <p class="text-sm text-gray-600">
                            {table.name === 'users' ? '회원 데이터' :
                             table.name === 'posts' ? '게시글 데이터' :
                             table.name === 'comments' ? '댓글 데이터' :
                             table.name === 'boards' ? '게시판 데이터' :
                             table.name === 'events' ? '이벤트 데이터' :
                             table.name === 'sessions' ? '세션 데이터' :
                             table.name === 'board_permissions' ? '권한 데이터' :
                             table.name === 'page_contents' ? '페이지 데이터' :
                             '기타 데이터'
                            }
                          </p>
                        </div>
                        <div class="text-right">
                          <span class="text-lg font-bold text-primary-600">{table.count.toLocaleString()}</span>
                          <p class="text-xs text-gray-500">레코드</p>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-database text-4xl mb-4"></i>
                      <p>테이블을 찾을 수 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 백업 작업 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-download text-primary-600 mr-2"></i>
                  데이터 내보내기
                </h3>
              </div>
              <div class="p-6 space-y-4">
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                  <div class="flex items-start">
                    <i class="fas fa-info-circle text-blue-500 mt-1 mr-3"></i>
                    <div>
                      <h4 class="font-medium text-blue-900 mb-2">백업 정보</h4>
                      <p class="text-sm text-blue-700 leading-relaxed">
                        Cloudflare D1 데이터베이스는 자동으로 백업이 관리됩니다. 
                        여기서는 데이터를 SQL 덤프 또는 CSV 형태로 내보낼 수 있습니다.
                      </p>
                    </div>
                  </div>
                </div>

                <div class="space-y-3">
                  <button 
                    onclick="exportFullBackup()" 
                    class="w-full bg-primary-600 text-white py-3 px-4 rounded-lg hover:bg-primary-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-file-export mr-2"></i>
                    전체 데이터 SQL 덤프 생성
                  </button>
                  
                  <button 
                    onclick="exportUsers()" 
                    class="w-full bg-green-600 text-white py-3 px-4 rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-users mr-2"></i>
                    회원 데이터 CSV 내보내기
                  </button>
                  
                  <button 
                    onclick="exportPosts()" 
                    class="w-full bg-purple-600 text-white py-3 px-4 rounded-lg hover:bg-purple-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-file-alt mr-2"></i>
                    게시글 데이터 CSV 내보내기
                  </button>
                  
                  <button 
                    onclick="exportEvents()" 
                    class="w-full bg-orange-600 text-white py-3 px-4 rounded-lg hover:bg-orange-700 transition-colors flex items-center justify-center"
                  >
                    <i class="fas fa-calendar-alt mr-2"></i>
                    이벤트 데이터 CSV 내보내기
                  </button>
                </div>

                <div id="backup-status" class="mt-4 p-3 bg-gray-50 rounded-lg text-sm text-gray-600 hidden">
                  <div class="flex items-center">
                    <i class="fas fa-spinner fa-spin mr-2"></i>
                    백업을 생성 중입니다...
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* 백업 기록 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-history text-primary-600 mr-2"></i>
                  백업 작업 가이드
                </h3>
              </div>
              <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="space-y-4">
                    <h4 class="font-medium text-gray-900">자동 백업 (Cloudflare D1)</h4>
                    <ul class="space-y-2 text-sm text-gray-600">
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        데이터베이스는 자동으로 백업됩니다
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        Point-in-time 복구 지원
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-check-circle text-green-500 mt-1 mr-2"></i>
                        지역별 복제를 통한 안정성
                      </li>
                    </ul>
                  </div>
                  
                  <div class="space-y-4">
                    <h4 class="font-medium text-gray-900">수동 내보내기</h4>
                    <ul class="space-y-2 text-sm text-gray-600">
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        SQL 덤프: 전체 데이터베이스 구조 + 데이터
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        CSV 내보내기: 개별 테이블 데이터
                      </li>
                      <li class="flex items-start">
                        <i class="fas fa-download text-blue-500 mt-1 mr-2"></i>
                        분석이나 마이그레이션 용도
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <script dangerouslySetInnerHTML={{__html: `
          async function exportFullBackup() {
            showBackupStatus('전체 데이터 SQL 덤프를 생성하고 있습니다...');
            try {
              const response = await fetch('/api/admin/backup/sql', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'chemissue_backup_' + new Date().toISOString().split('T')[0] + '.sql';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
                hideBackupStatus();
              } else {
                throw new Error('백업 생성 실패');
              }
            } catch (error) {
              console.error('Export error:', error);
              alert('백업 생성 중 오류가 발생했습니다.');
              hideBackupStatus();
            }
          }

          async function exportUsers() {
            await exportCSV('users', '회원');
          }

          async function exportPosts() {
            await exportCSV('posts', '게시글');
          }

          async function exportEvents() {
            await exportCSV('events', '이벤트');
          }

          async function exportCSV(table, name) {
            showBackupStatus(name + ' 데이터를 CSV로 내보내고 있습니다...');
            try {
              const response = await fetch('/api/admin/backup/csv/' + table, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              });
              
              if (response.ok) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'chemissue_' + table + '_' + new Date().toISOString().split('T')[0] + '.csv';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
                hideBackupStatus();
              } else {
                throw new Error(name + ' 데이터 내보내기 실패');
              }
            } catch (error) {
              console.error('Export error:', error);
              alert(name + ' 데이터 내보내기 중 오류가 발생했습니다.');
              hideBackupStatus();
            }
          }

          function showBackupStatus(message) {
            const status = document.getElementById('backup-status');
            status.querySelector('div').innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>' + message;
            status.classList.remove('hidden');
          }

          function hideBackupStatus() {
            const status = document.getElementById('backup-status');
            status.classList.add('hidden');
          }
        `}} />
      </Layout>,
      { title: '백업 관리' }
    );

  } catch (error) {
    console.error('Admin backup page error:', error);
    return c.redirect('/admin');
  }
});

// API: SQL 덤프 생성
app.post('/api/admin/backup/sql', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    
    // 테이블 목록 가져오기
    const tables = await env.DB.prepare(`
      SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%'
    `).all();

    let sqlDump = `-- ChemiSSUe Database Backup\n-- Generated on ${new Date().toISOString()}\n\n`;

    for (const table of tables.results) {
      // 테이블 스키마 가져오기
      const schema = await env.DB.prepare(`
        SELECT sql FROM sqlite_master WHERE type='table' AND name = ?
      `).bind(table.name).first();

      if (schema) {
        sqlDump += `-- Table: ${table.name}\n`;
        sqlDump += `${schema.sql};\n\n`;

        // 데이터 가져오기
        const data = await env.DB.prepare(`SELECT * FROM ${table.name}`).all();
        
        if (data.results.length > 0) {
          const columns = Object.keys(data.results[0]);
          
          for (const row of data.results) {
            const values = columns.map(col => {
              const val = row[col];
              if (val === null) return 'NULL';
              if (typeof val === 'string') return `'${val.replace(/'/g, "''")}'`;
              return val;
            }).join(', ');
            
            sqlDump += `INSERT INTO ${table.name} (${columns.join(', ')}) VALUES (${values});\n`;
          }
          sqlDump += '\n';
        }
      }
    }

    return new Response(sqlDump, {
      headers: {
        'Content-Type': 'text/plain',
        'Content-Disposition': `attachment; filename="chemissue_backup_${new Date().toISOString().split('T')[0]}.sql"`
      }
    });

  } catch (error) {
    console.error('SQL backup error:', error);
    return c.json({ error: '백업 생성 중 오류가 발생했습니다.' }, 500);
  }
});

// API: CSV 내보내기
app.post('/api/admin/backup/csv/:table', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const tableName = c.req.param('table');
    
    // 허용된 테이블만 내보내기
    const allowedTables = ['users', 'posts', 'comments', 'events', 'boards'];
    if (!allowedTables.includes(tableName)) {
      return c.json({ error: '허용되지 않은 테이블입니다.' }, 400);
    }

    const data = await env.DB.prepare(`SELECT * FROM ${tableName}`).all();
    
    if (data.results.length === 0) {
      return c.json({ error: '데이터가 없습니다.' }, 404);
    }

    // CSV 헤더
    const columns = Object.keys(data.results[0]);
    let csv = columns.join(',') + '\n';

    // CSV 데이터
    for (const row of data.results) {
      const values = columns.map(col => {
        const val = row[col];
        if (val === null) return '';
        if (typeof val === 'string' && (val.includes(',') || val.includes('"') || val.includes('\n'))) {
          return `"${val.replace(/"/g, '""')}"`;
        }
        return val;
      }).join(',');
      csv += values + '\n';
    }

    return new Response(csv, {
      headers: {
        'Content-Type': 'text/csv',
        'Content-Disposition': `attachment; filename="chemissue_${tableName}_${new Date().toISOString().split('T')[0]}.csv"`
      }
    });

  } catch (error) {
    console.error('CSV export error:', error);
    return c.json({ error: 'CSV 내보내기 중 오류가 발생했습니다.' }, 500);
  }
});

// Admin Messages Management Page (메시지 관리)
app.get('/admin/messages', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 메시지 통계
    const messageStats = await Promise.all([
      // 총 메시지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM messages').first(),
      // 읽지 않은 메시지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM messages WHERE is_read = 0').first(),
      // 오늘 보낸 메시지 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM messages WHERE date(created_at) = date('now')`).first(),
      // 이번 주 메시지 수
      env.DB.prepare(`SELECT COUNT(*) as count FROM messages WHERE created_at >= datetime('now', '-7 days')`).first(),
    ]);

    // 최근 메시지 목록
    const recentMessages = await env.DB.prepare(`
      SELECT 
        m.id,
        m.subject,
        m.content,
        m.is_read,
        m.created_at,
        s.username as sender_username,
        s.full_name as sender_name,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      ORDER BY m.created_at DESC
      LIMIT 50
    `).all();

    // 활발한 메시지 사용자
    const activeMessagers = await env.DB.prepare(`
      SELECT 
        u.username,
        u.full_name,
        u.role,
        COUNT(DISTINCT m1.id) as sent_count,
        COUNT(DISTINCT m2.id) as received_count,
        COUNT(DISTINCT m1.id) + COUNT(DISTINCT m2.id) as total_count
      FROM users u
      LEFT JOIN messages m1 ON u.id = m1.sender_id AND m1.created_at >= datetime('now', '-30 days')
      LEFT JOIN messages m2 ON u.id = m2.recipient_id AND m2.created_at >= datetime('now', '-30 days')
      WHERE u.is_active = 1
      GROUP BY u.id, u.username, u.full_name, u.role
      HAVING total_count > 0
      ORDER BY total_count DESC
      LIMIT 15
    `).all();

    const [totalMessages, unreadMessages, todayMessages, weeklyMessages] = messageStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-envelope text-primary-600 mr-3"></i>
                메시지 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">회원 간 메시지 관리 및 통계</p>
          </div>

          {/* 메시지 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-envelope text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 메시지</p>
                  <p class="text-2xl font-bold text-gray-900">{totalMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-red-100 text-red-600">
                  <i class="fas fa-envelope-open text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">읽지 않음</p>
                  <p class="text-2xl font-bold text-gray-900">{unreadMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-calendar-day text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">오늘 메시지</p>
                  <p class="text-2xl font-bold text-gray-900">{todayMessages.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-calendar-week text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">이번 주</p>
                  <p class="text-2xl font-bold text-gray-900">{weeklyMessages.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {/* 최근 메시지 목록 */}
            <div class="lg:col-span-2">
              <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                  <h3 class="text-lg font-semibold text-gray-900">
                    <i class="fas fa-list text-primary-600 mr-2"></i>
                    최근 메시지
                  </h3>
                  <div class="flex space-x-2">
                    <button 
                      onclick="window.location.reload()" 
                      class="px-3 py-1 text-sm bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors"
                    >
                      <i class="fas fa-refresh mr-1"></i>새로고침
                    </button>
                  </div>
                </div>
                <div class="max-h-96 overflow-y-auto">
                  {recentMessages.results.length > 0 ? (
                    <div class="divide-y divide-gray-200">
                      {recentMessages.results.map((message: any) => (
                        <div class="p-4 hover:bg-gray-50">
                          <div class="flex justify-between items-start">
                            <div class="flex-1">
                              <div class="flex items-center space-x-2 mb-2">
                                <span class={`px-2 py-1 text-xs rounded-full ${
                                  message.is_read ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600'
                                }`}>
                                  {message.is_read ? '읽음' : '미읽음'}
                                </span>
                                <span class="text-sm font-medium text-gray-900">{message.subject}</span>
                              </div>
                              <div class="text-sm text-gray-600 mb-2">
                                <span class="font-medium">{message.sender_name}</span> 
                                <span class="text-gray-400 mx-1">→</span>
                                <span class="font-medium">{message.recipient_name}</span>
                              </div>
                              <p class="text-sm text-gray-500 line-clamp-2">
                                {message.content.substring(0, 100)}...
                              </p>
                            </div>
                            <div class="text-right text-xs text-gray-400">
                              {new Date(message.created_at).toLocaleString('ko-KR')}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-12 text-gray-500">
                      <i class="fas fa-inbox text-4xl mb-4"></i>
                      <p>메시지가 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>

            {/* 활발한 메시지 사용자 */}
            <div class="lg:col-span-1">
              <div class="bg-white rounded-lg shadow">
                <div class="px-6 py-4 border-b border-gray-200">
                  <h3 class="text-lg font-semibold text-gray-900">
                    <i class="fas fa-users text-primary-600 mr-2"></i>
                    활발한 사용자 (30일)
                  </h3>
                </div>
                <div class="max-h-96 overflow-y-auto">
                  {activeMessagers.results.length > 0 ? (
                    <div class="p-4 space-y-3">
                      {activeMessagers.results.map((user: any, index: number) => (
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                          <div class="flex items-center space-x-3">
                            <span class={`flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold ${
                              index < 3 ? 'bg-yellow-100 text-yellow-600' : 'bg-gray-100 text-gray-600'
                            }`}>
                              {index + 1}
                            </span>
                            <div>
                              <h4 class="text-sm font-medium text-gray-900">{user.full_name}</h4>
                              <p class="text-xs text-gray-500">@{user.username}</p>
                            </div>
                          </div>
                          <div class="text-right">
                            <div class="text-sm font-bold text-primary-600">{user.total_count}</div>
                            <div class="text-xs text-gray-500">
                              보냄 {user.sent_count} | 받음 {user.received_count}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <div class="text-center py-8 text-gray-500">
                      <i class="fas fa-user-friends text-4xl mb-4"></i>
                      <p>활동이 없습니다.</p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* 관리 작업 */}
          <div class="mt-8">
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-cogs text-primary-600 mr-2"></i>
                  관리 작업
                </h3>
              </div>
              <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <button class="bg-blue-600 text-white py-3 px-4 rounded-lg hover:bg-blue-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-check-double mr-2"></i>
                    모든 메시지 읽음 처리
                  </button>
                  
                  <button class="bg-red-600 text-white py-3 px-4 rounded-lg hover:bg-red-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-trash-alt mr-2"></i>
                    오래된 메시지 삭제 (30일 이상)
                  </button>
                  
                  <button class="bg-green-600 text-white py-3 px-4 rounded-lg hover:bg-green-700 transition-colors flex items-center justify-center">
                    <i class="fas fa-download mr-2"></i>
                    메시지 내역 내보내기
                  </button>
                </div>

                <div id="admin-action-status" class="mt-4 p-3 bg-gray-50 rounded-lg text-sm text-gray-600 hidden">
                  <div class="flex items-center">
                    <i class="fas fa-spinner fa-spin mr-2"></i>
                    작업을 처리하고 있습니다...
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

{/* 메시지 상세 보기 기능은 추후 구현 */}

        <script dangerouslySetInnerHTML={{__html: `
          async function refreshMessages() {
            window.location.reload();
          }

          function viewMessage(messageId) {
            alert('메시지 상세보기 기능은 준비 중입니다.');
            // TODO: 메시지 상세보기 구현
                  <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4 text-sm">
                      <div>
                        <span class="font-medium text-gray-700">보낸 사람:</span>
                        <span class="ml-2">${message.sender_name} (@${message.sender_username})</span>
                      </div>
                      <div>
                        <span class="font-medium text-gray-700">받는 사람:</span>
                        <span class="ml-2">${message.recipient_name} (@${message.recipient_username})</span>
                      </div>
                      <div>
                        <span class="font-medium text-gray-700">보낸 시간:</span>
                        <span class="ml-2">${new Date(message.created_at).toLocaleString('ko-KR')}</span>
                      </div>
                      <div>
                        <span class="font-medium text-gray-700">읽은 상태:</span>
                        <span class="ml-2 ${message.is_read ? 'text-green-600' : 'text-red-600'}">${message.is_read ? '읽음' : '미읽음'}</span>
                      </div>
                    </div>
                    <div>
                      <div class="font-medium text-gray-700 mb-2">제목:</div>
                      <div class="text-lg font-medium">${message.subject}</div>
                    </div>
                    <div>
                      <div class="font-medium text-gray-700 mb-2">내용:</div>
                      <div class="bg-gray-50 p-4 rounded-lg whitespace-pre-wrap">${message.content}</div>
                    </div>
                    <div class="flex space-x-2 pt-4 border-t">
                      <button onclick="deleteMessage(${message.id})" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">
                        <i class="fas fa-trash mr-1"></i> 삭제
                      </button>
                      <button onclick="closeMessageModal()" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">
                        닫기
                      </button>
                    </div>
                  </div>
                `;
                document.getElementById('message-modal').classList.remove('hidden');
              }
            } catch (error) {
              console.error('Error loading message:', error);
              alert('메시지를 불러올 수 없습니다.');
            }
          }

          function closeMessageModal() {
            document.getElementById('message-modal').classList.add('hidden');
          }

          async function deleteMessage(messageId) {
            if (!confirm('정말 이 메시지를 삭제하시겠습니까?')) return;
            
            try {
              const response = await fetch('/api/admin/messages/' + messageId, { method: 'DELETE' });
              const data = await response.json();
              
              if (data.success) {
                alert('메시지가 삭제되었습니다.');
                closeMessageModal();
                refreshMessages();
              } else {
                alert('삭제 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Delete error:', error);
              alert('삭제 중 오류가 발생했습니다.');
            }
          }

          async function markAllAsRead() {
            if (!confirm('모든 메시지를 읽음 처리하시겠습니까?')) return;
            
            showAdminActionStatus('모든 메시지를 읽음 처리하고 있습니다...');
            try {
              const response = await fetch('/api/admin/messages/mark-all-read', { method: 'POST' });
              const data = await response.json();
              
              if (data.success) {
                alert(data.count + '개의 메시지가 읽음 처리되었습니다.');
                refreshMessages();
              } else {
                alert('처리 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Mark as read error:', error);
              alert('처리 중 오류가 발생했습니다.');
            } finally {
              hideAdminActionStatus();
            }
          }

          async function deleteOldMessages() {
            if (!confirm('30일 이상된 메시지를 모두 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.')) return;
            
            showAdminActionStatus('오래된 메시지를 삭제하고 있습니다...');
            try {
              const response = await fetch('/api/admin/messages/delete-old', { method: 'DELETE' });
              const data = await response.json();
              
              if (data.success) {
                alert(data.count + '개의 오래된 메시지가 삭제되었습니다.');
                refreshMessages();
              } else {
                alert('삭제 실패: ' + data.error);
              }
            } catch (error) {
              console.error('Delete old messages error:', error);
              alert('삭제 중 오류가 발생했습니다.');
            } finally {
              hideAdminActionStatus();
            }
          }

          async function exportMessages() {
            showAdminActionStatus('메시지 내역을 내보내고 있습니다...');
            try {
              const response = await fetch('/api/admin/messages/export', { method: 'POST' });
              
              if (response.ok) {
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'messages_export_' + new Date().toISOString().split('T')[0] + '.csv';
                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(url);
                document.body.removeChild(a);
              } else {
                throw new Error('내보내기 실패');
              }
            } catch (error) {
              console.error('Export error:', error);
              alert('내보내기 중 오류가 발생했습니다.');
            } finally {
              hideAdminActionStatus();
            }
          }

          function showAdminActionStatus(message) {
            const status = document.getElementById('admin-action-status');
            status.querySelector('div').innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>' + message;
            status.classList.remove('hidden');
          }

          function hideAdminActionStatus() {
            const status = document.getElementById('admin-action-status');
            status.classList.add('hidden');
          }
        `}} />
      </Layout>,
      { title: '메시지 관리' }
    );

  } catch (error) {
    console.error('Admin messages page error:', error);
    return c.redirect('/admin');
  }
});

// API: 개별 메시지 조회
app.get('/api/admin/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    const message = await env.DB.prepare(`
      SELECT 
        m.*,
        s.username as sender_username,
        s.full_name as sender_name,
        r.username as recipient_username,
        r.full_name as recipient_name
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      WHERE m.id = ?
    `).bind(messageId).first();

    if (!message) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    return c.json({ success: true, message });

  } catch (error) {
    console.error('Get message error:', error);
    return c.json({ error: '메시지를 불러올 수 없습니다.' }, 500);
  }
});

// API: 메시지 삭제
app.delete('/api/admin/messages/:id', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;
    const messageId = c.req.param('id');

    const result = await env.DB.prepare('DELETE FROM messages WHERE id = ?').bind(messageId).run();
    
    if (result.changes === 0) {
      return c.json({ error: '메시지를 찾을 수 없습니다.' }, 404);
    }

    return c.json({ success: true });

  } catch (error) {
    console.error('Delete message error:', error);
    return c.json({ error: '메시지 삭제에 실패했습니다.' }, 500);
  }
});

// API: 모든 메시지 읽음 처리
app.post('/api/admin/messages/mark-all-read', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const result = await env.DB.prepare(`
      UPDATE messages 
      SET is_read = 1, read_at = datetime('now') 
      WHERE is_read = 0
    `).run();

    return c.json({ success: true, count: result.changes });

  } catch (error) {
    console.error('Mark all as read error:', error);
    return c.json({ error: '읽음 처리에 실패했습니다.' }, 500);
  }
});

// API: 오래된 메시지 삭제
app.delete('/api/admin/messages/delete-old', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const result = await env.DB.prepare(`
      DELETE FROM messages 
      WHERE created_at < datetime('now', '-30 days')
    `).run();

    return c.json({ success: true, count: result.changes });

  } catch (error) {
    console.error('Delete old messages error:', error);
    return c.json({ error: '오래된 메시지 삭제에 실패했습니다.' }, 500);
  }
});

// API: 메시지 내역 내보내기
app.post('/api/admin/messages/export', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.json({ error: '권한이 없습니다.' }, 403);
  }

  try {
    const { env } = c;

    const messages = await env.DB.prepare(`
      SELECT 
        m.id,
        s.username as sender,
        r.username as recipient,
        m.subject,
        m.content,
        m.is_read,
        m.created_at,
        m.read_at
      FROM messages m
      JOIN users s ON m.sender_id = s.id
      JOIN users r ON m.recipient_id = r.id
      ORDER BY m.created_at DESC
    `).all();

    if (messages.results.length === 0) {
      return c.json({ error: '내보낼 메시지가 없습니다.' }, 404);
    }

    // CSV 헤더
    let csv = 'ID,보낸사람,받는사람,제목,내용,읽음여부,보낸시간,읽은시간\n';

    // CSV 데이터
    for (const message of messages.results) {
      const csvRow = [
        message.id,
        message.sender,
        message.recipient,
        `"${message.subject.replace(/"/g, '""')}"`,
        `"${message.content.replace(/"/g, '""').substring(0, 200)}"`,
        message.is_read ? '읽음' : '미읽음',
        message.created_at,
        message.read_at || ''
      ].join(',');
      csv += csvRow + '\n';
    }

    return new Response(csv, {
      headers: {
        'Content-Type': 'text/csv; charset=utf-8',
        'Content-Disposition': `attachment; filename="messages_export_${new Date().toISOString().split('T')[0]}.csv"`
      }
    });

  } catch (error) {
    console.error('Export messages error:', error);
    return c.json({ error: '내보내기에 실패했습니다.' }, 500);
  }
});

// Admin Broadcast/Notification Management Page (공지 발송)
app.get('/admin/broadcast', async (c) => {
  const user = c.get('user');
  if (!user || user.role !== 'admin') {
    return c.redirect('/auth/login');
  }

  try {
    const { env } = c;
    
    // 공지 통계
    const broadcastStats = await Promise.all([
      // 총 공지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications').first(),
      // 활성 공지 수
      env.DB.prepare('SELECT COUNT(*) as count FROM notifications WHERE is_active = 1').first(),
      // 총 공고/공지글 수  
      env.DB.prepare('SELECT COUNT(*) as count FROM announcements').first(),
      // 활성 공고 수
      env.DB.prepare('SELECT COUNT(*) as count FROM announcements WHERE is_active = 1').first(),
    ]);

    // 최근 발송 공지
    const recentNotifications = await env.DB.prepare(`
      SELECT 
        n.*,
        u.username as sender_username,
        u.full_name as sender_name,
        COUNT(nr.id) as recipient_count,
        COUNT(CASE WHEN nr.is_read = 1 THEN 1 END) as read_count
      FROM notifications n
      JOIN users u ON n.sender_id = u.id
      LEFT JOIN notification_recipients nr ON n.id = nr.notification_id
      GROUP BY n.id, n.title, n.content, n.sender_id, n.notification_type, n.target_type, n.target_value, n.is_active, n.created_at, n.expires_at, u.username, u.full_name
      ORDER BY n.created_at DESC
      LIMIT 20
    `).all();

    // 최근 공고글
    const recentAnnouncements = await env.DB.prepare(`
      SELECT 
        a.*,
        u.username as author_username,
        u.full_name as author_name
      FROM announcements a
      JOIN users u ON a.author_id = u.id
      ORDER BY a.created_at DESC
      LIMIT 10
    `).all();

    // 게시판 목록 (공고 대상 선택용)
    const boards = await env.DB.prepare('SELECT id, name FROM boards ORDER BY name').all();

    // 역할별 회원 수
    const roleStats = await env.DB.prepare(`
      SELECT 
        role,
        COUNT(*) as count
      FROM users
      WHERE is_active = 1
      GROUP BY role
    `).all();

    const [totalNotifications, activeNotifications, totalAnnouncements, activeAnnouncements] = broadcastStats;

    return c.render(
      <Layout user={user}>
        <div class="max-w-7xl mx-auto px-4 py-8">
          <div class="mb-8">
            <div class="flex justify-between items-center">
              <h1 class="text-3xl font-bold text-gray-900">
                <i class="fas fa-bullhorn text-primary-600 mr-3"></i>
                공지 발송 관리
              </h1>
              <a href="/admin" class="text-primary-600 hover:text-primary-700 font-medium">
                ← 관리자 패널
              </a>
            </div>
            <p class="text-gray-600 mt-2">전체/개별 공지사항 및 알림 발송 관리</p>
          </div>

          {/* 통계 */}
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                  <i class="fas fa-bell text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 알림</p>
                  <p class="text-2xl font-bold text-gray-900">{totalNotifications.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-green-100 text-green-600">
                  <i class="fas fa-bell-slash text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 알림</p>
                  <p class="text-2xl font-bold text-gray-900">{activeNotifications.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                  <i class="fas fa-megaphone text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">총 공고</p>
                  <p class="text-2xl font-bold text-gray-900">{totalAnnouncements.count}</p>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex items-center">
                <div class="p-3 rounded-full bg-orange-100 text-orange-600">
                  <i class="fas fa-thumbtack text-xl"></i>
                </div>
                <div class="ml-4">
                  <p class="text-sm font-medium text-gray-600">활성 공고</p>
                  <p class="text-2xl font-bold text-gray-900">{activeAnnouncements.count}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            {/* 새 알림 발송 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-paper-plane text-primary-600 mr-2"></i>
                  새 알림 발송
                </h3>
              </div>
              <div class="p-6">
                <form id="notification-form" class="space-y-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">알림 제목</label>
                    <input type="text" id="notification-title" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="알림 제목을 입력하세요" required />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">알림 내용</label>
                    <textarea id="notification-content" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="알림 내용을 입력하세요" required></textarea>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">알림 유형</label>
                      <select id="notification-type" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                        <option value="general">일반</option>
                        <option value="important">중요</option>
                        <option value="system">시스템</option>
                        <option value="event">이벤트</option>
                      </select>
                    </div>
                    
                    <div>
                      <label class="block text-sm font-medium text-gray-700 mb-2">발송 대상</label>
                      <select id="target-type" class="w-full border border-gray-300 rounded-lg px-3 py-2" onchange="toggleTargetOptions()">
                        <option value="all">전체 회원</option>
                        <option value="role">역할별</option>
                        <option value="specific">특정 회원</option>
                      </select>
                    </div>
                  </div>
                  
                  <div id="target-options" class="hidden">
                    <label class="block text-sm font-medium text-gray-700 mb-2">대상 선택</label>
                    <div id="role-options" class="space-y-2 hidden">
                      <label class="flex items-center">
                        <input type="checkbox" value="admin" class="mr-2" /> 관리자 ({roleStats.results.find(r => r.role === 'admin')?.count || 0}명)
                      </label>
                      <label class="flex items-center">
                        <input type="checkbox" value="moderator" class="mr-2" /> 모더레이터 ({roleStats.results.find(r => r.role === 'moderator')?.count || 0}명)
                      </label>
                      <label class="flex items-center">
                        <input type="checkbox" value="member" class="mr-2" /> 일반 회원 ({roleStats.results.find(r => r.role === 'member')?.count || 0}명)
                      </label>
                    </div>
                    <input type="text" id="specific-users" placeholder="회원명 또는 이메일 (쉼표로 구분)" class="w-full border border-gray-300 rounded-lg px-3 py-2 hidden" />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">만료일 (선택사항)</label>
                    <input type="datetime-local" id="expires-at" class="w-full border border-gray-300 rounded-lg px-3 py-2" />
                  </div>
                  
                  <button type="submit" class="w-full bg-primary-600 text-white py-3 rounded-lg hover:bg-primary-700 transition-colors">
                    <i class="fas fa-paper-plane mr-2"></i>알림 발송
                  </button>
                </form>
              </div>
            </div>

            {/* 새 공고 작성 */}
            <div class="bg-white rounded-lg shadow">
              <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">
                  <i class="fas fa-plus-circle text-primary-600 mr-2"></i>
                  새 공고 작성
                </h3>
              </div>
              <div class="p-6">
                <form id="announcement-form" class="space-y-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">공고 제목</label>
                    <input type="text" id="announcement-title" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="공고 제목을 입력하세요" required />
                  </div>
                  
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">공고 내용</label>
                    <textarea id="announcement-content" rows="4" class="w-full border border-gray-300 rounded-lg px-3 py-2" placeholder="공고 내용을 입력하세요" required></textarea>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-4">
