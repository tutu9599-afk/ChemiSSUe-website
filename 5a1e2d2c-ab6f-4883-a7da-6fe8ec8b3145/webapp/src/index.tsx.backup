  });
} else {
  window.ChemiSSUe.initializeComponents();
}

console.log('[ChemiSSUe] App.js loaded successfully');
  `;
  
  return new Response(js, {
    headers: { 
      'Content-Type': 'application/javascript',
      'Cache-Control': 'public, max-age=86400'
    }
  });
})

